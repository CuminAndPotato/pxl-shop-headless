---
import type { Locale } from '../i18n/strings';
import type { Product } from '../lib/shop';
import type { PageVariant } from '../lib/page-variants';
import DefaultLayout from './DefaultLayout.astro';
import DevLayout from './DevLayout.astro';
import MakerLayout from './MakerLayout.astro';
import OriginalDraftPage from './OriginalDraftPage.astro';
import OriginalTweakPage from './OriginalTweakPage.astro';
import ExperimentPage from './ExperimentPage.astro';
import StoryRibbonPage from './StoryRibbonPage.astro';
import LivingSidebarPage from './LivingSidebarPage.astro';
import PixelNativePage from './PixelNativePage.astro';
import EditorialObjectPage from './EditorialObjectPage.astro';
import QuietDropPage from './QuietDropPage.astro';
import OriginalPlusPage from './OriginalPlusPage.astro';
import OriginalPlus2Page from './OriginalPlus2Page.astro';
import OriginalPlus3Page from './OriginalPlus3Page.astro';
import OriginalPlus4Page from './OriginalPlus4Page.astro';
import OriginalPlus5Page from './OriginalPlus5Page.astro';
import OriginalPlus6Page from './OriginalPlus6Page.astro';
import OriginalPlus7Page from './OriginalPlus7Page.astro';

// === Single source of truth: layout slug → Astro component =================
// Adding a new variant is now a TWO-file change: register in page-variants.ts
// and (if it uses a new layout) add a row here. Old setup required four files.
const LAYOUT_COMPONENTS = {
  default:    DefaultLayout,
  dev:        DevLayout,
  maker:      MakerLayout,
  original:   OriginalDraftPage,
  tweak:      OriginalTweakPage,
  experiment: ExperimentPage,
  ribbon:     StoryRibbonPage,
  sidebar:    LivingSidebarPage,
  native:     PixelNativePage,
  editorial:  EditorialObjectPage,
  drop:       QuietDropPage,
  plus:       OriginalPlusPage,
  plus2:      OriginalPlus2Page,
  plus3:      OriginalPlus3Page,
  plus4:      OriginalPlus4Page,
  plus5:      OriginalPlus5Page,
  plus6:      OriginalPlus6Page,
  plus7:      OriginalPlus7Page,
} as const;

interface Props {
  locale: Locale;
  variant: PageVariant;
  product: Product | null;
}

const { locale, variant, product } = Astro.props;
const Layout = LAYOUT_COMPONENTS[variant.layout as keyof typeof LAYOUT_COMPONENTS];
if (!Layout) {
  throw new Error(`No layout component registered for variant.layout="${variant.layout}". ` +
    `Add a row to LAYOUT_COMPONENTS in src/components/VariantPage.astro.`);
}
---

<Layout locale={locale} variant={variant} product={product} />
