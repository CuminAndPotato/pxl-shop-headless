---
interface Props {
  /** Background color above the curve (prior section) */
  from?: string;
  /** Fill color of the curve (next section) */
  to?: string;
  /** Optional gradient stops on the curve (overrides `to` fill) */
  toGradient?: string[];
  /** Curve depth */
  height?: string;
  /** Sweep direction. 'right' = curve dips low on the right, 'left' = mirrored, 'symmetric' = centered */
  sweep?: 'right' | 'left' | 'symmetric';
  /** "down" = curve dips down (next section bulges into prior); "up" = inverted */
  direction?: 'down' | 'up';
  /** Sweep amount: 0 = flat, ~1.5 typical */
  amount?: number;
}
const {
  from = 'transparent',
  to = '#ffffff',
  toGradient,
  height = 'clamp(70px, 9vw, 150px)',
  sweep = 'right',
  direction = 'down',
  amount = 1.4,
} = Astro.props;

// Cubic-bezier control points, scaled by amount.
// Asymmetric S-curves like the Wix Studio Editor: one side goes deep, the other side stays nearer flat.
const dip = 120 * amount;
const flat = 0;
const c1x = 360, c2x = 1080;
let c1y, c2y;
if (sweep === 'right') {
  c1y = direction === 'down' ? -flat : 120 + flat;
  c2y = direction === 'down' ? dip : 120 - dip;
} else if (sweep === 'left') {
  c1y = direction === 'down' ? dip : 120 - dip;
  c2y = direction === 'down' ? -flat : 120 + flat;
} else {
  c1y = direction === 'down' ? dip * 0.85 : 120 - dip * 0.85;
  c2y = direction === 'down' ? dip * 0.85 : 120 - dip * 0.85;
}

const path = direction === 'down'
  ? `M0,0 C${c1x},${c1y} ${c2x},${c2y} 1440,0 L1440,120 L0,120 Z`
  : `M0,120 C${c1x},${c1y} ${c2x},${c2y} 1440,120 L1440,0 L0,0 Z`;

const gradId = 'wgrad-' + Math.random().toString(36).slice(2, 9);
const useGradient = !!(toGradient && toGradient.length >= 2);
---
<div class="wave" style={`background:${from}; --h:${height}`} aria-hidden="true">
  <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
    {useGradient && (
      <defs>
        <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="0">
          {toGradient!.map((c, i) => (
            <stop offset={`${(i / (toGradient!.length - 1)) * 100}%`} stop-color={c} />
          ))}
        </linearGradient>
      </defs>
    )}
    <path d={path} fill={useGradient ? `url(#${gradId})` : to} />
  </svg>
</div>
<style>
  .wave { width: 100%; height: var(--h); line-height: 0; overflow: hidden; }
  .wave svg { display: block; width: 100%; height: 100%; }
</style>
