---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';
import WaveOverlay from './WaveOverlay.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const s = t(locale);

const heroImg = 'https://static.wixstatic.com/media/5d430b_f1e3cda1718b41d0b40fe277ff6de803~mv2.jpg/v1/fill/w_1100,h_780,al_c,q_85,enc_avif,quality_auto/dev.avif';
const thumbs = [
  'https://static.wixstatic.com/media/5d430b_c2dda73e68f948f9aa4b5c0bd1c0b4c1~mv2.jpg/v1/fill/w_220,h_140,q_85,enc_avif,quality_auto/t1.avif',
  'https://static.wixstatic.com/media/5d430b_fb1d22317a4f43f284b772995ce5ddc7~mv2.jpg/v1/fill/w_220,h_140,q_85,enc_avif,quality_auto/t2.avif',
  'https://static.wixstatic.com/media/5d430b_3f45f9bd1e594c49bc303ddc5538aa8b~mv2.jpg/v1/fill/w_220,h_140,q_85,enc_avif,quality_auto/t3.avif',
  'https://static.wixstatic.com/media/5d430b_bacd04b5df084167b055daaab8fa619d~mv2.jpg/v1/fill/w_220,h_140,q_85,enc_avif,quality_auto/t4.avif',
  'https://static.wixstatic.com/media/5d430b_8171588421ad4eb381e4d586b360c583~mv2.jpg/v1/fill/w_220,h_140,q_85,enc_avif,quality_auto/t5.avif',
];
---

<section class="section create section--bg-create">
  <WaveOverlay side="top" fill="#ffffff" height="170px" />

  <div class="container create__grid">
    <div class="create__media">
      <img class="create__hero" src={heroImg} alt="Developer designing animations" loading="lazy" />
      <div class="create__thumbs" aria-hidden="true">
        {thumbs.map((src) => <img src={src} alt="" loading="lazy" />)}
      </div>
    </div>
    <div class="create__copy">
      <h3 class="h-sub create__h">
        {s.create.title.map((line) => <span>{line}</span>)}
      </h3>
      {s.create.paragraphs.map((p) => <p class="lead">{p}</p>)}
      <div class="btn--row create__cta">
        <a class="btn" href="https://github.com/CuminAndPotato/PXL-Clock" target="_blank" rel="noopener">{s.create.github}</a>
        <a class="btn" href="https://discord.gg/KDbVdKQh5j" target="_blank" rel="noopener">{s.create.discord}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .create { position: relative; padding-top: clamp(8rem, 14vw, 13rem); }
  .create__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .create__h { font-weight: 700; max-width: 16ch; }
  .create__h span { display: block; }
  .create__copy .lead { margin-bottom: 1rem; }
  .create__cta { margin-top: 1.75rem; }
  .create__hero {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 4px;
  }
  .create__thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.4rem;
    margin-top: 0.5rem;
  }
  .create__thumbs img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 3px;
  }
  @media (max-width: 860px) {
    .create__grid { grid-template-columns: 1fr; }
  }
</style>
