---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';

interface Props { locale: Locale }
const { locale } = Astro.props;
const s = t(locale);

// Asset IDs (and crop hints) from the live "Create" gallery on pxlclock.com.
// Each entry produces both a hero (1020x648) and a thumbnail (220x140) URL from the same Wix asset.
// Self-hosted under public/img/gallery as <id>-hero.avif and <id>-thumb.avif.
const frameIds = [
  '5d430b_c2dda73e68f948f9aa4b5c0bd1c0b4c1',
  '5d430b_fb1d22317a4f43f284b772995ce5ddc7',
  '5d430b_fcf22499e4bb4150b5e4e4aff526a1bf',
  '5d430b_3f45f9bd1e594c49bc303ddc5538aa8b',
  '5d430b_bacd04b5df084167b055daaab8fa619d',
  '5d430b_bbb23226bacc40e4a977aee958861cab',
  '5d430b_8171588421ad4eb381e4d586b360c583',
];

const items = frameIds.map((id) => ({
  hero: `/img/gallery/${id}-hero.avif`,
  thumb: `/img/gallery/${id}-thumb.avif`,
}));
const initial = items[0];
---

<section class="section create section--bg-create">
  <div class="container create__grid">
    <div class="create__media">
      <img class="create__hero" src={initial.hero} alt="" loading="lazy" data-create-hero />
      <div class="create__thumbs" role="tablist">
        {items.map((it, i) => (
          <button
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            class={i === 0 ? 'create__thumb is-active' : 'create__thumb'}
            data-hero={it.hero}
            aria-label={`Frame ${i + 1}`}
          >
            <img src={it.thumb} alt="" loading="lazy" />
          </button>
        ))}
      </div>
    </div>
    <div class="create__copy">
      <h3 class="h-sub create__h">
        {s.create.title.map((line) => <span>{line}</span>)}
      </h3>
      {s.create.paragraphs.map((p) => <p class="lead">{p}</p>)}
      <div class="btn--row create__cta">
        <a class="btn" href="https://github.com/CuminAndPotato/PXL-Clock" target="_blank" rel="noopener">{s.create.github}</a>
        <a class="btn" href="https://discord.gg/KDbVdKQh5j" target="_blank" rel="noopener">{s.create.discord}</a>
      </div>
    </div>
  </div>
</section>

<script>
  // Click a thumb → swap the hero image. Pure client-side, no framework.
  const hero = document.querySelector<HTMLImageElement>('[data-create-hero]');
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.create__thumb');
  if (hero && thumbs.length) {
    // Preload all hero variants so the swap is instant
    thumbs.forEach((b) => {
      const url = b.dataset.hero;
      if (url) { const img = new Image(); img.src = url; }
    });
    thumbs.forEach((b) => {
      b.addEventListener('click', () => {
        const url = b.dataset.hero;
        if (!url) return;
        hero.src = url;
        thumbs.forEach((x) => {
          x.classList.toggle('is-active', x === b);
          x.setAttribute('aria-selected', x === b ? 'true' : 'false');
        });
      });
    });
  }
</script>

<style>
  .create { position: relative; padding-top: clamp(8rem, 14vw, 13rem); }
  .create__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .create__h { font-weight: 700; max-width: 16ch; }
  .create__h span { display: block; }
  .create__copy .lead { margin-bottom: 1rem; }
  .create__cta { margin-top: 1.75rem; }

  .create__hero {
    width: 100%;
    aspect-ratio: 510 / 324;
    object-fit: cover;
    border-radius: 4px;
    transition: opacity 0.18s ease;
  }
  .create__thumbs {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.55rem;
    margin-top: 0.6rem;
  }
  .create__thumb {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
    transition: opacity 0.18s ease, transform 0.18s ease;
    opacity: 0.7;
  }
  .create__thumb img {
    width: 100%;
    aspect-ratio: 510 / 324;
    object-fit: cover;
    display: block;
  }
  .create__thumb:hover { opacity: 1; }
  .create__thumb.is-active {
    opacity: 1;
    outline: 2px solid var(--fg);
    outline-offset: 2px;
  }
  .create__thumb:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: 2px;
  }

  @media (max-width: 860px) {
    .create__grid { grid-template-columns: 1fr; }
  }
</style>
