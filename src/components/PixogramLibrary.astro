---
import { url } from '../lib/url';
import type { Locale } from '../i18n/strings';
import indexJson from '../../public/pixograms/index.json';

interface Props {
  locale: Locale;
  /** Limit to the first N items (0 = all). */
  limit?: number;
}

const { locale, limit = 0 } = Astro.props;

const allItems = (indexJson?.items ?? []) as Array<{
  slug: string;
  file: string;
  displayName: string;
  author: string;
  description: string;
  appType: string;
  type: string;
  /** Source framerate the .pxl was rendered at; drives playback interval. */
  fps?: number;
  duration?: number;
}>;

const items = limit > 0 ? allItems.slice(0, limit) : allItems;
const initial = items[0]?.slug ?? '';

const ui = locale === 'de'
  ? {
      eyebrow: 'Aus der Werkstatt',
      title: 'Pixogramme, die schon auf der Uhr laufen.',
      lead: 'Echte Clockfaces und Szenen aus dem offiziellen PXL-Clock-Repo. Klick eins an — du siehst es links auf der Uhr.',
      author: 'von',
    }
  : {
      eyebrow: 'From the workshop',
      title: 'Pixograms that already run on the clock.',
      lead: 'Real clockfaces and scenes from the official PXL Clock repo. Click one — it plays on the clock on the left.',
      author: 'by',
    };
---

<section class="pxlib">
  <header class="pxlib__head">
    <p class="pxlib__eyebrow">{ui.eyebrow}</p>
    <h2 class="pxlib__title">{ui.title}</h2>
    <p class="pxlib__lead">{ui.lead}</p>
  </header>

  <div class="pxlib__layout">
    <!-- Big stage: sticky on desktop, animated photoreal canvas projected
         onto a real product photo so the active pixogram looks like it's
         running on the actual clock. -->
    <aside class="pxlib__stage">
      <div class="pxlib__stage-inner">
        <div class="pxlib__clock" data-pxlib-clock>
          <img class="pxlib__clock-photo" src={url("/img/products/whatis-clock-tight.png")} alt="" loading="lazy" width="997" height="1045" />
          <div class="pxlib__clock-display" data-pxlib-display>
            <canvas class="pxlib__clock-canvas" data-pxlib-large-canvas width="540" height="540"></canvas>
          </div>
          <!-- Reflection: simulates light from the LED matrix's leftmost
               column spilling onto the clock frame's inner-left bezel edge.
               Native PXL Clock photos show this warm spill in the original
               product shot; we re-create it dynamically so it tracks
               whatever pixogram is currently playing. -->
          <div class="pxlib__clock-reflection" data-pxlib-reflection>
            <canvas data-pxlib-reflection-canvas></canvas>
          </div>
          <button type="button" class="pxlib__corner" data-corner="tl" aria-label="Top-left corner"></button>
          <button type="button" class="pxlib__corner" data-corner="tr" aria-label="Top-right corner"></button>
          <button type="button" class="pxlib__corner" data-corner="bl" aria-label="Bottom-left corner"></button>
          <button type="button" class="pxlib__corner" data-corner="br" aria-label="Bottom-right corner"></button>
        </div>
        <div class="pxlib__current">
          <p class="pxlib__current-type" data-pxlib-large-type></p>
          <h3 class="pxlib__current-name" data-pxlib-large-name></h3>
          <p class="pxlib__current-author" data-pxlib-large-author></p>
          <p class="pxlib__current-desc" data-pxlib-large-desc></p>
        </div>
      </div>
    </aside>

    <!-- Thumbnail grid: static freeze-frames, no animation. Click a thumb
         to swap which pixogram plays on the stage. -->
    <div class="pxlib__thumbs">
      {items.map((item) => (
        <button
          class={item.slug === initial ? 'pxlib__thumb is-active' : 'pxlib__thumb'}
          data-pxlib-thumb={item.slug}
          data-pxlib-file={url(`/pixograms/${item.file}`)}
          data-pxlib-name={item.displayName}
          data-pxlib-author={item.author}
          data-pxlib-desc={item.description}
          data-pxlib-type={item.type}
          data-pxlib-fps={item.fps ?? 5}
          type="button"
          aria-pressed={item.slug === initial}
        >
          <div class="pxlib__thumb-canvas-wrap">
            <canvas class="pxlib__thumb-canvas" data-pxlib-thumb-canvas width="200" height="200"></canvas>
          </div>
          <div class="pxlib__thumb-meta">
            <span class="pxlib__thumb-name">{item.displayName}</span>
            {item.author && <span class="pxlib__thumb-author">{ui.author} {item.author}</span>}
          </div>
        </button>
      ))}
    </div>
  </div>

  <!-- Compact readout next to the corner-drag handles. Only visible with
       ?tweak. Shows the four corner positions (in % of the photo) and a
       Copy button that exports a ready-to-paste JS literal. -->
  <aside class="pxlib-tweak" data-pxlib-tweak hidden>
    <header>
      <strong>Tweak panel</strong>
      <button type="button" data-pxlib-tweak-close aria-label="Close">×</button>
    </header>

    <!-- Corner perspective + opacity + canvas crop. Crop covers the top +
         right edges where the recessed LED matrix is partly occluded by the
         frame's inner lip at the photo's 3/4 angle. -->
    <section class="pxlib-tweak__section">
      <p class="pxlib-tweak__hint">Drag the four dots on the clock to fit the display area.</p>
      <label class="pxlib-tweak__check">
        <input type="checkbox" checked data-pxlib-tweak-handles>
        <span>show handles</span>
      </label>
      <label class="pxlib-tweak__row">
        <span>opacity <output data-pxlib-tweak-opacity-out>50</output>%</span>
        <input type="range" min="0" max="100" step="1" value="50" data-pxlib-tweak-opacity>
      </label>
      <label class="pxlib-tweak__row">
        <span>crop top <output data-pxlib-crop-out="top">0.9</output>%</span>
        <input type="range" min="0" max="15" step="0.1" value="0.9" data-pxlib-crop="top">
      </label>
      <label class="pxlib-tweak__row">
        <span>crop right <output data-pxlib-crop-out="right">1.3</output>%</span>
        <input type="range" min="0" max="15" step="0.1" value="1.3" data-pxlib-crop="right">
      </label>
      <label class="pxlib-tweak__row">
        <span>refl width <output data-pxlib-refl-out="width">0.9</output>%</span>
        <input type="range" min="0" max="10" step="0.1" value="0.9" data-pxlib-refl="width">
      </label>
      <label class="pxlib-tweak__row">
        <span>refl offset <output data-pxlib-refl-out="offset">0.1</output>%</span>
        <input type="range" min="-5" max="5" step="0.1" value="0.1" data-pxlib-refl="offset">
      </label>
      <label class="pxlib-tweak__row">
        <span>refl opacity <output data-pxlib-refl-out="opacity">66</output>%</span>
        <input type="range" min="0" max="100" step="1" value="66" data-pxlib-refl="opacity">
      </label>
      <label class="pxlib-tweak__row">
        <span>refl blur <output data-pxlib-refl-out="blur">1.5</output>px</span>
        <input type="range" min="0" max="20" step="0.1" value="1.5" data-pxlib-refl="blur">
      </label>
      <pre data-pxlib-tweak-output></pre>
      <div class="pxlib-tweak__actions">
        <button type="button" data-pxlib-tweak-copy>Copy</button>
        <button type="button" data-pxlib-tweak-reset>Reset</button>
      </div>
    </section>
  </aside>
</section>

<script>
  import { parsePxl, type Pixogram } from '../lib/pxl-format';
  import { renderRgbFast, renderRgbPhotoreal } from '../lib/pixel-canvas';
  import { cornersToMatrix3d, type Corners as PerspectiveCorners } from '../lib/pxlib-perspective';

  // === State ================================================================
  const pixogramCache = new Map<string, Pixogram>();
  const inflight = new Map<string, Promise<Pixogram | null>>();

  // === Helpers ==============================================================
  async function loadPixogram(url: string): Promise<Pixogram | null> {
    if (inflight.has(url)) return inflight.get(url)!;
    const p = (async () => {
      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return parsePxl(await res.text());
      } catch (err) {
        console.error('[pxlib] load failed', url, err);
        return null;
      }
    })();
    inflight.set(url, p);
    return p;
  }

  // === Thumbnails ===========================================================
  // Each thumbnail renders ONE freeze-frame (a middle frame) once and stays
  // static after that. No interval, no worker — main thread sits idle while
  // you scroll.
  type Thumb = {
    el: HTMLButtonElement;
    slug: string;
    url: string;
    canvas: HTMLCanvasElement;
    rendered: boolean;
    fps: number;
    meta: { displayName: string; author: string; description: string; type: string };
  };

  const thumbs: Thumb[] = [];
  document.querySelectorAll<HTMLButtonElement>('.pxlib__thumb').forEach((el) => {
    const slug = el.dataset.pxlibThumb ?? '';
    const url = el.dataset.pxlibFile ?? '';
    const canvas = el.querySelector<HTMLCanvasElement>('[data-pxlib-thumb-canvas]');
    if (!canvas || !slug || !url) return;
    thumbs.push({
      el, slug, url, canvas,
      rendered: false,
      fps: Math.max(1, Number(el.dataset.pxlibFps ?? 5)),
      meta: {
        displayName: el.dataset.pxlibName ?? '',
        author: el.dataset.pxlibAuthor ?? '',
        description: el.dataset.pxlibDesc ?? '',
        type: el.dataset.pxlibType ?? '',
      },
    });
  });

  async function renderThumb(t: Thumb) {
    if (t.rendered) return;
    let pix = pixogramCache.get(t.slug);
    if (!pix) {
      pix = (await loadPixogram(t.url)) ?? undefined;
      if (pix) pixogramCache.set(t.slug, pix);
    }
    if (!pix) return;
    // Use the middle frame as a "characteristic" freeze — frame 0 is often
    // an initial dark state which would make every thumbnail look identical.
    const frame = pix.frames[Math.floor(pix.frames.length / 2)];
    renderRgbFast(t.canvas, frame, pix.width, pix.height);
    t.rendered = true;
  }

  const thumbIO = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (!entry.isIntersecting) continue;
      const t = thumbs.find((x) => x.el === entry.target);
      if (t) renderThumb(t);
    }
  }, { rootMargin: '300px 0px', threshold: 0 });
  thumbs.forEach((t) => thumbIO.observe(t.el));

  // === Big stage ============================================================
  const largeCanvas = document.querySelector<HTMLCanvasElement>('[data-pxlib-large-canvas]');
  const largeType = document.querySelector<HTMLElement>('[data-pxlib-large-type]');
  const largeName = document.querySelector<HTMLElement>('[data-pxlib-large-name]');
  const largeAuthor = document.querySelector<HTMLElement>('[data-pxlib-large-author]');
  const largeDesc = document.querySelector<HTMLElement>('[data-pxlib-large-desc]');
  const reflectionCanvas = document.querySelector<HTMLCanvasElement>('[data-pxlib-reflection-canvas]');

  let activePix: Pixogram | null = null;
  let activeFrame = 0;
  let activeTimer: number | null = null;
  let activeFps = 5;
  let inView = true;

  function paintLarge() {
    if (!activePix || !largeCanvas) return;
    const f = activePix.frames[activeFrame % activePix.frames.length];
    renderRgbPhotoreal(largeCanvas, f, activePix.width, activePix.height);
    paintReflection(activePix.width);
  }

  // Reflection = a horizontal slice of the leftmost LED column from the
  // already-rendered main canvas, copied into the reflection canvas via
  // drawImage. Reusing the main canvas pixels guarantees the bezel light
  // matches the photoreal LED look exactly (same gradients, same bloom);
  // matrix3d on the parent stretches the slice down to the slim strip.
  function paintReflection(matrixWidth: number) {
    if (!reflectionCanvas || !largeCanvas) return;
    const ctx = reflectionCanvas.getContext('2d');
    if (!ctx) return;
    const cssW = reflectionCanvas.clientWidth;
    const cssH = reflectionCanvas.clientHeight;
    if (cssW === 0 || cssH === 0) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const targetW = Math.round(cssW * dpr);
    const targetH = Math.round(cssH * dpr);
    if (reflectionCanvas.width !== targetW || reflectionCanvas.height !== targetH) {
      reflectionCanvas.width = targetW;
      reflectionCanvas.height = targetH;
    }
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, cssW, cssH);
    // ~1 LED column wide — slice includes one cell's hotspot + bloom. Reading
    // from the device-pixel buffer of largeCanvas keeps the source crisp.
    const sliceW = Math.max(1, Math.round(largeCanvas.width / matrixWidth));
    ctx.drawImage(largeCanvas, 0, 0, sliceW, largeCanvas.height, 0, 0, cssW, cssH);
  }

  function stopLarge() {
    if (activeTimer != null) {
      clearInterval(activeTimer);
      activeTimer = null;
    }
  }

  function startLarge() {
    stopLarge();
    if (!activePix) return;
    paintLarge();
    // Playback interval is derived from the source .pxl's fps (index.json
    // metadata), so re-rendering at higher fps produces smoother playback
    // automatically without any code change.
    const intervalMs = Math.max(16, Math.round(1000 / activeFps));
    activeTimer = window.setInterval(() => {
      activeFrame += 1;
      paintLarge();
    }, intervalMs);
  }

  async function setActive(t: Thumb) {
    // Visual highlight
    thumbs.forEach((other) => {
      const on = other === t;
      other.el.classList.toggle('is-active', on);
      other.el.setAttribute('aria-pressed', String(on));
    });
    // Meta
    if (largeType) largeType.textContent = t.meta.type;
    if (largeName) largeName.textContent = t.meta.displayName;
    if (largeAuthor) largeAuthor.textContent = t.meta.author ? `by ${t.meta.author}` : '';
    if (largeDesc) largeDesc.textContent = t.meta.description;
    // Load + play
    let pix = pixogramCache.get(t.slug);
    if (!pix) {
      pix = (await loadPixogram(t.url)) ?? undefined;
      if (pix) pixogramCache.set(t.slug, pix);
    }
    if (!pix) return;
    activePix = pix;
    activeFrame = 0;
    activeFps = t.fps;
    if (inView) startLarge();
  }

  thumbs.forEach((t) => {
    t.el.addEventListener('click', () => setActive(t));
  });

  // Initialise with the first thumb. The thumbnail render hasn't necessarily
  // happened yet, so we eagerly load the first pixogram for the stage.
  if (thumbs.length > 0) setActive(thumbs[0]);

  // Pause the stage when it's off-screen.
  const stage = document.querySelector<HTMLElement>('.pxlib__stage');
  if (stage) {
    const stageIO = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        inView = entry.isIntersecting;
        if (inView && activePix) startLarge();
        else stopLarge();
      }
    }, { threshold: 0 });
    stageIO.observe(stage);
  }
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stopLarge();
    else if (inView && activePix) startLarge();
  });

  // === 4-corner perspective mapping ========================================
  // The canvas wrapper is matrix3d-projected onto whatever quadrilateral the
  // four corner % values describe. Pure math lives in lib/pxlib-perspective.ts;
  // we only deal with DOM + persistence here.
  type Corner = { x: number; y: number };
  type Corners = PerspectiveCorners;

  // Default corners — measured against whatis-clock-tight.png by dragging
  // the four handles into the photo's display rectangle. Frame perspective
  // is baked in (right + bottom are inset further than left + top because
  // the clock's body has depth and the frame partly occludes the LEDs at
  // those edges).
  const DEFAULT_CORNERS: Corners = {
    tl: { x: 10.4, y: 8.1 },
    tr: { x: 85.0, y: 9.3 },
    bl: { x: 10.4, y: 83.6 },
    br: { x: 84.8, y: 90.0 },
  };
  const CORNERS_KEY = 'pxlib-corners';
  const CROP_KEY = 'pxlib-crop';

  type Crop = { top: number; right: number };
  const DEFAULT_CROP: Crop = { top: 0.9, right: 1.3 };

  function loadCorners(): Corners {
    try {
      const raw = localStorage.getItem(CORNERS_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        if (parsed?.tl && parsed?.tr && parsed?.bl && parsed?.br) return parsed;
      }
    } catch {}
    return JSON.parse(JSON.stringify(DEFAULT_CORNERS));
  }
  function saveCorners(c: Corners) {
    try { localStorage.setItem(CORNERS_KEY, JSON.stringify(c)); } catch {}
  }
  function loadCrop(): Crop {
    try {
      const raw = localStorage.getItem(CROP_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        if (typeof parsed?.top === 'number' && typeof parsed?.right === 'number') return parsed;
      }
    } catch {}
    return { ...DEFAULT_CROP };
  }
  function saveCrop(c: Crop) {
    try { localStorage.setItem(CROP_KEY, JSON.stringify(c)); } catch {}
  }

  const clockEl = document.querySelector<HTMLElement>('[data-pxlib-clock]');
  const displayEl = document.querySelector<HTMLElement>('[data-pxlib-display]');
  const reflectionEl = document.querySelector<HTMLElement>('[data-pxlib-reflection]');
  let corners = loadCorners();

  // Reflection config — live-tunable from the tweak panel. Persisted to
  // localStorage so visitors don't lose their tuning across reloads.
  type ReflConfig = { width: number; offset: number; opacity: number; blur: number };
  const DEFAULT_REFL: ReflConfig = { width: 0.9, offset: 0.1, opacity: 66, blur: 1.5 };
  const REFL_KEY = 'pxlib-reflection';
  function loadRefl(): ReflConfig {
    try {
      const raw = localStorage.getItem(REFL_KEY);
      if (raw) return { ...DEFAULT_REFL, ...JSON.parse(raw) };
    } catch {}
    return { ...DEFAULT_REFL };
  }
  function saveRefl(c: ReflConfig) {
    try { localStorage.setItem(REFL_KEY, JSON.stringify(c)); } catch {}
  }
  let refl = loadRefl();

  // Opacity + blur live on the canvas, not on the wrapping reflection div —
  // the div carries the opaque black backdrop that covers the photo's bezel,
  // and that must stay at 100% regardless of how transparent the LED column
  // copy on top is. Otherwise lowering refl.opacity would also fade the
  // backdrop, letting the photo bleed through.
  function applyReflStyle() {
    if (!reflectionCanvas) return;
    reflectionCanvas.style.opacity = String(refl.opacity / 100);
    reflectionCanvas.style.filter = `blur(${refl.blur}px)`;
  }
  applyReflStyle();

  function applyCorners() {
    if (!clockEl || !displayEl) return;
    // getBoundingClientRect gives fractional pixels; offsetWidth/Height round
    // to integers and accumulate visible drift at higher browser zoom levels.
    const rect = clockEl.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;
    if (w === 0 || h === 0) return;
    displayEl.style.top = '0';
    displayEl.style.left = '0';
    displayEl.style.width = '100%';
    displayEl.style.height = '100%';
    displayEl.style.transformOrigin = '0 0';
    displayEl.style.transform = cornersToMatrix3d(corners, w, h);
    // Reflection strip — slim quad attached to the LEFT edge of the LED
    // matrix, tracking the same perspective tilt so it sits flush on the
    // bezel instead of floating. Width + offset come from the tweak config.
    if (reflectionEl) {
      const rightX_top = corners.tl.x + refl.offset;
      const rightX_bot = corners.bl.x + refl.offset;
      const reflCorners: Corners = {
        tl: { x: rightX_top - refl.width, y: corners.tl.y },
        tr: { x: rightX_top,               y: corners.tl.y },
        bl: { x: rightX_bot - refl.width, y: corners.bl.y },
        br: { x: rightX_bot,               y: corners.bl.y },
      };
      reflectionEl.style.transform = cornersToMatrix3d(reflCorners, w, h);
    }
    document.querySelectorAll<HTMLElement>('.pxlib__corner').forEach((handle) => {
      const k = handle.dataset.corner as keyof Corners | undefined;
      if (!k || !corners[k]) return;
      handle.style.left = `${corners[k].x}%`;
      handle.style.top = `${corners[k].y}%`;
    });
  }

  function fmtCorners(c: Corners) {
    const n = (v: number) => v.toFixed(1);
    return (
      `tl: { x: ${n(c.tl.x)}, y: ${n(c.tl.y)} },\n` +
      `tr: { x: ${n(c.tr.x)}, y: ${n(c.tr.y)} },\n` +
      `bl: { x: ${n(c.bl.x)}, y: ${n(c.bl.y)} },\n` +
      `br: { x: ${n(c.br.x)}, y: ${n(c.br.y)} },`
    );
  }

  applyCorners();
  // ResizeObserver catches the clock element's size changing for any reason:
  // viewport resize, browser zoom (which may or may not fire window.resize on
  // each browser), responsive breakpoints, container layout shifts. Anchoring
  // to the element itself instead of `window` is the only zoom-safe approach.
  if (clockEl) {
    const clockRO = new ResizeObserver(() => applyCorners());
    clockRO.observe(clockEl);
  }
  // Keep the window.resize listener as a belt-and-braces fallback for the
  // rare case where ResizeObserver isn't supported (very old browsers).
  window.addEventListener('resize', applyCorners);

  // Apply saved crop on load so it's visible even without ?tweak. Variables
  // live on clockEl so both the display and the reflection can read them.
  let crop = loadCrop();
  function applyCrop() {
    if (!clockEl) return;
    clockEl.style.setProperty('--pxlib-crop-top', `${crop.top}%`);
    clockEl.style.setProperty('--pxlib-crop-right', `${crop.right}%`);
  }
  applyCrop();

  if (new URLSearchParams(location.search).has('tweak')) {
    clockEl?.setAttribute('data-tweak', '');
    const panel = document.querySelector<HTMLElement>('[data-pxlib-tweak]');
    const out = panel?.querySelector<HTMLElement>('[data-pxlib-tweak-output]');
    const copyBtn = panel?.querySelector<HTMLButtonElement>('[data-pxlib-tweak-copy]');
    const resetBtn = panel?.querySelector<HTMLButtonElement>('[data-pxlib-tweak-reset]');
    if (panel) panel.hidden = false;
    if (out) out.textContent = fmtCorners(corners);

    document.querySelectorAll<HTMLElement>('.pxlib__corner').forEach((handle) => {
      handle.addEventListener('pointerdown', (e) => {
        e.preventDefault();
        handle.setPointerCapture(e.pointerId);
        handle.classList.add('is-dragging');
        const key = handle.dataset.corner as keyof Corners;
        function onMove(ev: PointerEvent) {
          // Re-read the clock's bounding rect on every move — covers scroll,
          // resize and zoom during drag (a cached rect would silently drift).
          const rect = clockEl!.getBoundingClientRect();
          const x = ((ev.clientX - rect.left) / rect.width) * 100;
          const y = ((ev.clientY - rect.top) / rect.height) * 100;
          corners[key] = {
            x: Math.max(0, Math.min(100, x)),
            y: Math.max(0, Math.min(100, y)),
          };
          applyCorners();
          if (out) out.textContent = fmtCorners(corners);
        }
        function onUp() {
          handle.classList.remove('is-dragging');
          handle.removeEventListener('pointermove', onMove);
          handle.removeEventListener('pointerup', onUp);
          saveCorners(corners);
        }
        handle.addEventListener('pointermove', onMove);
        handle.addEventListener('pointerup', onUp);
      });
    });

    copyBtn?.addEventListener('click', async () => {
      const text = fmtCorners(corners);
      try {
        await navigator.clipboard.writeText(text);
        const orig = copyBtn.textContent;
        copyBtn.textContent = 'Copied ✓';
        setTimeout(() => { if (copyBtn) copyBtn.textContent = orig; }, 1200);
      } catch {}
    });

    resetBtn?.addEventListener('click', () => {
      corners = JSON.parse(JSON.stringify(DEFAULT_CORNERS));
      saveCorners(corners);
      applyCorners();
      if (out) out.textContent = fmtCorners(corners);
      // Also reset the crop sliders + applied crop.
      crop = { ...DEFAULT_CROP };
      saveCrop(crop);
      applyCrop();
      document.querySelectorAll<HTMLInputElement>('[data-pxlib-crop]').forEach((input) => {
        const key = input.dataset.pxlibCrop as 'top' | 'right' | undefined;
        if (!key) return;
        input.value = String(crop[key]);
        const o = document.querySelector<HTMLElement>(`[data-pxlib-crop-out="${key}"]`);
        if (o) o.textContent = crop[key].toFixed(1);
      });
      // Also reset reflection sliders.
      refl = { ...DEFAULT_REFL };
      saveRefl(refl);
      applyReflStyle();
      applyCorners();
      document.querySelectorAll<HTMLInputElement>('[data-pxlib-refl]').forEach((input) => {
        const key = input.dataset.pxlibRefl as keyof ReflConfig | undefined;
        if (!key) return;
        input.value = String(refl[key]);
        const o = document.querySelector<HTMLElement>(`[data-pxlib-refl-out="${key}"]`);
        if (o) o.textContent = key === 'opacity' ? String(refl[key]) : refl[key].toFixed(1);
      });
    });

    // Opacity slider — makes the canvas semi-transparent so the underlying
    // product photo shows through, letting you eyeball the corner positions
    // against the real display rectangle.
    const opacityInput = panel?.querySelector<HTMLInputElement>('[data-pxlib-tweak-opacity]');
    const opacityOut = panel?.querySelector<HTMLElement>('[data-pxlib-tweak-opacity-out]');
    function applyOpacity(v: number) {
      if (displayEl) displayEl.style.opacity = String(v / 100);
      if (opacityOut) opacityOut.textContent = String(v);
    }
    if (opacityInput) {
      applyOpacity(Number(opacityInput.value));  // initial: 50%
      opacityInput.addEventListener('input', () => applyOpacity(Number(opacityInput.value)));
    }

    // Handles checkbox — lets the user temporarily hide the orange drag dots
    // (e.g. to take a clean screenshot) without leaving tweak mode.
    const handlesInput = panel?.querySelector<HTMLInputElement>('[data-pxlib-tweak-handles]');
    function applyHandlesVisible(on: boolean) {
      if (!clockEl) return;
      if (on) clockEl.removeAttribute('data-handles-hidden');
      else clockEl.setAttribute('data-handles-hidden', '');
    }
    if (handlesInput) {
      applyHandlesVisible(handlesInput.checked);
      handlesInput.addEventListener('change', () => applyHandlesVisible(handlesInput.checked));
    }

    // Crop sliders — top + right inset on the rendered canvas. Persists to
    // localStorage so the chosen crop survives a reload.
    document.querySelectorAll<HTMLInputElement>('[data-pxlib-crop]').forEach((input) => {
      const key = input.dataset.pxlibCrop as 'top' | 'right' | undefined;
      if (!key) return;
      input.value = String(crop[key]);
      const out = document.querySelector<HTMLElement>(`[data-pxlib-crop-out="${key}"]`);
      if (out) out.textContent = crop[key].toFixed(1);
      input.addEventListener('input', () => {
        const v = Number(input.value);
        crop = { ...crop, [key]: v };
        applyCrop();
        if (out) out.textContent = v.toFixed(1);
        saveCrop(crop);
      });
    });

    // Reflection sliders — width, offset, opacity, blur. Persisted likewise.
    document.querySelectorAll<HTMLInputElement>('[data-pxlib-refl]').forEach((input) => {
      const key = input.dataset.pxlibRefl as keyof ReflConfig | undefined;
      if (!key) return;
      input.value = String(refl[key]);
      const out = document.querySelector<HTMLElement>(`[data-pxlib-refl-out="${key}"]`);
      if (out) out.textContent = key === 'opacity' ? String(refl[key]) : refl[key].toFixed(1);
      input.addEventListener('input', () => {
        const v = Number(input.value);
        refl = { ...refl, [key]: v };
        applyReflStyle();
        applyCorners();  // recompute reflection quad
        if (out) out.textContent = key === 'opacity' ? String(v) : v.toFixed(1);
        saveRefl(refl);
      });
    });

    panel?.querySelector('[data-pxlib-tweak-close]')?.addEventListener('click', () => {
      if (panel) panel.hidden = true;
      if (displayEl) displayEl.style.opacity = '';  // restore full opacity
    });
  }
</script>

<style>
