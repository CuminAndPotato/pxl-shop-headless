    filter: drop-shadow(0 40px 80px rgba(10, 10, 10, 0.22));
    pointer-events: none;
  }
  /* Display wrapper — JS computes matrix3d from four corner positions and
     sets it inline. The element itself fills the photo container; the
     matrix maps that unit quad onto whatever quadrilateral the corners
     describe. Resize-safe: corners stay in %, matrix recomputed on resize. */
  .pxlib__clock-display {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform-origin: 0 0;
    border-radius: 4px;
    /* Crop — clips the top + right edges of the rendered pixogram before
       the matrix3d transform, so the topmost + rightmost LEDs (which would
       visually spill onto the bezel because of the photo's 3/4 angle and
       recessed display) get hidden. Defaults live on .pxlib__clock so the
       bezel reflection can read them too; JS may override via inline style. */
    clip-path: inset(var(--pxlib-crop-top) var(--pxlib-crop-right) 0 0);
    /* The LED matrix sits a couple of millimetres BEHIND the frame's inner
       edge, so the frame casts a real shadow onto the outer pixels. Right
       and bottom shadows are stronger because that's where perspective
       reveals the frame depth most. */
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      /* top: soft, frame-top inner edge */
      inset 0 8px 18px rgba(0, 0, 0, 0.45),
      /* right: stronger — perspective makes this the most visible recess */
      inset -14px 0 28px -2px rgba(0, 0, 0, 0.6),
      /* bottom: matches right */
      inset 0 -12px 24px -2px rgba(0, 0, 0, 0.55),
      /* left: subtle highlight (closest to viewer) */
      inset 2px 0 4px rgba(255, 255, 255, 0.04),
      /* outer glow under the clock */
      0 0 80px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }
  .pxlib__clock-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Reflection strip — narrow band sitting just LEFT of the LED matrix, on
     the clock's inner bezel. Its matrix3d transform comes from JS (derived
     from the four LED corners). The canvas is rendered as a photoreal column
     (per-LED hotspot + bloom) so the bezel spill reads as discrete LEDs;
     mix-blend-mode lets the light merge into the matte black frame. The
     top crop matches the main display so the topmost LEDs that are
     occluded by the frame's inner lip are also hidden in the reflection. */
  .pxlib__clock-reflection {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform-origin: 0 0;
    pointer-events: none;
    /* No blend mode + opaque black backdrop so the original photo's bezel
       doesn't bleed through the dark voids between LEDs in the projected
