---
import { url } from '../lib/url';
import type { Locale } from '../i18n/strings';

// Merged showcase: combines the PixogramLibrary's photoreal clock-on-photo
// rendering with the StickyPixelStory's scroll-driven chapter flow. The clock
// stays sticky on the left while four pixogram chapters cross-fade through it
// as their copy enters the viewport on the right. A fifth, non-pixogram
// chapter closes the section with workshop/community context.

export interface ShowcaseChapter {
  /** Pixogram slug (matches index.json) — empty string for the closing chapter. */
  slug: string;
  /** Public path to the .pxl file. Empty for the closing chapter. */
  file?: string;
  /** Source framerate of the .pxl, drives playback interval. */
  fps?: number;
  /** Eyebrow text shown above the chapter title. */
  eyebrow: string;
  /** Headline (also used as the pixogram display name). */
  title: string;
  /** Optional author byline. */
  author?: string;
  /** Body paragraph(s). Newlines split into separate <p> tags. */
  body: string;
}

interface Props {
  locale: Locale;
  chapters: ShowcaseChapter[];
}

const { locale, chapters } = Astro.props;
const ui = locale === 'de'
  ? {
      eyebrow: 'Aus der Werkstatt',
      title: 'Vier Pixogramme, eine sticky Uhr.',
      lead: 'Scroll dich durch — die Uhr links zeigt jeweils das Pixogramm, das du gerade liest.',
      authorPrefix: 'von',
    }
  : {
      eyebrow: 'From the workshop',
      title: 'Four pixograms, one sticky clock.',
      lead: 'Scroll through — the clock on the left plays whichever pixogram you are currently reading about.',
      authorPrefix: 'by',
    };

---

<section class="pscs" data-pscs>
  <header class="pscs__head">
    <p class="pscs__eyebrow">{ui.eyebrow}</p>
    <h2 class="pscs__title">{ui.title}</h2>
    <p class="pscs__lead">{ui.lead}</p>
  </header>

  <div class="pscs__layout">
    {/* Sticky stage — photoreal clock with matrix3d-projected canvas. The
        photo, perspective corners, reflection strip and crop variables are
        carried over 1:1 from PixogramLibrary so the clock looks identical. */}
    <aside class="pscs__stage">
      <div class="pscs__stage-inner">
        <div class="pscs__clock" data-pscs-clock>
          <img
            class="pscs__clock-photo"
            src={url('/img/products/whatis-clock-tight.png')}
            alt=""
            loading="lazy"
            width="997"
            height="1045"
          />
          <div class="pscs__clock-display" data-pscs-display>
            {/* Two stacked canvases for cross-fade swaps. At any moment one
                is fully opaque (the visible pixogram) and the other is
                staged for the next swap. We fade the staged one IN over the
                visible one — the visible one never fades to a low opacity,
                so the LED display area of the underlying photo is never
                allowed to show through. */}
            <canvas class="pscs__clock-canvas" data-pscs-canvas-a width="540" height="540"></canvas>
            <canvas class="pscs__clock-canvas" data-pscs-canvas-b width="540" height="540"></canvas>
          </div>
          {/* Paired reflection canvases — one per main slot. Both stack
              identically to the main canvases and share their opacity /
              z-index swap so the bezel reflection cross-fades in perfect
              lock-step with the main display (no visible "lag"). */}
          <div class="pscs__clock-reflection" data-pscs-reflection>
            <canvas data-pscs-refl-a></canvas>
            <canvas data-pscs-refl-b></canvas>
          </div>
        </div>
      </div>
    </aside>

    {/* Scroll-driven right column. Each article is a chapter; an
        IntersectionObserver triggers a cross-fade on the left canvas when
        a chapter enters the viewport's vertical centre band. */}
    <div class="pscs__flow">
      {chapters.map((ch, i) => (
        <article
          class={ch.slug ? 'pscs__chap' : 'pscs__chap pscs__chap--closing'}
          data-pscs-chapter={ch.slug || `closing-${i}`}
          data-pscs-file={ch.file ? url(`/pixograms/${ch.file}`) : ''}
          data-pscs-name={ch.title}
          data-pscs-fps={ch.fps ?? 5}
        >
          <p class="pscs__chap-eyebrow">{ch.eyebrow}</p>
          <h3 class="pscs__chap-title">{ch.title}</h3>
          {ch.author && (
            <p class="pscs__chap-author">{ui.authorPrefix} {ch.author}</p>
          )}
          {ch.body.split('\n').filter(Boolean).map((para) => (
            <p class="pscs__chap-body">{para}</p>
          ))}
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { parsePxl, type Pixogram } from '../lib/pxl-format';
  import { renderRgbPhotoreal } from '../lib/pixel-canvas';
  import { cornersToMatrix3d, type Corners as PerspectiveCorners } from '../lib/pxlib-perspective';

  // === Pixogram loader ======================================================
  const cache = new Map<string, Pixogram>();
  const inflight = new Map<string, Promise<Pixogram | null>>();
  async function loadPixogram(url: string): Promise<Pixogram | null> {
    if (!url) return null;
    if (cache.has(url)) return cache.get(url) ?? null;
    if (inflight.has(url)) return inflight.get(url)!;
    const p = (async () => {
      try {
        const res = await fetch(url);
        if (!res.ok) return null;
        const pix = parsePxl(await res.text());
        cache.set(url, pix);
        return pix;
      } catch { return null; }
    })();
    inflight.set(url, p);
    return p;
  }

  // === Playback state =======================================================
  // Two canvases ("slots") cross-fade: at any moment one is the visible front
  // slot (opacity 1) and the other is staged for the next swap. We never fade
  // the front slot OUT — instead the back slot fades IN over the front. This
  // keeps the underlying photo's LED display area covered at all times.
  const canvasA = document.querySelector<HTMLCanvasElement>('[data-pscs-canvas-a]');
  const canvasB = document.querySelector<HTMLCanvasElement>('[data-pscs-canvas-b]');
  const reflA = document.querySelector<HTMLCanvasElement>('[data-pscs-refl-a]');
  const reflB = document.querySelector<HTMLCanvasElement>('[data-pscs-refl-b]');
  // displayEl carries the matrix3d transform that projects the canvases onto
  // the LED quadrilateral in the clock photo. Lose this lookup and the
  // canvases stay axis-aligned full-bleed on the photo — i.e. the visible
  // clock frame disappears behind the pixogram.
  const displayEl = document.querySelector<HTMLElement>('[data-pscs-display]');
  const reflEl = document.querySelector<HTMLElement>('[data-pscs-reflection]');
  const clockEl = document.querySelector<HTMLElement>('[data-pscs-clock]');
  const stage = document.querySelector<HTMLElement>('.pscs__stage');

  interface Slot {
    el: HTMLCanvasElement;
    refl: HTMLCanvasElement | null;
    pix: Pixogram | null;
    frame: number;
    fps: number;
    /** rAF handle for the playback loop. */
    raf: number;
    /** Timestamp of last paint, for fps-throttled rAF. */
    lastPaint: number;
  }
  const slotA: Slot | null = canvasA ? { el: canvasA, refl: reflA, pix: null, frame: 0, fps: 5, raf: 0, lastPaint: 0 } : null;
  const slotB: Slot | null = canvasB ? { el: canvasB, refl: reflB, pix: null, frame: 0, fps: 5, raf: 0, lastPaint: 0 } : null;
  let front: Slot | null = slotA; // currently visible
  let back: Slot | null = slotB;  // staged for next swap
  let inView = true;

  function paintSlot(slot: Slot) {
    if (!slot.pix) return;
    const f = slot.pix.frames[slot.frame % slot.pix.frames.length];
    renderRgbPhotoreal(slot.el, f, slot.pix.width, slot.pix.height);
    // The reflection is painted from THIS slot's main canvas, so it stays
    // in lock-step with its slot's opacity. Because both reflections stack
    // identically to the main canvases, the visible reflection always
    // matches the visible front pixogram — no perceived lag.
    paintReflection(slot);
  }
  function paintReflection(slot: Slot) {
    const reflCanvas = slot.refl;
    if (!reflCanvas || !slot.pix) return;
    const ctx = reflCanvas.getContext('2d');
    if (!ctx) return;
    const cssW = reflCanvas.clientWidth;
    const cssH = reflCanvas.clientHeight;
    if (cssW === 0 || cssH === 0) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const targetW = Math.round(cssW * dpr);
    const targetH = Math.round(cssH * dpr);
    if (reflCanvas.width !== targetW || reflCanvas.height !== targetH) {
      reflCanvas.width = targetW;
      reflCanvas.height = targetH;
    }
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, cssW, cssH);
    const sliceW = Math.max(1, Math.round(slot.el.width / slot.pix.width));
    ctx.drawImage(slot.el, 0, 0, sliceW, slot.el.height, 0, 0, cssW, cssH);
  }
  // === Playback via rAF =====================================================
  // setInterval can fire while the browser is composing a scroll frame, which
  // causes visible jank on lower-end hardware. rAF lets the browser schedule
  // the paint between layout passes, so the scroll thread stays responsive.
  // We throttle to the pixogram's native fps by comparing timestamps.
  function startSlot(slot: Slot) {
    stopSlot(slot);
    if (!slot.pix) return;
    paintSlot(slot);
    slot.lastPaint = performance.now();
    const intervalMs = 1000 / slot.fps;
    const tick = (now: number) => {
      if (!slot.pix || slot.raf === 0) return;
      if (now - slot.lastPaint >= intervalMs) {
        slot.frame += 1;
        paintSlot(slot);
        // Drift-correct: align lastPaint to the most recent expected tick so
        // we don't accumulate sub-frame error across long playback sessions.
        slot.lastPaint = now - ((now - slot.lastPaint) % intervalMs);
      }
      slot.raf = requestAnimationFrame(tick);
    };
    slot.raf = requestAnimationFrame(tick);
  }
  function stopSlot(slot: Slot) {
    if (slot.raf !== 0) { cancelAnimationFrame(slot.raf); slot.raf = 0; }
  }
  function stopAll() {
    if (slotA) stopSlot(slotA);
    if (slotB) stopSlot(slotB);
  }
  function startAll() {
    if (front && front.pix) startSlot(front);
    if (back && back.pix) startSlot(back);
  }

  // === Cross-fade swap ======================================================
  // Render the new pixogram on the BACK slot, raise it above the front via
  // z-index, then animate its opacity from 0→1. The front slot stays at
  // opacity 1 throughout, so the photo's display area is never exposed.
  // After the fade completes we swap roles and reset the new back slot.
  const FADE_MS = 480;
  let activeSlug = '';
  let pendingSwapToken = 0;
  async function swapTo(slug: string, file: string, fps: number) {
    if (slug === activeSlug) return;
    activeSlug = slug;
    const myToken = ++pendingSwapToken;
    // Closing chapter has no file — keep showing the previous pixogram but
    // dim the clock a little to signal "the showcase is winding down".
    if (!file) {
      if (clockEl) clockEl.classList.add('is-closing');
      return;
    }
    if (clockEl) clockEl.classList.remove('is-closing');
    const pix = await loadPixogram(file);
    if (myToken !== pendingSwapToken) return;
    if (!pix || !front || !back) return;

    // Helper: assign opacity + z-index to both the main canvas AND its
    // paired reflection canvas at once so they cross-fade together.
    function setSlotVisuals(slot: Slot, opacity: string, zIndex: string, transition: string) {
      slot.el.style.transition = transition;
      slot.el.style.opacity = opacity;
      slot.el.style.zIndex = zIndex;
      if (slot.refl) {
        slot.refl.style.transition = transition;
        slot.refl.style.opacity = opacity;
        slot.refl.style.zIndex = zIndex;
      }
    }

    // Initial paint: no fade — directly render on the front slot and snap
    // its opacity to 1. The display element's solid #000 background covers
    // the photo's LED rectangle until the first frame paints.
    if (!front.pix) {
      front.pix = pix;
      front.frame = 0;
      front.fps = Math.max(1, fps);
      setSlotVisuals(front, '1', '2', 'none');
      setSlotVisuals(back, '0', '1', 'none');
      void front.el.offsetWidth; // commit instant styles before next paint
      setSlotVisuals(front, '1', '2', 'opacity 480ms ease');
      setSlotVisuals(back, '0', '1', 'opacity 480ms ease');
      if (inView) startSlot(front);
      return;
    }

    // Subsequent swap: stage on back, fade back IN above front.
    back.pix = pix;
    back.frame = 0;
    back.fps = Math.max(1, fps);
    setSlotVisuals(back, '0', '2', 'opacity 480ms ease');
    setSlotVisuals(front, '1', '1', 'opacity 480ms ease');
    if (inView) startSlot(back);
    else paintSlot(back);
    // Force a layout commit so the upcoming opacity change actually
    // transitions instead of being batched with the z-index change.
    void back.el.offsetWidth;
    back.el.style.opacity = '1';
    if (back.refl) back.refl.style.opacity = '1';
    await new Promise((r) => setTimeout(r, FADE_MS));
    if (myToken !== pendingSwapToken) return;
    // Swap roles. The old front becomes the staging slot; snap it to
    // opacity 0 instantly so it's invisible behind the new front, and
    // stop its animation loop to save cycles.
    const oldFront = front;
    front = back;
    back = oldFront;
    stopSlot(back);
    back.pix = null;
    setSlotVisuals(back, '0', '1', 'none');
    void back.el.offsetWidth;
    setSlotVisuals(back, '0', '1', 'opacity 480ms ease');
  }

  // === Scroll-driven chapter selection =====================================
  // We use IntersectionObserver with a tight rootMargin so only the chapter
  // currently sitting in the vertical middle band of the viewport is "active".
  // Chapters above/below the band emit non-intersecting events and don't
  // trigger a swap.
  const chapters = Array.from(document.querySelectorAll<HTMLElement>('[data-pscs-chapter]'));
  const chapterIO = new IntersectionObserver((entries) => {
    // Multiple chapters can intersect at once near the band edges; pick the
    // one whose centre is closest to the viewport centre.
    const visible = entries.filter((e) => e.isIntersecting);
    if (visible.length === 0) return;
    const vh = window.innerHeight;
    const mid = vh / 2;
    let best: { el: HTMLElement; dist: number } | null = null;
    for (const v of visible) {
      const rect = v.boundingClientRect;
      const c = rect.top + rect.height / 2;
      const d = Math.abs(c - mid);
      if (!best || d < best.dist) best = { el: v.target as HTMLElement, dist: d };
    }
    // Also re-scan all observed entries to catch the case where one chapter
    // is leaving and another is entering in the same callback batch but only
    // the leaving one is in `entries`.
    if (!best) return;
    const el = best.el;
    const slug = el.dataset.pscsChapter ?? '';
    const file = el.dataset.pscsFile ?? '';
    const fps = Number(el.dataset.pscsFps ?? '5');
    swapTo(slug, file, fps);
  }, {
    // Activate when the chapter's centre sits roughly mid-viewport.
    rootMargin: '-35% 0px -45% 0px',
    threshold: 0,
  });
  chapters.forEach((c) => chapterIO.observe(c));

  // === Scroll-driven chapter opacity =======================================
  // Each chapter fades in as its centre approaches the viewport centre and
  // fades out as it leaves. The curve is a smoothstep so the transition is
  // gentle near the edges and snappy near the centre — chapters arriving
  // from below are invisible until they enter the active band, then ramp up
  // to full opacity, then ramp back down as they leave upward.
  //
  // Tuning:
  //  - FULL_BAND:  fraction of viewport height where the chapter is solid 1.
  //  - FADE_BAND:  additional fraction over which it fades from 0 to 1.
  // dist = |chapter-centre − viewport-centre| in pixels.
  const FULL_BAND = 0.18; // ±18% of vh is fully opaque
  const FADE_BAND = 0.38; // an extra 38% of vh to fade from 0 to 1
  let rafPending = false;
  function updateChapterOpacity() {
    rafPending = false;
    const vh = window.innerHeight;
    const mid = vh / 2;
    const full = vh * FULL_BAND;
    const fade = vh * FADE_BAND;
    const maxDist = full + fade;
    for (const ch of chapters) {
      const r = ch.getBoundingClientRect();
      // Cheap pre-filter: skip chapters whose bounding box is entirely
      // outside the viewport plus a generous fade margin. Avoids the
      // smoothstep arithmetic and the style write for off-screen chapters.
      if (r.bottom < -fade || r.top > vh + fade) {
        // Make sure they're invisible — we still need to commit opacity 0
        // once when a chapter first leaves the active zone, but afterwards
        // it stays 0 so we can keep skipping the write.
        if (ch.style.opacity !== '0') ch.style.opacity = '0';
        continue;
      }
      const c = r.top + r.height / 2;
      const dist = Math.abs(c - mid);
      let t: number;
      if (dist <= full) t = 1;
      else if (dist >= maxDist) t = 0;
      else {
        const u = 1 - (dist - full) / fade;
        t = u * u * (3 - 2 * u); // smoothstep
      }
      // Avoid forcing a style recalc when the value hasn't moved enough to
      // matter. Two decimal places is sub-pixel for opacity rendering.
      const next = t.toFixed(2);
      if (ch.style.opacity !== next) ch.style.opacity = next;
    }
  }
  function scheduleOpacityUpdate() {
    if (rafPending) return;
    rafPending = true;
    requestAnimationFrame(updateChapterOpacity);
  }
  window.addEventListener('scroll', scheduleOpacityUpdate, { passive: true });
  window.addEventListener('resize', scheduleOpacityUpdate);
  scheduleOpacityUpdate();

  // === Stage visibility — pause when off-screen ============================
  if (stage) {
    const stageIO = new IntersectionObserver((entries) => {
      for (const e of entries) {
        inView = e.isIntersecting;
        if (inView) startAll();
        else stopAll();
      }
    }, { threshold: 0 });
    stageIO.observe(stage);
  }
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stopAll();
    else if (inView) startAll();
  });

  // === Initial pixogram — first chapter ====================================
  // Route the initial load through swapTo. swapTo skips the fade-out phase
  // when activePix is still null, so the page intro is a single fade-in.
  const first = chapters[0];
  if (first) {
    const slug = first.dataset.pscsChapter ?? '';
    const file = first.dataset.pscsFile ?? '';
    const fps = Number(first.dataset.pscsFps ?? '5');
    if (file) swapTo(slug, file, fps);
  }

  // === Perspective corners (same as PixogramLibrary) =======================
  type Corners = PerspectiveCorners;
  const CORNERS: Corners = {
    tl: { x: 10.4, y: 8.1 },
    tr: { x: 85.0, y: 9.3 },
    bl: { x: 10.4, y: 83.6 },
    br: { x: 84.8, y: 90.0 },
  };
  const REFL = { width: 0.9, offset: 0.1, opacity: 66, blur: 1.5 };
  const CROP = { top: 0.9, right: 1.3 };

  // Brightness multiplier lives on the reflection CONTAINER so it stacks
  // multiplicatively with each canvas's cross-fade opacity. Blur lives on
  // each canvas individually because filters compose with their target's
  // own pixels, not with siblings.
  if (reflEl) reflEl.style.opacity = String(REFL.opacity / 100);
  if (reflA) reflA.style.filter = `blur(${REFL.blur}px)`;
  if (reflB) reflB.style.filter = `blur(${REFL.blur}px)`;

  function applyCorners() {
    if (!clockEl || !displayEl) return;
    const rect = clockEl.getBoundingClientRect();
    if (rect.width === 0 || rect.height === 0) return;
    displayEl.style.transformOrigin = '0 0';
    displayEl.style.transform = cornersToMatrix3d(CORNERS, rect.width, rect.height);
    if (reflEl) {
      const rightX_top = CORNERS.tl.x + REFL.offset;
      const rightX_bot = CORNERS.bl.x + REFL.offset;
      const reflCorners: Corners = {
        tl: { x: rightX_top - REFL.width, y: CORNERS.tl.y },
        tr: { x: rightX_top,               y: CORNERS.tl.y },
        bl: { x: rightX_bot - REFL.width, y: CORNERS.bl.y },
        br: { x: rightX_bot,               y: CORNERS.bl.y },
      };
      reflEl.style.transform = cornersToMatrix3d(reflCorners, rect.width, rect.height);
    }
  }
  if (clockEl) {
    clockEl.style.setProperty('--pscs-crop-top', `${CROP.top}%`);
    clockEl.style.setProperty('--pscs-crop-right', `${CROP.right}%`);
    const ro = new ResizeObserver(() => applyCorners());
    ro.observe(clockEl);
  }
  window.addEventListener('resize', applyCorners);
  applyCorners();
</script>

<style>
  .pscs {
    font-family: 'Inter Tight', -apple-system, system-ui, Helvetica, Arial, sans-serif;
    font-feature-settings: 'tnum' 1;
    color: #0a0a0a;
    padding: clamp(4rem, 8vw, 6rem) clamp(1rem, 4vw, 3rem) 0;
    max-width: 1320px;
    margin: 0 auto;
  }
  .pscs__head {
    max-width: 60ch;
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .pscs__eyebrow {
    margin: 0 0 0.85rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(10, 10, 10, 0.55);
  }
  .pscs__title {
    margin: 0 0 1rem;
    font-family: 'Mona Sans', 'Inter Tight', sans-serif;
    font-size: clamp(1.9rem, 3.6vw, 2.9rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }
  .pscs__lead {
    margin: 0;
    color: rgba(10, 10, 10, 0.7);
    line-height: 1.6;
    font-size: clamp(1rem, 1.3vw, 1.08rem);
  }

  /* === Two-column layout: sticky clock | scrolling chapters =============== */
  .pscs__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  /* === Sticky stage (photo + projected canvas + reflection) =============== */
  /* align-self: stretch overrides the grid container's `align-items: start`
     so the stage column fills the full row height. Without this, the stage
     is only as tall as its content and `position: sticky` has zero scroll
     range — the clock just scrolls away with everything else. */
  .pscs__stage {
    position: relative;
    align-self: stretch;
    height: 100%;
  }
  .pscs__stage-inner {
    position: sticky;
    top: clamp(1rem, 6vh, 4rem);
    padding: clamp(1rem, 3vh, 2rem) 0;
  }
  .pscs__clock {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    --pscs-crop-top: 0.9%;
    --pscs-crop-right: 1.3%;
    transition: filter 380ms ease;
  }
  .pscs__clock.is-closing { filter: brightness(0.5) saturate(0.6); }
  .pscs__clock-photo {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 40px 80px rgba(10, 10, 10, 0.22));
    pointer-events: none;
  }
  .pscs__clock-display {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform-origin: 0 0;
    border-radius: 4px;
    clip-path: inset(var(--pscs-crop-top) var(--pscs-crop-right) 0 0);
    /* Solid black underneath the canvases: if a canvas is mid-transition or
       hasn't painted its first frame yet, the photo's LED display rectangle
       is still covered, so we never see the bare photo through the canvas. */
    background: #000;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      inset 0 8px 18px rgba(0, 0, 0, 0.45),
      inset -14px 0 28px -2px rgba(0, 0, 0, 0.6),
      inset 0 -12px 24px -2px rgba(0, 0, 0, 0.55),
      inset 2px 0 4px rgba(255, 255, 255, 0.04),
      0 0 80px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }
  .pscs__clock-display::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.10) 0%, rgba(255, 255, 255, 0) 32%, rgba(255, 255, 255, 0) 70%, rgba(255, 255, 255, 0.06) 100%),
      radial-gradient(ellipse 90% 110% at 50% 50%, rgba(0, 0, 0, 0) 55%, rgba(0, 0, 0, 0.35) 100%);
    border-radius: inherit;
