---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';
import type { Product } from '../lib/shop';
import WaveOverlay from './WaveOverlay.astro';

interface Props { locale: Locale; product: Product | null }
const { locale, product } = Astro.props;
const s = t(locale);

const stockLabel = !product
  ? null
  : !product.inStock
    ? s.stock.outOfStock
    : product.trackInventory && typeof product.stockQuantity === 'number' && product.stockQuantity <= 10
      ? s.stock.lowStock(product.stockQuantity)
      : s.stock.inStock;

// Tightly-cropped clock photo (transparent background) — the original
// whatis-clock.png had ~60% empty transparent margin around the clock,
// making the rendered image look tiny inside its grid column. The "-tight"
// variant trims to the clock's bounding box plus a small shadow gutter.
const productImage = '/img/products/whatis-clock-tight.png';

const hasDiscount = !!product?.discountedPrice;
const priceLabel = product?.price?.formatted ?? '';
const discountedLabel = product?.discountedPrice?.formatted ?? '';
const productHasVariants = !!product?.hasVariants && (product?.variants.length ?? 0) > 0;
---

<section class="section product section--bg-whatis">
  <div class="container product__grid">
    <div class="product__copy">
      <h5 class="h-card product__h">{s.whatIs.eyebrow}</h5>
      {s.whatIs.paragraphs.map((p) => <p class="lead">{p}</p>)}
      <p class="lead lead--bold">{s.whatIs.what}</p>
      <p class="lead">{s.whatIs.closing}</p>

      {product && (
        <div class="product__price">
          {hasDiscount ? (
            <>
              <span class="price__old">{s.price.salePrefix} {priceLabel}</span>
              <span class="price__now">{discountedLabel}</span>
            </>
          ) : (
            <span class="price__now">{priceLabel}</span>
          )}
        </div>
      )}
      {stockLabel && (
        <p class={`product__stock ${product?.inStock ? '' : 'product__stock--out'}`}>
          <span class="product__dot" aria-hidden="true"></span>{stockLabel}
        </p>
      )}
      {product && <p class="product__shipping">{s.shipping}</p>}

      {product && product.hasVariants && product.variants.length > 0 && (
        <fieldset class="product__variants" aria-label={product.options[0]?.name ?? 'Variant'}>
          <legend class="visually-hidden">{product.options[0]?.name ?? 'Variant'}</legend>
          {product.variants.map((v, i) => (
            <label class={v.inStock ? 'variant-chip' : 'variant-chip is-out'}>
              <input
                type="radio"
                name="selectedVariantId"
                value={v.id}
                form="buy-form"
                checked={i === 0}
                disabled={!v.inStock}
              />
              <span>{v.label}</span>
            </label>
          ))}
        </fieldset>
      )}

      <form method="POST" action="/api/cart/add" id="buy-form" class="product__cta">
        <input type="hidden" name="productId" value={product?.id ?? ''} />
        <input type="hidden" name="back" value={locale === 'de' ? '/de/cart' : '/cart'} />
        <input type="hidden" name="quantity" value="1" />
        {!productHasVariants && product && (
          <input type="hidden" name="variantId" value={product.variants[0]?.id ?? ''} />
        )}
        <button class="btn" type="submit" disabled={product != null && !product.inStock}>
          {s.whatIs.cta}
        </button>
      </form>
      <script is:inline>
        // Wire variant radio buttons → hidden variantId field on submit.
        (() => {
          const form = document.getElementById('buy-form');
          if (!form) return;
          form.addEventListener('submit', () => {
            const radio = document.querySelector('input[name="selectedVariantId"]:checked');
            if (radio && radio.value) {
              let hidden = form.querySelector('input[name="variantId"]');
              if (!hidden) {
                hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'variantId';
                form.appendChild(hidden);
              }
              hidden.value = radio.value;
            }
          });
        })();
      </script>
    </div>
    <div class="product__media">
      <img src={productImage} alt={product?.name ?? 'PXL Clock'} loading="lazy" />
    </div>
  </div>

  <WaveOverlay side="bottom" fill="#ffffff" height="180px" />
</section>

<style>
  .product { position: relative; padding-bottom: clamp(7rem, 14vw, 12rem); }
  /* Lives inside .container (1280 max), matching every other body section.
     Image is the visually dominant column via the 1 / 1.6 ratio rather than
     by overflowing the container. */
  .product__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }
  .product__h { margin-bottom: 1.5rem; font-weight: 700; }
  .product__copy { max-width: 460px; }
  .product__copy .lead { margin-bottom: 22px; }
  .lead--bold { font-weight: 700; }
  .product__media img {
    width: 100%;
    height: auto;
    object-fit: contain;
    background: transparent;
    /* Drop-shadow only renders on the visible (non-transparent) pixels of the
       PNG, so the section's gradient flows around the clock — no white box. */
    filter: drop-shadow(0 30px 50px rgba(0,0,0,0.18));
  }
  .product__price {
    display: flex; align-items: baseline; gap: 0.75rem;
    margin: 1.75rem 0 0.75rem;
  }
  .price__old { color: var(--muted); text-decoration: line-through; font-size: 1.05rem; }
  .price__now { font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 700; letter-spacing: -0.01em; }
  .product__stock {
    display: inline-flex; align-items: center; gap: 0.55rem;
    margin: 0 0 0.4rem; font-weight: 500; color: #1a7f37;
  }
  .product__stock--out { color: #b42318; }
  .product__dot { width: 9px; height: 9px; border-radius: 50%; background: currentColor; }
  .product__shipping { color: var(--muted); font-size: 0.92rem; margin: 0 0 1.5rem; }
  .product__cta { margin-top: 1.5rem; }
  .product__variants {
    border: 0; padding: 0; margin: 0 0 1rem;
    display: flex; gap: 0.5rem; flex-wrap: wrap;
  }
  .variant-chip {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.5rem 1rem;
    border: 1.5px solid var(--hairline); border-radius: 4px;
    cursor: pointer; font-weight: 700; font-size: 0.9rem;
    user-select: none;
  }
  .variant-chip input { position: absolute; opacity: 0; pointer-events: none; }
  .variant-chip:has(input:checked) { border-color: var(--fg); background: var(--fg); color: #fff; }
  .variant-chip.is-out { opacity: 0.5; cursor: not-allowed; text-decoration: line-through; }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  @media (max-width: 860px) {
    .product__grid { grid-template-columns: 1fr; }
    .product__media { order: -1; max-width: 460px; margin: 0 auto; }
  }
</style>
