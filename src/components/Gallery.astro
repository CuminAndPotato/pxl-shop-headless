---
interface Props {
  images: string[];
  ariaLabel?: string;
  /** Marquee speed in seconds for one full loop */
  speed?: number;
}
const { images, ariaLabel = 'Gallery', speed = 60 } = Astro.props;
// Duplicate the images so the marquee can loop seamlessly:
// once translation reaches the end of the first copy, it lands exactly on the
// start of the second copy → visually identical → instant jump back to 0.
const doubled = [...images, ...images];
const ITEM_W = 253;
const GAP = 16;
const stepPx = (ITEM_W + GAP) * images.length; // distance for one full set
---

<section class="gallery" aria-label={ariaLabel}>
  <div class="gallery__viewport">
    <div class="gallery__track" style={`--marquee-duration: ${speed}s; --step: ${stepPx}px;`}>
      {doubled.map((src, i) => (
        <div class="gallery__item" aria-hidden={i >= images.length ? 'true' : undefined}>
          <img
            src={src}
            alt=""
            loading={i < 5 ? 'eager' : 'lazy'}
            decoding="async"
            width="253"
            height="338"
            draggable="false"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    /* Larger vertical breathing room — the workshop slider especially needs
       it between the dark statement above and the next dark statement below. */
    padding: clamp(3rem, 6vw, 5rem) 0;
    overflow: hidden;
    background: #fff;
  }
  .gallery__viewport {
    width: 100%;
    overflow: hidden;
  }
  .gallery__track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: marquee var(--marquee-duration) linear infinite;
    will-change: transform;
    backface-visibility: hidden;
  }
  /* Hover does NOT pause. The marquee runs continuously. */
  .gallery__item {
    flex: 0 0 253px;
    height: 338px;
    overflow: hidden;
    background: #f0f0f0;
    user-select: none;
  }
  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    /* Translate by exactly one full set: end position is visually identical
       to start, so the loop wraps without any visible jump. */
    to   { transform: translateX(calc(-1 * var(--step))); }
  }
  /* prefers-reduced-motion intentionally NOT honored here — user requested the
     marquee always run. */
</style>
