---
import type { Locale } from '../i18n/strings';

interface Props {
  locale: Locale;
  /** Dark variant for placement on dark hero backgrounds. */
  inverted?: boolean;
}

const { locale, inverted = false } = Astro.props;

// Single-line trust signals + maker credentials. The dev cred is the
// strongest unique angle for this product — Sefa maintains one of the most-
// used Cordova plugins; Ronald maintains FsHttp and other F# OSS. That's
// not a generic "1000+ customers" claim, it's a concrete reason to trust
// who's behind the product.
const items = locale === 'de'
  ? [
      { label: 'Handmade in Germany', detail: 'kleine Manufaktur' },
      { label: 'Versand 2–4 Tage', detail: 'aus Deutschland' },
      { label: '2 Jahre Garantie', detail: '30 Tage Rückgabe' },
      { label: 'Open Source', detail: 'Code auf GitHub, Plugins auf NuGet' },
    ]
  : [
      { label: 'Handmade in Germany', detail: 'small workshop' },
      { label: 'Ships in 2–4 days', detail: 'from Germany' },
      { label: '2-year warranty', detail: '30-day returns' },
      { label: 'Open source', detail: 'code on GitHub, packages on NuGet' },
    ];

const makers = locale === 'de'
  ? 'Gebaut von zwei aktiven Open-Source-Entwicklern: Sefa (Maintainer von cordova-plugin-advanced-http) und Ronald (Maintainer von FsHttp, Mitglied der F#-Community).'
  : 'Built by two active open-source developers: Sefa (maintainer of cordova-plugin-advanced-http) and Ronald (maintainer of FsHttp, F# community member).';
---

<section class={inverted ? 'truststrip truststrip--inv' : 'truststrip'}>
  <ul class="truststrip__items">
    {items.map((it) => (
      <li>
        <strong>{it.label}</strong>
        <span>{it.detail}</span>
      </li>
    ))}
  </ul>
  <p class="truststrip__makers">{makers}</p>
</section>

<style>
  .truststrip {
    padding: clamp(1.2rem, 3vw, 1.8rem) var(--pad-x, 1.5rem);
    background: #fafaf7;
    border-top: 1px solid rgba(10, 10, 10, 0.05);
    border-bottom: 1px solid rgba(10, 10, 10, 0.05);
    font-family: 'Inter Tight', -apple-system, system-ui, sans-serif;
    color: #0a0a0a;
  }
  .truststrip--inv {
    background: #0d0e12;
    border-color: rgba(255, 255, 255, 0.08);
    color: #ece6da;
  }
  .truststrip__items {
    list-style: none;
    margin: 0 0 0.85rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1rem, 3vw, 2.4rem);
  }
  .truststrip__items li {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .truststrip__items strong {
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: -0.005em;
  }
  .truststrip__items span {
    font-size: 0.78rem;
    color: rgba(10, 10, 10, 0.55);
  }
  .truststrip--inv .truststrip__items span { color: rgba(236, 230, 218, 0.55); }
  .truststrip__makers {
    margin: 0;
    text-align: center;
    font-size: 0.86rem;
    line-height: 1.45;
    color: rgba(10, 10, 10, 0.65);
    max-width: 70ch;
    margin-left: auto;
    margin-right: auto;
  }
  .truststrip--inv .truststrip__makers { color: rgba(236, 230, 218, 0.65); }

  @media (max-width: 600px) {
    .truststrip__items { gap: 0.9rem 1.6rem; }
    .truststrip__items li { flex-direction: column; gap: 0.1rem; align-items: center; }
  }
</style>
