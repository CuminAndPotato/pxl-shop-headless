---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';
import type { Product } from '../lib/shop';
import type { ExperimentVariantSlug, PageVariant } from '../lib/page-variants';
import { lifestyleGallery, workshopGallery } from '../lib/assets';
import { url } from '../lib/url';
import PixogramShowcase from './PixogramShowcase.astro';

interface Props {
  locale: Locale;
  variant: PageVariant;
  product: Product | null;
}

const { locale, variant, product } = Astro.props;
const s = t(locale);
const copy = variant.copy[locale];
const experimentSlug = variant.slug as ExperimentVariantSlug;

const productImage = url('/img/products/whatis-clock-tight.png');
const price = product?.discountedPrice?.formatted ?? product?.price?.formatted ?? '229,00€';
const oldPrice = product?.discountedPrice ? product?.price?.formatted : '';
const cartHref = locale === 'de' ? url('/de/cart') : url('/cart');
const defaultVariantId = product?.variants[0]?.id ?? '';
const stock = product?.inStock
  ? locale === 'de' ? 'Auf Lager, Versand aus Deutschland' : 'In stock, ships from Germany'
  : locale === 'de' ? 'Aktuell nicht verfügbar' : 'Currently out of stock';

const specRows = locale === 'de'
  ? [
      ['Format', '24 x 24 RGB-LEDs, 576 Pixel'],
      ['Gehäuse', 'Handgefertigter Rahmen mit echtem Glas'],
      ['Größe', '27 x 27 x 6 cm'],
      ['Gewicht', '2 kg, Versand mit DHL'],
      ['Software', 'WiFi, OTA-Updates, Mobile App'],
      ['Programmierung', 'C# / .NET, Simulator, GitHub'],
    ]
  : [
      ['Format', '24 x 24 RGB LEDs, 576 pixels'],
      ['Body', 'Handmade frame with real glass'],
      ['Size', '27 x 27 x 6 cm'],
      ['Weight', '2 kg, ships with DHL'],
      ['Software', 'WiFi, OTA updates, mobile app'],
      ['Programmability', 'C# / .NET, simulator, GitHub'],
    ];

const proofCards = locale === 'de'
  ? [
      ['Warum teuer?', 'Kleine Serie, Handarbeit, echtes Glas, Elektronik, Software und Versand aus Deutschland.'],
      ['Warum nicht nur App?', 'Weil es ein Objekt im Raum ist. Es bleibt sichtbar, auch wenn dein Handy weg ist.'],
      ['Warum programmierbar?', 'Weil die Uhr nicht fertig sein muss. Sie kann deine eigenen Farben, Ideen und Animationen bekommen.'],
    ]
  : [
      ['Why this price?', 'Small run, handwork, real glass, electronics, software, and shipping from Germany.'],
      ['Why not just an app?', 'Because it is an object in the room. It stays visible when your phone disappears.'],
      ['Why programmable?', 'Because the clock does not have to be finished. It can carry your own colors, ideas, and animations.'],
    ];

const buildSteps = locale === 'de'
  ? [
      ['01', 'Matrix testen', 'Jede Clock beginnt als Lichtfläche: 576 LEDs, Helligkeit, Farbe, Timing.'],
      ['02', 'Rahmen bauen', 'Der Rahmen macht aus Technik ein Objekt. Glas, Tiefe, Schatten, Kante.'],
      ['03', 'Software flashen', 'WiFi, App, OTA und der Weg zu eigenen Pixogrammen.'],
      ['04', 'Verpacken', 'Kein Massenprodukt. Jede Uhr geht als fertiges Stück aus der Werkstatt.'],
    ]
  : [
      ['01', 'Test the matrix', 'Every clock starts as a field of light: 576 LEDs, brightness, color, timing.'],
      ['02', 'Build the frame', 'The frame turns technology into an object. Glass, depth, shadow, edge.'],
      ['03', 'Flash software', 'WiFi, app, OTA, and the path to your own pixograms.'],
      ['04', 'Pack it', 'Not mass-produced. Each clock leaves the workshop as a finished piece.'],
    ];

const codeSample = `public sealed class Orbit : Pixogram
{
    public override async Task Run(Matrix m)
    {
        await m.Clear("#050607");
        await m.DrawCircle(12, 12, 8, "#FFD56A");
        await m.Play();
    }
}`;

const deepContent: Record<ExperimentVariantSlug, {
  label: string;
  title: string;
  body: string;
  facts: [string, string][];
  chapters: [string, string][];
  includedTitle: string;
  included: string[];
  objectionsTitle: string;
  objections: [string, string][];
}> = locale === 'de'
  ? {
