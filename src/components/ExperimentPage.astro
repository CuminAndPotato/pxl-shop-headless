const deep = deepContent[experimentSlug];
---

<section class={`experiment experiment--${variant.slug}`}>
  {variant.slug === 'poster' && (
    <>
      <section class="xp-poster-hero">
        <div class="xp-poster-hero__type">
          <p>{copy.introEyebrow}</p>
          <h1><span>Pixel</span><span>Furniture</span><span>for time.</span></h1>
        </div>
        <figure class="xp-poster-hero__object"><img src={productImage} alt={product?.name ?? 'PXL Clock'} /></figure>
        <aside class="xp-poster-hero__buy">
          <strong>{price}</strong>
          {oldPrice && <span>{s.price.salePrefix} {oldPrice}</span>}
          <button type="button" data-xp-buy data-product-id={product?.id ?? ''} data-variant-id={defaultVariantId} data-cart-href={cartHref}>{s.whatIs.cta}</button>
        </aside>
      </section>
      <section class="xp-poster-strip">
        {copy.bullets.map((item) => <span>{item}</span>)}
      </section>
      <section class="xp-poster-info">
        <article><h2>{locale === 'de' ? 'Nicht bloß Uhr.' : 'Not just a clock.'}</h2><p>{copy.introLead}</p></article>
        <article><h2>576</h2><p>{locale === 'de' ? 'einzelne Lichtpunkte hinter echtem Glas.' : 'points of light behind real glass.'}</p></article>
        <article><h2>24x24</h2><p>{locale === 'de' ? 'klein genug für Klarheit, groß genug für Pixelart.' : 'small enough for clarity, large enough for pixel art.'}</p></article>
      </section>
    </>
  )}

  {variant.slug === 'console' && (
    <>
      <section class="xp-console-hero">
        <div class="xp-console-copy">
          <p class="eyebrow">{copy.introEyebrow}</p>
          <h1>{locale === 'de' ? 'Eine Uhr, die du bespielen kannst.' : 'A clock you can play.'}</h1>
          <p>{copy.introLead}</p>
          <pre><code>{codeSample}</code></pre>
        </div>
        <div class="xp-console-device">
          <PixogramShowcase locale={locale} />
        </div>
      </section>
      <section class="xp-console-modes">
        {['Clock', 'Weather', 'Pixel Art', 'Hackathon', 'Ambient'].map((mode) => <span>{mode}</span>)}
      </section>
    </>
  )}

  {variant.slug === 'catalog' && (
    <section class="xp-catalog">
      <div class="xp-catalog-gallery">
        <img class="xp-catalog-main" src={productImage} alt={product?.name ?? 'PXL Clock'} />
        {lifestyleGallery.slice(0, 4).map((image) => <img src={image} alt="" />)}
      </div>
      <div class="xp-catalog-buy">
        <p class="eyebrow">{locale === 'de' ? 'Produktdetailseite' : 'Product detail page'}</p>
        <h1>{product?.name ?? 'PXL Clock'}</h1>
        <p>{copy.introLead}</p>
        <div class="xp-catalog-price"><strong>{price}</strong>{oldPrice && <span>{s.price.salePrefix} {oldPrice}</span>}</div>
        <p class="xp-stock">{stock}</p>
        <button type="button" data-xp-buy data-product-id={product?.id ?? ''} data-variant-id={defaultVariantId} data-cart-href={cartHref}>{s.whatIs.cta}</button>
        <dl>{specRows.map(([key, value]) => <><dt>{key}</dt><dd>{value}</dd></>)}</dl>
      </div>
    </section>
  )}

