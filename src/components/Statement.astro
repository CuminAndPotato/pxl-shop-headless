---
interface Props {
  line1: string;
  line2?: string;
  bgImage?: string;
}
const { line1, line2, bgImage } = Astro.props;

// Pre-compose the background-image stack so the URL goes through directly
// (some browsers won't resolve var(--bg) inside `background-image` cleanly
// when combined with background-attachment: fixed).
const dimGradient = 'linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.55) 100%)';
const bgStyle = bgImage
  ? `background-image: ${dimGradient}, url('${bgImage}');`
  : '';
---

<section class="statement" style={bgStyle}>
  <div class="container statement__inner">
    <h2 class="statement__h">
      <span>{line1}</span>
      {line2 && <span>{line2}</span>}
    </h2>
  </div>
</section>

<style>
  /* Parallax via background-attachment: fixed — the photo stays anchored to
     the viewport while the text scrolls past, exactly like the live site.
     The dark gradient in the same `background-image` stack provides the
     readable-text overlay without an extra DOM node. */
  .statement {
    position: relative;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    text-align: center;
    background-color: #000;
    background-size: cover, cover;
    background-position: center, center;
    background-repeat: no-repeat, no-repeat;
    background-attachment: scroll, fixed;
  }
  /* iOS Safari can't composite background-attachment: fixed without jank, so
     fall back to scroll on touch devices. */
  @media (hover: none) and (pointer: coarse) {
    .statement { background-attachment: scroll, scroll; }
  }
  .statement__inner { position: relative; }
  .statement__h {
    font-weight: 500;
    font-size: clamp(1.75rem, 4vw, 3.25rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    color: #fff;
  }
  .statement__h span { display: block; }
</style>
