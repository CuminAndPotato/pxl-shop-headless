---
interface Props {
  line1: string;
  line2?: string;
  bgImage?: string;
}
const { line1, line2, bgImage } = Astro.props;
---

<section class="statement" style={bgImage ? `--bg: url('${bgImage}')` : undefined}>
  <div class="statement__overlay" aria-hidden="true"></div>
  <div class="container statement__inner">
    <h2 class="statement__h">
      <span>{line1}</span>
      {line2 && <span>{line2}</span>}
    </h2>
  </div>
</section>

<style>
  /* Parallax via background-attachment: fixed — the photo stays anchored to
     the viewport while the text scrolls past, exactly like the live site. */
  .statement {
    position: relative;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    text-align: center;
    background-color: #000;
    background-image: var(--bg);
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  /* iOS Safari can't composite background-attachment: fixed without jank, so
     fall back to scroll on touch devices. */
  @media (hover: none) and (pointer: coarse) {
    .statement { background-attachment: scroll; }
  }
  .statement__overlay {
    position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.55) 100%);
  }
  .statement__inner { position: relative; }
  .statement__h {
    font-weight: 500;
    font-size: clamp(1.75rem, 4vw, 3.25rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    color: #fff;
  }
  .statement__h span { display: block; }
</style>
