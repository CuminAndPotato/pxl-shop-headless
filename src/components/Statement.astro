---
interface Props {
  line1: string;
  line2?: string;
  bgImage?: string;
}
const { line1, line2, bgImage } = Astro.props;
---

<section class="statement">
  {bgImage && (
    <picture class="statement__pic">
      <img src={bgImage} alt="" loading="lazy" width="1920" height="900" />
    </picture>
  )}
  <div class="statement__overlay" aria-hidden="true"></div>
  <div class="container statement__inner">
    <h2 class="statement__h">
      <span>{line1}</span>
      {line2 && <span>{line2}</span>}
    </h2>
  </div>
</section>

<style>
  .statement {
    position: relative;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    text-align: center;
    background: #000;
  }
  .statement__pic { position: absolute; inset: 0; z-index: -2; }
  .statement__pic img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block;
  }
  .statement__overlay {
    position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.55) 100%);
  }
  .statement__inner { position: relative; }
  .statement__h {
    font-weight: 500;
    font-size: clamp(1.75rem, 4vw, 3.25rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    color: #fff;
  }
  .statement__h span { display: block; }
</style>
