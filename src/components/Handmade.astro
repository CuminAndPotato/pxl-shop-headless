---
import type { Locale } from '../i18n/strings';
import { url } from '../lib/url';
import { t } from '../i18n/strings';

interface Props { locale: Locale; productId?: string }
const { locale, productId } = Astro.props;
const s = t(locale);
---

<section class="section handmade section--white">
  <div class="container handmade__grid">
    <div class="handmade__copy">
      <h3 class="h-sub handmade__h">
        {s.handmade.title.map((line) => <span>{line}</span>)}
      </h3>
      {s.handmade.paragraphs.map((p) => <p class="lead">{p}</p>)}
      <div class="handmade__cta">
        <button
          class="btn"
          type="button"
          data-buy
          data-product-id={productId ?? ''}
          data-cart-href={locale === 'de' ? url('/de/cart') : url('/cart')}
          disabled={!productId}
        >
          {s.handmade.cta}
        </button>
      </div>
      <script>
        import { addToCart } from '../lib/shop-browser';
        const btn = document.querySelector<HTMLButtonElement>('.handmade__cta [data-buy]');
        if (btn) {
          btn.addEventListener('click', async () => {
            const productId = btn.dataset.productId;
            if (!productId) return;
            const cartHref = btn.dataset.cartHref ?? import.meta.env.BASE_URL + 'cart';
            btn.disabled = true;
            try {
              await addToCart({ productId, quantity: 1 });
              window.location.href = cartHref;
            } catch (err) {
              console.error('[Handmade] addToCart failed:', err);
              btn.disabled = false;
            }
          });
        }
      </script>
    </div>
    <div class="handmade__media">
      <video autoplay loop muted playsinline preload="metadata"
        poster={url("/img/products/pacman-poster.avif")}
        aria-label="PXL Clock playing Pac-Man animation">
        <source src={url("/video/pacman.mp4")} type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<style>
  .handmade__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .handmade__h { max-width: 14ch; font-weight: 700; }
  .handmade__h span { display: block; }
  .handmade__copy .lead { margin-bottom: 1rem; }
  .handmade__cta { margin-top: 1.5rem; }
  .handmade__media video,
  .handmade__media img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    background: #000;
  }
  @media (max-width: 860px) {
    .handmade__grid { grid-template-columns: 1fr; }
  }
</style>
