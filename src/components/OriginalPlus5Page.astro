      });
      gridGapInput?.addEventListener('input', () => {
        const v = Number(gridGapInput.value);
        if (Number.isFinite(v)) {
          settings.gridGap = Math.max(0, Math.min(10, v));
          applyGridGap();
        }
      });
      resetBtn?.addEventListener('click', () => {
        settings.enabled = DEFAULT_SETTINGS.enabled;
        settings.quad = cloneQuad(DEFAULT_SETTINGS.quad);
        settings.cropTop = DEFAULT_SETTINGS.cropTop;
        settings.cropRight = DEFAULT_SETTINGS.cropRight;
        settings.cornerTop = DEFAULT_SETTINGS.cornerTop;
        settings.gridGap = DEFAULT_SETTINGS.gridGap;
        settings.cellStyle = DEFAULT_SETTINGS.cellStyle;
        applyQuad();
        applyCropTop();
        applyCropRight();
        applyCornerTop();
        applyGridGap();
        applyCellStyle(settings.cellStyle);  // also calls applyEnabled
      });
      copyBtn?.addEventListener('click', () => {
        // Copies the entire `settings` object — covers every tab:
        //   Render  → enabled, cellStyle, quad, cropTop, cropRight,
        //             cornerTop, gridGap
        //   Pacing  → pacing.{heroEndVh, startVh, spacingVh, textFadeVh,
        //             activationFrac, pixTransitionVh, pixMarginVh}
        //   Story   → activeStory
        // Paste this into a chat to share a full tuning snapshot.
        const json = JSON.stringify(settings, null, 2);
        const originalLabel = copyBtn.textContent;
        const flash = (msg: string): void => {
          copyBtn.textContent = msg;
          setTimeout(() => { copyBtn.textContent = originalLabel; }, 900);
        };
        if (navigator.clipboard?.writeText) {
          navigator.clipboard.writeText(json)
            .then(() => flash('Copied'))
            .catch(() => flash('Failed'));
        } else {
          flash('No clipboard');
        }
      });
      toggleBtn?.addEventListener('click', () => {
        panel.classList.toggle('is-collapsed');
        toggleBtn.textContent = panel.classList.contains('is-collapsed') ? '+' : '–';
      });

      function applyGrippersVisible(): void {
        if (!grippersHost) return;
        grippersHost.hidden = !grippersCheck?.checked;
      }
      grippersCheck?.addEventListener('change', applyGrippersVisible);

      // 50px diagonal-outward offset from each corner. The direction is
      // OUT from the quad centroid so the gripper sits clear of the
      // canvas corner regardless of how slanted the quad becomes.
      const GRIP_OFFSET = 50;
      function positionGrippers(): void {
        if (!grippersHost) return;
        const cx = (viewQuad.tl.x + viewQuad.tr.x + viewQuad.br.x + viewQuad.bl.x) / 4;
        const cy = (viewQuad.tl.y + viewQuad.tr.y + viewQuad.br.y + viewQuad.bl.y) / 4;
        for (const g of grippers) {
          const which = g.dataset.grip as CornerKey;
          const p = viewQuad[which];
          const dx = p.x - cx, dy = p.y - cy;
          const len = Math.hypot(dx, dy) || 1;
          g.style.left = (p.x + (dx / len) * GRIP_OFFSET) + 'px';
          g.style.top  = (p.y + (dy / len) * GRIP_OFFSET) + 'px';
        }
      }
      onLedRectChanged = positionGrippers;
      positionGrippers();
      applyGrippersVisible();

      // Drag: each gripper moves ONLY its own corner. Image-space delta
      // = viewport-space delta / cover-scale (captured at drag start).
      for (const g of grippers) {
        g.addEventListener('pointerdown', (ev) => {
          ev.preventDefault();
          const which = g.dataset.grip as CornerKey;
          const scale = currentLedScale || 1;
          const origX = settings.quad[which].x;
          const origY = settings.quad[which].y;
          const sX = ev.clientX, sY = ev.clientY;
          g.setPointerCapture(ev.pointerId);
          const drag = (e: PointerEvent) => {
            settings.quad[which].x = Math.round(origX + (e.clientX - sX) / scale);
            settings.quad[which].y = Math.round(origY + (e.clientY - sY) / scale);
            applyQuad();
          };
          const up = (e: PointerEvent) => {
            g.releasePointerCapture(e.pointerId);
            g.removeEventListener('pointermove', drag);
            g.removeEventListener('pointerup', up);
          };
          g.addEventListener('pointermove', drag);
          g.addEventListener('pointerup', up);
        });
      }

      // ── Tab switcher (Render / Pacing / Story) ──────────────────────
      const tabButtons = Array.from(panel.querySelectorAll<HTMLButtonElement>('[data-op5-tab]'));
      const tabPanels = Array.from(panel.querySelectorAll<HTMLElement>('[data-op5-tab-panel]'));
      tabButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const targetTab = btn.dataset.op5Tab;
          tabButtons.forEach((b) => {
            const active = b.dataset.op5Tab === targetTab;
            b.classList.toggle('is-active', active);
            b.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          tabPanels.forEach((p) => {
            p.classList.toggle('is-hidden', p.dataset.op5TabPanel !== targetTab);
          });
        });
      });

      // ── Pacing tab — live tweaks for the scroll choreography ─────────
      const pacingInputs = Array.from(panel.querySelectorAll<HTMLInputElement>('[data-op5-pacing]'));
      const pacingOuts: Record<string, HTMLOutputElement | null> = {
        heroend:       panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="heroend"]'),
        start:         panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="start"]'),
        spacing:       panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="spacing"]'),
        textfade:      panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="textfade"]'),
        activation:    panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="activation"]'),
        pixtransition: panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="pixtransition"]'),
        pixmargin:     panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="pixmargin"]'),
        tailhold:      panel.querySelector<HTMLOutputElement>('[data-op5-pacing-out="tailhold"]'),
      };
      const pacingResetBtn = panel.querySelector<HTMLButtonElement>('[data-op5-pacing-reset]');
      function pacingValueFor(key: string): number {
        switch (key) {
          case 'heroend':       return HERO_END_VH;
          case 'start':         return START_VH;
          case 'spacing':       return SPACING_VH;
          case 'textfade':      return TEXT_FADE_VH;
          case 'activation':    return ACTIVATION_FRAC;
          case 'pixtransition': return PIXOGRAM_TRANSITION_VH;
          case 'pixmargin':     return PIXOGRAM_MARGIN_VH;
          case 'tailhold':      return TAIL_HOLD_VH;
          default:              return 0;
        }
      }
      function syncPacingControls(): void {
        pacingInputs.forEach((inp) => {
          const key = inp.dataset.op5Pacing ?? '';
          const val = pacingValueFor(key);
          if (document.activeElement !== inp) inp.value = String(val);
          const out = pacingOuts[key];
          if (out) out.value = key === 'activation' ? val.toFixed(2) : String(val);
        });
      }
      function applyPacing(): void {
        HERO_END_VH = settings.pacing.heroEndVh;
        START_VH = settings.pacing.startVh;
        SPACING_VH = settings.pacing.spacingVh;
        TEXT_FADE_VH = settings.pacing.textFadeVh;
        ACTIVATION_FRAC = settings.pacing.activationFrac;
        PIXOGRAM_TRANSITION_VH = settings.pacing.pixTransitionVh;
        PIXOGRAM_MARGIN_VH = settings.pacing.pixMarginVh;
        TAIL_HOLD_VH = settings.pacing.tailHoldVh;
        recomputeFades();
        applySpacerHeight();
        recomputeTargetDocY();
        // Invalidate per-chapter style write caches so the next rAF tick
        // pushes fresh opacity/transform values (the new FADES window
        // shifts what those should be).
        lastChStr.forEach((c) => { c.o = ''; c.t = ''; });
        saveSettings();
        syncPacingControls();
      }
      pacingInputs.forEach((inp) => {
        inp.addEventListener('input', () => {
          const key = inp.dataset.op5Pacing ?? '';
          const v = Number(inp.value);
          if (!Number.isFinite(v) || !key) return;
          switch (key) {
            case 'heroend':       settings.pacing.heroEndVh = v; break;
            case 'start':         settings.pacing.startVh = v; break;
            case 'spacing':       settings.pacing.spacingVh = v; break;
            case 'textfade':      settings.pacing.textFadeVh = v; break;
            case 'activation':    settings.pacing.activationFrac = v; break;
            case 'pixtransition': settings.pacing.pixTransitionVh = v; break;
            case 'pixmargin':     settings.pacing.pixMarginVh = v; break;
            case 'tailhold':      settings.pacing.tailHoldVh = v; break;
          }
          applyPacing();
        });
      });
      pacingResetBtn?.addEventListener('click', () => {
        settings.pacing = { ...DEFAULT_SETTINGS.pacing };
        applyPacing();
      });
      syncPacingControls();

      syncControls();
      setInterval(() => {
        if (fpsOut) fpsOut.value = fpsDisplay > 0 ? String(fpsDisplay) : '—';
      }, 500);
    }

    // ── Story switcher (inside Tweak panel, "Story" tab) ──────────────
    // Persist the click to localStorage, then reload. Reloading is the
    // simplest way to re-init the rAF loop with the new chapter set —
    // chapterMeta + lastChStr + FADES are all derived from chapterEls
    // at script start, and dynamic re-binding would touch too many
    // closures.
    if (panel) {
      const storyBtns = Array.from(panel.querySelectorAll<HTMLButtonElement>('[data-op5-story-btn]'));
      const storyBlurb = panel.querySelector<HTMLElement>('[data-op5-story-blurb]');
      const storyCurrent = panel.querySelector<HTMLElement>('[data-op5-story-current]');
      const STORY_BLURBS: Record<string, string> = Object.fromEntries(
        storyBtns.map((b) => [b.dataset.storyId ?? '', b.title ?? '']),
      );
      const STORY_LABELS: Record<string, string> = Object.fromEntries(
        storyBtns.map((b) => [b.dataset.storyId ?? '', b.textContent?.trim() ?? b.dataset.storyId ?? '']),
      );
      function syncStoryActive(): void {
        storyBtns.forEach((b) => {
          b.classList.toggle('is-active', b.dataset.storyId === activeStoryId);
        });
        if (storyBlurb) storyBlurb.textContent = STORY_BLURBS[activeStoryId] ?? '';
        if (storyCurrent) storyCurrent.textContent = STORY_LABELS[activeStoryId] ?? activeStoryId;
      }
      storyBtns.forEach((b) => {
        b.addEventListener('click', () => {
          const next = b.dataset.storyId;
          if (!next || next === activeStoryId) return;
          try {
            const raw = localStorage.getItem('op5-settings-v5');
            const parsed = raw ? JSON.parse(raw) : {};
            parsed.activeStory = next;
            localStorage.setItem('op5-settings-v5', JSON.stringify(parsed));
          } catch {}
          location.reload();
        });
      });
      syncStoryActive();
    }

    // ── Act badge ──────────────────────────────────────────────────────
    const badgeNum = page.querySelector<HTMLElement>('[data-op5-badge-num]');
    const badgeName = page.querySelector<HTMLElement>('[data-op5-badge-name]');
    if (badgeNum && badgeName) {
      // Thresholds in "viewport heights of scroll", matched to the 700vh
      // spacer geometry (max progress ≈ 7).
      const acts: Array<[number, string, string]> = [
        [0.75, '1', 'Hero out'],
        [1.75, '2', 'Chapter 1'],
        [2.75, '3', 'Chapter 2'],
        [3.75, '4', 'Chapter 3'],
        [4.75, '5', 'Chapter 4'],
        [6,    '6', 'Variants slide'],
        [7,    '7', 'Unpin'],
      ];
      let last = -1;
      let raf = 0;
      const update = () => {
        raf = 0;
        const rect = target.getBoundingClientRect();
        const progress = -rect.top / window.innerHeight;
        let idx = acts.length;
        for (let i = 0; i < acts.length; i++) {
          if (progress < acts[i][0]) { idx = i; break; }
        }
        if (idx !== last) {
          last = idx;
          if (idx === acts.length) {
            badgeNum.textContent = '–';
            badgeName.textContent = 'Post';
          } else {
            badgeNum.textContent = acts[idx][1];
            badgeName.textContent = acts[idx][2];
          }
        }
      };
      const onScroll = () => { if (!raf) raf = requestAnimationFrame(update); };
      window.addEventListener('scroll', onScroll, { passive: true });
      update();
    }
  }
</script>

<style>
  .op5-page {
    background: #0a0a0a;
    color: #fff;
    font-family: 'Inter Tight', -apple-system, system-ui, Helvetica, Arial, sans-serif;

    /* Tunable: how far from the left edge the chapter eyebrow/title/body
       starts. Hero title sits at `padding-left: var(--pad-x)` (= 160px),
       so the chapter sits slightly to the RIGHT of it. Adjust the
       additive offset to move chapters left/right. */
    --op5-chapter-left: calc(var(--pad-x) + 80px);
  }

  /* Dev act indicator: pinned to top-right, always above everything. */
  .op5-act-badge {
