    // chapter id (or -1 for unassigned). The two slots crossfade: the
    // slot holding the dominant chapter (highest opacity) is kept at
    // opacity 1 underneath; the slot holding the secondary chapter sits
    // on top with opacity = its raw chapter opacity. Because adjacent
    // chapter fade windows overlap 1:1 (oA + oB ≈ 1 during a transition),
    // the opaque underlayer guarantees the wrap is always fully covered.
    type SlotKey = 'A' | 'B';
    interface SlotState {
      chapterIdx: number;
    }
