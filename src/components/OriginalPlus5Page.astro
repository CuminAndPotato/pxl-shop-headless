---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';
import type { Product } from '../lib/shop';
import type { PageVariant } from '../lib/page-variants';
import { url } from '../lib/url';
import Variants from './Variants.astro';

interface Props {
  locale: Locale;
  variant: PageVariant;
  product: Product | null;
}

const { locale } = Astro.props;
const s = t(locale);

// Chapters that scroll through Acts 2–5. Each chapter pairs a pixogram
// (rendered on the LED canvas overlaid on the hero photo) with text on
// the left side. Reuses Plus⁴'s curated set so we can iterate the
// scroll choreography without re-doing the copy.
interface Chapter {
  slug: string;
  file: string;
  fps: number;
  eyebrow: string;
  title: string;
  body: string;
}
const chapters: Chapter[] = locale === 'de'
  ? [
      { slug: 'ourtinysailboat',    file: 'ourtinysailboat.pxl',    fps: 5, eyebrow: 'Pixogramm 01', title: 'Our Tiny Sailboat',    body: 'Eine kleine Szene, die einfach passiert: ein Segelboot, eine Welle, ein Horizont. Pixogramme müssen nicht "smart" sein — manchmal reicht ein Bild, das atmet.' },
      { slug: 'colourwheeldynamic', file: 'colourwheeldynamic.pxl', fps: 5, eyebrow: 'Pixogramm 02', title: 'Colour Wheel Dynamic', body: 'Reine Farbe, kein Inhalt. Ein HSV-Rad, das sich permanent neu sortiert — die Uhr wird zur Farbpalette an der Wand und zeigt nebenbei die Sekunde.' },
      { slug: 'mythen',             file: 'mythen.pxl',             fps: 5, eyebrow: 'Pixogramm 03', title: 'Mythen',               body: 'Die Silhouette der Schweizer Mythen über einem zerfließenden Sonnenuntergang. Ein Pixogramm ist 24 × 24 — und kann trotzdem eine Landschaft sein.' },
      { slug: 'gameoflife',         file: 'gameoflife.pxl',         fps: 5, eyebrow: 'Pixogramm 04', title: 'Game of Life',         body: 'Conways Game of Life, live auf 576 Zellen. Jede Generation rechnet die Uhr selbst — kein Loop, kein Cheat. Ein Bildschirm darf auch einfach denken.' },
    ]
  : [
      { slug: 'ourtinysailboat',    file: 'ourtinysailboat.pxl',    fps: 5, eyebrow: 'Pixogram 01', title: 'Our Tiny Sailboat',    body: 'A small scene that simply happens — a boat, a wave, a horizon. Pixograms do not have to be "smart". Sometimes a quiet picture that breathes is enough.' },
      { slug: 'colourwheeldynamic', file: 'colourwheeldynamic.pxl', fps: 5, eyebrow: 'Pixogram 02', title: 'Colour Wheel Dynamic', body: 'Pure colour, no subject. An HSV wheel that keeps reshuffling itself — the clock turns into a colour palette on the wall and still tells you the second.' },
      { slug: 'mythen',             file: 'mythen.pxl',             fps: 5, eyebrow: 'Pixogram 03', title: 'Mythen',               body: 'The silhouette of the Swiss Mythen mountains over a slow sunset gradient. 24 × 24 pixels are still enough room for a landscape.' },
      { slug: 'gameoflife',         file: 'gameoflife.pxl',         fps: 5, eyebrow: 'Pixogram 04', title: 'Game of Life',         body: 'Conway\'s Game of Life, running live across 576 cells. Every generation is computed on the device — no loop, no cheat. A screen is allowed to just think.' },
    ];
---

{/* Plus⁵ — Hero-only sandbox for Motion (motion.dev).
    Markup + styling of the hero itself mirror Hero.astro 1:1 so the initial
    on-load view is visually identical to Plus⁴. The added wrapping (200vh
    scroll spacer with the hero `position: sticky` inside) is invisible at
    rest — it only becomes meaningful once the user starts scrolling, at
    which point Motion's scroll() scrubs two animations:
      1. .hero__title translates up and fades out
      2. .hero__pic dims its filter:brightness from 1 to 0.2
    After the scroll spacer is consumed, the Variants section follows. */}
<div class="op5-page" data-op5>
  {/* Dev/debug-only act indicator. Pinned to viewport, shows which Act of
      the choreography is currently active based on scroll position. */}
  <div class="op5-act-badge" data-op5-badge aria-hidden="true">
    <span data-op5-badge-num>1</span>
    <span data-op5-badge-name>Hero out</span>
  </div>

  {/* Dev tweak panel — render-mode toggle, live FPS, LED bbox inputs.
      Pairs with the four corner grippers (rendered inside .hero) to fine
      tune the canvas projection without code edits. State persists to
      localStorage so adjustments survive reloads. */}
  <aside class="op5-tweak" data-op5-tweak>
    <header class="op5-tweak__head">
      <strong>Plus⁵ Tweak</strong>
      <button type="button" data-op5-tweak-toggle aria-label="Collapse">–</button>
    </header>
    <div class="op5-tweak__body">
      <div class="op5-tweak__row">
        <span>FPS</span>
        <output data-op5-tweak-fps>—</output>
      </div>
      <div class="op5-tweak__row">
        <span>Render</span>
        <div class="op5-tweak__seg" data-op5-tweak-mode>
          <button type="button" data-mode="photoreal">Photoreal</button>
          <button type="button" data-mode="flat">Flat</button>
          <button type="button" data-mode="off">Off</button>
        </div>
      </div>
      <div class="op5-tweak__row op5-tweak__row--slider">
        <span>Crop top</span>
        <input type="range" data-op5-tweak-croptop min="0" max="5" step="0.1">
        <output data-op5-tweak-croptop-out>0</output>%
      </div>
      <div class="op5-tweak__row op5-tweak__row--slider">
        <span>Crop right</span>
        <input type="range" data-op5-tweak-cropright min="0" max="5" step="0.1">
        <output data-op5-tweak-cropright-out>0</output>%
      </div>
      <div class="op5-tweak__row op5-tweak__row--slider">
        <span>Corner top</span>
        <input type="range" data-op5-tweak-cornertop min="0" max="50" step="1">
        <output data-op5-tweak-cornertop-out>0</output>px
      </div>
      <div class="op5-tweak__row op5-tweak__row--slider">
        <span>Grid gap</span>
        <input type="range" data-op5-tweak-gridgap min="0" max="10" step="0.1">
        <output data-op5-tweak-gridgap-out>2</output>px
      </div>
      <fieldset class="op5-tweak__fs">
        <legend>LED corners (image-px)</legend>
        <label>TL x <input type="number" data-corner="tl" data-axis="x" step="1"></label>
        <label>TL y <input type="number" data-corner="tl" data-axis="y" step="1"></label>
        <label>TR x <input type="number" data-corner="tr" data-axis="x" step="1"></label>
        <label>TR y <input type="number" data-corner="tr" data-axis="y" step="1"></label>
        <label>BR x <input type="number" data-corner="br" data-axis="x" step="1"></label>
        <label>BR y <input type="number" data-corner="br" data-axis="y" step="1"></label>
        <label>BL x <input type="number" data-corner="bl" data-axis="x" step="1"></label>
        <label>BL y <input type="number" data-corner="bl" data-axis="y" step="1"></label>
      </fieldset>
      <div class="op5-tweak__row">
        <label class="op5-tweak__check">
          <input type="checkbox" data-op5-tweak-grippers checked>
          Show corner grippers
        </label>
      </div>
      <div class="op5-tweak__actions">
        <button type="button" data-op5-tweak-reset>Reset</button>
        <button type="button" data-op5-tweak-copy>Copy</button>
      </div>
    </div>
  </aside>
  <div class="op5-hero-scroll" data-op5-scroll>
    <div class="op5-hero-sticky">
    <section class="hero">
      <picture class="hero__pic" data-op5-bg>
        <img
          src={url('/img/sections/hero-lifestyle.avif')}
          alt=""
          width="2400"
          height="1600"
        />
      </picture>
      <div class="hero__overlay" aria-hidden="true"></div>
      {/* Dim layer — black overlay whose opacity is scroll-scrubbed in
          Act 1. Replaces `filter: brightness()` on the bg <img> because
          opacity on a flat-colour layer is ~free on the GPU, while a
          filter shader has to run over the entire 2400×1600 bg texture
          each composite. */}
      <div class="hero__dim" data-op5-dim aria-hidden="true"></div>
      {/* Clock-only overlay: same image cropped to the PXL Clock with the
          rest transparent. Sits ON TOP of the dim gradient at the same
          positioning as hero__pic so they line up pixel-perfectly. The
          dimming filter only targets hero__pic, so the clock stays at
          full brightness while the background fades. */}
      <picture class="hero__clock" data-op5-clock aria-hidden="true">
        <img
          src={url('/img/sections/hero-lifestyle-clock.webp')}
          alt=""
          width="2400"
          height="1600"
        />
      </picture>
      {/* LED stage — a wrapper div carries the matrix3d transform; the
          actual LEDs are a 24×24 HTML grid of <div>s. Per frame the JS
          only sets `--r/--g/--b` CSS custom properties on cells whose
          colour changed, so the main-thread work is just N setProperty
          calls (N typically 100–300, NOT 576). The browser handles cell
          rasterisation + bloom on its compositor/raster thread. */}
      <div class="hero__led-wrap" data-op5-led-wrap aria-hidden="true">
        <div class="hero__led-grid" data-op5-led-grid>
          {Array.from({ length: 576 }).map(() => <div class="hero__led-cell"></div>)}
        </div>
      </div>
      {/* Corner grippers — visible only when the tweak panel's "Show
          corner grippers" is on. Each gripper is offset diagonally
          OUTWARD from its LED corner by 50px so the canvas corner stays
          visible inside the gripper bracket. Drag a gripper to adjust the
          LED bbox in image-space. */}
      <div class="hero__grippers" data-op5-grippers hidden>
        <button type="button" class="hero__grip" data-grip="tl" aria-label="Top-left corner"></button>
        <button type="button" class="hero__grip" data-grip="tr" aria-label="Top-right corner"></button>
        <button type="button" class="hero__grip" data-grip="br" aria-label="Bottom-right corner"></button>
        <button type="button" class="hero__grip" data-grip="bl" aria-label="Bottom-left corner"></button>
      </div>
      {/* Chapter panel on the left. One container per chapter, all
          absolute-stacked at the same position; opacity is scrubbed by
          scroll position so they cross-fade through. */}
      <div class="hero__chapters" data-op5-chapters>
        {chapters.map((c, i) => (
          <div
            class="hero__chapter"
            data-op5-chapter
            data-chapter-index={i}
            data-chapter-slug={c.slug}
            data-chapter-file={c.file}
            data-chapter-fps={c.fps}
          >
            <p class="hero__chapter-eyebrow">{c.eyebrow}</p>
            <h2 class="hero__chapter-title">{c.title}</h2>
            <p class="hero__chapter-body">{c.body}</p>
          </div>
        ))}
      </div>
      <div class="hero__inner">
        <h1 class="h-display hero__title" data-op5-title>
          {s.hero.title.map((line) => <span>{line}</span>)}
        </h1>
      </div>
    </section>
    </div>
  </div>

  <Variants locale={locale} />

  {/* Hidden SVG defs — the bloom filter applied to the LED grid in
      Photoreal mode. feGaussianBlur is GPU-accelerated by modern
      browsers; feComposite arithmetic adds the blurred copy back on
      top of the source for an additive halo. */}
  <svg class="op5-defs" aria-hidden="true" focusable="false">
    <defs>
      <filter id="op5-led-bloom" x="-25%" y="-25%" width="150%" height="150%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="0.5" result="blur" />
        <feComposite in="blur" in2="SourceGraphic" operator="arithmetic" k1="0" k2="0.55" k3="1" k4="0" />
      </filter>
    </defs>
  </svg>
</div>

<script>
  import { parsePxl, type Pixogram } from '../lib/pxl-format';
  // Canvas-based renderers are no longer used — we paint the LED grid as
  // 576 HTML divs whose colour is set via CSS custom properties. The
  // browser does the cell rasterisation and a single SVG feGaussianBlur
  // filter pass for the bloom halo, all on the compositor/raster thread.
  import { cornersToMatrix3d } from '../lib/pxlib-perspective';
  import { url } from '../lib/url';

  const page = document.querySelector<HTMLElement>('[data-op5]');
  if (page) {
    const target = page.querySelector<HTMLElement>('[data-op5-scroll]')!;
    const hero = target.querySelector<HTMLElement>('.hero')!;
    const title = page.querySelector<HTMLElement>('[data-op5-title]');
    const bg = page.querySelector<HTMLElement>('[data-op5-bg]');
    const bgImg = bg?.querySelector('img') ?? null;
    const dim = page.querySelector<HTMLElement>('[data-op5-dim]');
    const clock = page.querySelector<HTMLElement>('[data-op5-clock]');
    const ledWrap = page.querySelector<HTMLElement>('[data-op5-led-wrap]');
    const ledGrid = page.querySelector<HTMLElement>('[data-op5-led-grid]');
    const ledCells = ledGrid ? Array.from(ledGrid.children) as HTMLElement[] : [];
    const chapterEls = Array.from(
      page.querySelectorAll<HTMLElement>('[data-op5-chapter]'),
    );

    // Act 1 animations (title out, dim in, clock fade in) were previously
    // driven by three separate motion.scroll() calls. Each installed its
    // own scroll listener + per-frame value-apply pipeline, so during
    // Act 1 the scroll thread had four animation handlers (3 motion + 1
    // rAF) all doing redundant work. Consolidated into the main rAF loop
    // below — one scroll handler, one writes-only-when-changed pass.

    // ── LED projection ─────────────────────────────────────────────────
    // The PXL Clock LED panel in hero-lifestyle.avif is a quadrilateral
    // (slight perspective tilt). We store FOUR independent corners in
    // IMAGE coordinates (1989×1119 source) and project them into the
    // hero's local space by replaying the CSS `object-fit: cover;
    // object-position: center 30%` math. The canvas itself sits at
    // hero (0,0) with a fixed base size; `matrix3d` warps it onto the
    // four corner points each layout pass.
    interface Pt { x: number; y: number }
    interface Quad { tl: Pt; tr: Pt; br: Pt; bl: Pt }
    const LED_NATURAL = { w: 1989, h: 1119 };
    // Calibrated against the hero-lifestyle.avif photo. Adjust here OR
    // via the dev tweak panel; the panel writes back to localStorage.
    const DEFAULT_QUAD: Quad = {
      tl: { x: 1208, y: 391 },
      tr: { x: 1672, y: 393 },
      br: { x: 1669, y: 869 },
      bl: { x: 1208, y: 839 },
    };
    // Live, mutable image-space corners. Tweak-panel inputs / gripper
    // drags edit this in place; positionLed reads from it.
    const LED_QUAD: Quad = {
      tl: { ...DEFAULT_QUAD.tl }, tr: { ...DEFAULT_QUAD.tr },
      br: { ...DEFAULT_QUAD.br }, bl: { ...DEFAULT_QUAD.bl },
    };
    const OBJECT_POS_X = 0.5;
    const OBJECT_POS_Y = 0.3; // fixed — matches CSS `object-position: center 30%`
    // Canvas base CSS size — matrix3d transforms this rectangle to the
    // four corners, so the value just needs to be big enough for crisp
    // backbuffer resolution (renderRgbPhotoreal then ups by DPR).
    const CANVAS_BASE = 600;

    // 4 viewport (hero-local) corners — populated by positionLed. Used by
    // the grippers and matrix3d transform.
    const viewQuad: Quad = {
      tl: { x: 0, y: 0 }, tr: { x: 0, y: 0 },
      br: { x: 0, y: 0 }, bl: { x: 0, y: 0 },
    };
    let currentLedScale = 1; // viewport-px per image-px (uniform under cover)
    let currentLedHeight = 0; // avg vertical span of the live quad, for chapter motion amplitude

    let dirty = true;
    let lastPaintedKey = '';
    function markDirty(): void { dirty = true; lastPaintedKey = ''; }
    let onLedRectChanged: () => void = () => {};

    function positionLed(): void {
      if (!ledWrap || !bg || !hero) return;
      const r = bg.getBoundingClientRect();
      if (r.width === 0 || r.height === 0) return;
      // Cover math against the hero element box (bg <picture> has inset 0).
      const imgAR = LED_NATURAL.w / LED_NATURAL.h;
      const elAR = r.width / r.height;
      let dispW: number, dispH: number;
      if (imgAR > elAR) { dispH = r.height; dispW = dispH * imgAR; }
      else              { dispW = r.width;  dispH = dispW / imgAR; }
      const offX = (r.width - dispW) * OBJECT_POS_X;
      const offY = (r.height - dispH) * OBJECT_POS_Y;
      const scale = dispW / LED_NATURAL.w;
      currentLedScale = scale;
      // Project each image-space corner into hero-local viewport coords.
      const heroRect = hero.getBoundingClientRect();
      const dx = r.left - heroRect.left;
      const dy = r.top - heroRect.top;
      (['tl', 'tr', 'br', 'bl'] as const).forEach((k) => {
        viewQuad[k].x = dx + offX + LED_QUAD[k].x * scale;
        viewQuad[k].y = dy + offY + LED_QUAD[k].y * scale;
      });
      // matrix3d on the wrapper — the LED grid inside is a 2D layer.
      ledWrap.style.left = '0px';
      ledWrap.style.top = '0px';
      ledWrap.style.width = CANVAS_BASE + 'px';
      ledWrap.style.height = CANVAS_BASE + 'px';
      ledWrap.style.transformOrigin = '0 0';
      const toPct = (p: Pt) => ({ x: (p.x / CANVAS_BASE) * 100, y: (p.y / CANVAS_BASE) * 100 });
      ledWrap.style.transform = cornersToMatrix3d(
        { tl: toPct(viewQuad.tl), tr: toPct(viewQuad.tr), br: toPct(viewQuad.br), bl: toPct(viewQuad.bl) },
        CANVAS_BASE, CANVAS_BASE,
      );
      // Average left & right edge heights → used by the chapter animation
      // amplitude. Doesn't drive chapter REST position any more (those
      // values are CSS-fixed) — only how far text travels in its window.
      const leftH = viewQuad.bl.y - viewQuad.tl.y;
      const rightH = viewQuad.br.y - viewQuad.tr.y;
      currentLedHeight = (leftH + rightH) / 2;
      markDirty();
      onLedRectChanged();
    }
    if (ledWrap) {
      positionLed();
      window.addEventListener('resize', positionLed);
      // ResizeObserver catches every size change of the bg element —
      // viewport resize, browser zoom, mobile URL-bar collapse, devtools
      // open/close — even when `resize` doesn't fire. visualViewport
      // covers pinch-zoom on touch devices.
      if (bg && 'ResizeObserver' in window) {
        const ro = new ResizeObserver(() => positionLed());
        ro.observe(bg);
      }
      if (typeof window.visualViewport !== 'undefined' && window.visualViewport) {
        window.visualViewport.addEventListener('resize', positionLed);
      }
      // Re-run after the image loads in case the hero hadn't laid out yet.
      if (bgImg && !bgImg.complete) bgImg.addEventListener('load', positionLed, { once: true });
    }

    // ── Pixogram playback ──────────────────────────────────────────────
    // Single canvas, single rAF loop. The "active" pixogram is whichever
    // chapter has the highest current opacity (computed from scroll). The
    // canvas's own opacity follows the SUM of all chapter opacities (clamped
    // to 1) so it dims to 0 outside the chapter range and stays fully
    // visible during crossfades.
    const pixCache = new Map<string, Pixogram | null>();
    async function loadPx(file: string): Promise<Pixogram | null> {
      if (pixCache.has(file)) return pixCache.get(file) ?? null;
      try {
        const res = await fetch(url('/pixograms/' + file));
        if (!res.ok) throw new Error('http ' + res.status);
        const pix = parsePxl(await res.text());
        pixCache.set(file, pix);
        return pix;
      } catch (e) {
        pixCache.set(file, null);
        return null;
      }
    }
    // Kick off loading all chapter files up front.
    const chapterMeta = chapterEls.map((el) => ({
      el,
      idx: Number(el.dataset.chapterIndex),
      file: el.dataset.chapterFile || '',
      fps: Number(el.dataset.chapterFps) || 5,
    }));
    chapterMeta.forEach((c) => { void loadPx(c.file); });

    // ── Chapter timing ─────────────────────────────────────────────────
    // ▼▼▼ THE pacing knobs — tweak here, FADES is derived from these. ▼▼▼
    //   CHAPTER_START_VH  doc-scroll vh where ch1's fade-in starts
    //                     (= end of Act 1, normally 75)
    //   CHAPTER_FADE_VH   length of each fade-in and fade-out
    //   CHAPTER_HOLD_VH   how long the chapter is FULLY visible
    //
    //   Per-chapter window  = 2·fade + hold
    //   Start-to-start dist = fade + hold  (= "how soon does the next
    //                         chapter start fading in")
    //
    //   Adjacent chapters overlap by exactly CHAPTER_FADE_VH so the
    //   fade-out of N coincides 1:1 with the fade-in of N+1 (cross-fade).
    //
    // TODO responsiveness: on narrow viewports these vh-based windows
    // map to less actual pixel distance — may feel hectic on mobile.
    // Future fix: scale via a media query or compute against an
    // effective-viewport multiplier.
    const CHAPTER_START_VH = 75;
    const CHAPTER_FADE_VH = 20;
    const CHAPTER_HOLD_VH = 30;
    const CHAPTER_WINDOW_VH = 2 * CHAPTER_FADE_VH + CHAPTER_HOLD_VH;
    const CHAPTER_STEP_VH = CHAPTER_FADE_VH + CHAPTER_HOLD_VH;
    const FADES: Array<[number, number, number, number]> = Array.from(
      { length: chapterMeta.length },
      (_, i) => {
        const s = CHAPTER_START_VH + i * CHAPTER_STEP_VH;
        return [s, s + CHAPTER_FADE_VH, s + CHAPTER_FADE_VH + CHAPTER_HOLD_VH, s + CHAPTER_WINDOW_VH];
      },
    );
    function chapterOpacityAt(progressVh: number, i: number): number {
      const [a, b, c, d] = FADES[i];
      if (progressVh <= a || progressVh >= d) return 0;
      if (progressVh >= b && progressVh <= c) return 1;
      if (progressVh < b) return (progressVh - a) / (b - a);
      return (d - progressVh) / (d - c);
    }
    // translateY for the chapter text. Linear interpolation across the
    // ENTIRE window — no hold in the middle. The text just scrolls up at
    // a constant rate while it's the active chapter, the way a normal
    // paragraph would behave on a non-pinned page. Total travel is
    // 2 × LED-height (from +H below the clock area to −H above it), which
    // keeps the motion confined to roughly the clock's vertical extent.
    const TRAVEL_FACTOR = 1.0; // multiplier on LED-height for each side
    function chapterTranslateAt(progressVh: number, i: number): number {
      const [a, _b, _c, d] = FADES[i];
      const h = currentLedHeight || 400;
      const t = Math.max(0, Math.min(1, (progressVh - a) / (d - a)));
      return (1 - 2 * t) * TRAVEL_FACTOR * h;
    }

    // ── Settings (persisted) ───────────────────────────────────────────
    // Render-mode + LED quad corners are user-tweakable via the dev
    // panel. State lives in `settings` and persists to localStorage.
    type RenderMode = 'photoreal' | 'flat' | 'off';
    interface Settings {
      mode: RenderMode;
      quad: Quad;
      /** 0–100. Percent of the LED wrap height that gets clipped off
       *  the top via `clip-path: inset(N% 0 0 0)`. Purely visual; does
       *  NOT shift the bg image or re-project the LED. */
      cropTop: number;
      /** 0–5. Same idea as cropTop, but clips the right edge. */
      cropRight: number;
      /** 0–50, in CSS px of the LED wrap's local coordinate system
       *  (CANVAS_BASE = 600). Radius applied to the TL + TR corners of
       *  the clip-path inset, softening the top edge. */
      cornerTop: number;
      /** Grid gap between LED cells, in CSS px of the wrap's local
       *  coordinate system (CANVAS_BASE = 600). Smaller = tighter
       *  pixels, more "panel-like"; larger = more visible trenches. */
      gridGap: number;
    }
    // v5 schema kept so previous tweaks survive; new fields read as
    // defaults if the stored object pre-dates them.
    const SETTINGS_KEY = 'op5-settings-v5';
    const DEFAULT_SETTINGS: Settings = {
      mode: 'photoreal',
      quad: {
        tl: { ...DEFAULT_QUAD.tl }, tr: { ...DEFAULT_QUAD.tr },
        br: { ...DEFAULT_QUAD.br }, bl: { ...DEFAULT_QUAD.bl },
      },
      cropTop: 1,
      cropRight: 0.8,
      cornerTop: 3,
      gridGap: 2,
    };
    function cloneQuad(q: Quad): Quad {
      return { tl: { ...q.tl }, tr: { ...q.tr }, br: { ...q.br }, bl: { ...q.bl } };
    }
    function freshSettings(): Settings {
      return {
        mode: DEFAULT_SETTINGS.mode,
        quad: cloneQuad(DEFAULT_SETTINGS.quad),
        cropTop: DEFAULT_SETTINGS.cropTop,
        cropRight: DEFAULT_SETTINGS.cropRight,
        cornerTop: DEFAULT_SETTINGS.cornerTop,
        gridGap: DEFAULT_SETTINGS.gridGap,
      };
    }
    function loadSettings(): Settings {
      try {
        const raw = localStorage.getItem(SETTINGS_KEY);
        if (!raw) return freshSettings();
        const parsed = JSON.parse(raw);
        const q = parsed.quad ?? {};
        return {
          mode: parsed.mode ?? DEFAULT_SETTINGS.mode,
          quad: {
            tl: { ...DEFAULT_SETTINGS.quad.tl, ...(q.tl ?? {}) },
            tr: { ...DEFAULT_SETTINGS.quad.tr, ...(q.tr ?? {}) },
            br: { ...DEFAULT_SETTINGS.quad.br, ...(q.br ?? {}) },
            bl: { ...DEFAULT_SETTINGS.quad.bl, ...(q.bl ?? {}) },
          },
          cropTop: typeof parsed.cropTop === 'number' ? parsed.cropTop : DEFAULT_SETTINGS.cropTop,
          cropRight: typeof parsed.cropRight === 'number' ? parsed.cropRight : DEFAULT_SETTINGS.cropRight,
          cornerTop: typeof parsed.cornerTop === 'number' ? parsed.cornerTop : DEFAULT_SETTINGS.cornerTop,
          gridGap: typeof parsed.gridGap === 'number' ? parsed.gridGap : DEFAULT_SETTINGS.gridGap,
        };
      } catch {
        return freshSettings();
      }
    }
    function saveSettings(): void {
      try { localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings)); } catch {}
    }
    const settings: Settings = loadSettings();
    // After loading, point positionLed at the loaded quad by mutating
    // LED_QUAD in place (positionLed already reads from it).
    (['tl', 'tr', 'br', 'bl'] as const).forEach((k) => {
      LED_QUAD[k].x = settings.quad[k].x;
      LED_QUAD[k].y = settings.quad[k].y;
    });
    // Crop-top + corner-top are pure visual clip-path knobs on the LED
    // wrap — driven by CSS custom properties, never recompute layout or
    // the projection. Bg image and clock overlay stay anchored.
    page.style.setProperty('--op5-led-crop-top', settings.cropTop + '%');
    page.style.setProperty('--op5-led-crop-right', settings.cropRight + '%');
    page.style.setProperty('--op5-led-corner-top', settings.cornerTop + 'px');
    page.style.setProperty('--op5-led-grid-gap', settings.gridGap + 'px');

    // ── Animation loop ─────────────────────────────────────────────────
    // The canvas paint is the expensive part. We ONLY repaint when the
    // pixogram's frame index actually advances (fps-throttled) — not on
    // every rAF — which on a 5fps pixogram cuts paints by ~12×. The rest
    // of the loop body (opacity + translateY for 4 chapter elements) is
    // composited and cheap.
    let lastFrameTs = 0;
    let frameCounter = 0;
    let activeIdx = -1;
    // Per-cell colour cache — packed rgb (24-bit) for each of the 576
    // cells. Diff against the new frame so we only touch the DOM for
    // cells whose colour actually changed.
    const lastRgb: Int32Array = new Int32Array(ledCells.length);
    lastRgb.fill(-1);
    const OFF_R = 12, OFF_G = 13, OFF_B = 16; // matches the original photoreal void colour
    // Mode classes applied to the grid. Only ONE may be active at a time.
    function applyGridModeClass(): void {
      if (!ledGrid) return;
      ledGrid.classList.toggle('is-flat', settings.mode === 'flat');
      ledGrid.classList.toggle('is-off',  settings.mode === 'off');
      // Photoreal = default (bloom filter + cell highlight overlay).
    }

    // Cache target's document-Y so the rAF loop never has to call
    // getBoundingClientRect (which forces a sync layout flush at 60Hz).
    // Recompute on resize.
    let targetDocY = 0;
    function recomputeTargetDocY(): void {
      targetDocY = target.getBoundingClientRect().top + window.scrollY;
    }
    recomputeTargetDocY();
    window.addEventListener('resize', recomputeTargetDocY);

    // Style-write cache. Browsers DO short-circuit identical style writes,
    // but skipping the assignment also avoids the String() allocation and
    // the property setter call on hot paths.
    const lastChStr: Array<{ o: string; t: string }> = chapterMeta.map(() => ({ o: '', t: '' }));
    let lastLedOpacityStr = '';
    // Per-element caches for the Act 1 animations folded into the loop.
    let lastTitleTransform = '';
    let lastTitleOpacity = '';
    let lastDimOpacity = '';
    let lastClockOpacity = '';

    // Cache viewport height; reads cost nothing but the property access
    // adds up, and resize is the only thing that can change it.
    let vh = window.innerHeight;
    window.addEventListener('resize', () => { vh = window.innerHeight; });

    function repaint(): void {
      if (activeIdx < 0 || ledCells.length === 0) return;
      const meta = chapterMeta[activeIdx];
      const pix = pixCache.get(meta.file);
      if (!pix) return;
      const frame = pix.frames[frameCounter % pix.frames.length];
      // For 'off' mode the CSS class makes every cell render flat-dark;
      // we still update lastRgb so the next non-off frame triggers a
      // full repaint of any cells whose colour differs.
      if (settings.mode === 'off') {
        for (let i = 0; i < ledCells.length; i++) {
          if (lastRgb[i] === 0) continue;
          lastRgb[i] = 0;
          const cell = ledCells[i];
          cell.style.setProperty('--r', String(OFF_R));
          cell.style.setProperty('--g', String(OFF_G));
          cell.style.setProperty('--b', String(OFF_B));
        }
        return;
      }
      // Photoreal + Flat both update the cell's --r/--g/--b. The visual
      // difference comes from CSS classes on the grid (filter + cell
      // gradient highlight on/off).
      const total = ledCells.length;
      for (let i = 0; i < total; i++) {
        const off = i * 3;
        const r = frame[off];
        const g = frame[off + 1];
        const b = frame[off + 2];
        const dark = r + g + b < 12;
        const er = dark ? OFF_R : r;
        const eg = dark ? OFF_G : g;
        const eb = dark ? OFF_B : b;
        // Pack into a single 24-bit int for cheap diff.
        const packed = (er << 16) | (eg << 8) | eb;
        if (lastRgb[i] === packed) continue;
        lastRgb[i] = packed;
        const cell = ledCells[i];
        cell.style.setProperty('--r', String(er));
        cell.style.setProperty('--g', String(eg));
        cell.style.setProperty('--b', String(eb));
      }
    }

    function loop(now: number): void {
      // Pure scroll-position math — no getBoundingClientRect, no layout
      // flush. window.scrollY is essentially a cached value.
      const progressPx = window.scrollY - targetDocY;
      const progressVh = progressPx / vh * 100;

      // ── Act 1: title out + dim in + clock fade in (0–75vh) ────────
      // translate3d (not translateY) so the browser keeps the title on
      // a dedicated GPU compositor layer — same trick used below for
      // chapters and the LED canvas.
      const act1 = progressVh <= 0 ? 0 : progressVh >= 75 ? 1 : progressVh / 75;
      if (title) {
        const tyPx = -act1 * 0.75 * vh;
        const tStr = `translate3d(0,${tyPx.toFixed(1)}px,0)`;
        const oStr = (1 - act1).toFixed(3);
        if (tStr !== lastTitleTransform) { title.style.transform = tStr; lastTitleTransform = tStr; }
        if (oStr !== lastTitleOpacity)   { title.style.opacity   = oStr; lastTitleOpacity   = oStr; }
      }
      if (dim) {
        const oStr = (act1 * 0.7).toFixed(3);
        if (oStr !== lastDimOpacity) { dim.style.opacity = oStr; lastDimOpacity = oStr; }
      }
      if (clock) {
        const oStr = act1.toFixed(3);
        if (oStr !== lastClockOpacity) { clock.style.opacity = oStr; lastClockOpacity = oStr; }
      }

      // ── Acts 2–5: chapter cross-fades + scroll-up motion ──────────
      let sum = 0;
      let bestOpacity = -1;
      let bestIdx = -1;
      for (let i = 0; i < chapterMeta.length; i++) {
        const o = chapterOpacityAt(progressVh, i);
        const ty = chapterTranslateAt(progressVh, i);
        const oStr = o.toFixed(3);
        const tStr = `translate3d(0,${ty.toFixed(1)}px,0)`;
        const cache = lastChStr[i];
        if (cache.o !== oStr) { chapterMeta[i].el.style.opacity = oStr; cache.o = oStr; }
        if (cache.t !== tStr) { chapterMeta[i].el.style.transform = tStr; cache.t = tStr; }
        sum += o;
        if (o > bestOpacity) { bestOpacity = o; bestIdx = i; }
      }
      const ledOp = Math.min(1, sum).toFixed(3);
      // Opacity goes on the WRAPPER (matrix3d carrier). The canvases
      // inside stay opaque so the compositor can keep them as static
      // 2D layers behind the wrapper's transform.
      if (ledWrap && ledOp !== lastLedOpacityStr) {
        ledWrap.style.opacity = ledOp;
        lastLedOpacityStr = ledOp;
      }

      if (bestIdx !== activeIdx) {
        activeIdx = bestIdx;
        frameCounter = 0;
        lastFrameTs = now;
        markDirty();
      }

      // Repaint ONLY when frame advances or chapter swaps. Also skip
      // entirely when the canvas is invisible (opacity ≈ 0).
      if (activeIdx >= 0 && bestOpacity > 0.01) {
        const meta = chapterMeta[activeIdx];
        const intervalMs = 1000 / meta.fps;
        if (now - lastFrameTs >= intervalMs) {
          frameCounter += 1;
          lastFrameTs = now - ((now - lastFrameTs) % intervalMs);
          markDirty();
        }
        const key = activeIdx + ':' + frameCounter;
        if (dirty || key !== lastPaintedKey) {
          repaint();
          lastPaintedKey = key;
          dirty = false;
        }
      }

      fpsTick(now);
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);

    // ── Live FPS counter (used by the dev panel) ───────────────────────
    let fpsSamples = 0;
    let fpsAccum = 0;
    let fpsLast = 0;
    let fpsDisplay = 0;
    function fpsTick(now: number): void {
      if (fpsLast > 0) {
        fpsAccum += now - fpsLast;
        fpsSamples += 1;
        if (fpsAccum >= 500) {
          fpsDisplay = Math.round(1000 * fpsSamples / fpsAccum);
          fpsAccum = 0;
          fpsSamples = 0;
        }
      }
      fpsLast = now;
    }

    // ── Tweak panel ────────────────────────────────────────────────────
    // Wires the floating panel + corner grippers to the LED bbox and
    // render-mode settings. Two-way binding: number inputs and gripper
    // drags both update `settings.bbox` and call positionLed; the panel
    // re-reads from `settings` on every change to keep all controls in
    // sync.
    const panel = page.querySelector<HTMLElement>('[data-op5-tweak]');
    const grippersHost = page.querySelector<HTMLElement>('[data-op5-grippers]');
    if (panel) {
      type CornerKey = 'tl' | 'tr' | 'br' | 'bl';
      type Axis = 'x' | 'y';
      const modeButtons = Array.from(panel.querySelectorAll<HTMLButtonElement>('[data-op5-tweak-mode] button'));
      const fpsOut = panel.querySelector<HTMLOutputElement>('[data-op5-tweak-fps]');
      const cornerInputs = Array.from(panel.querySelectorAll<HTMLInputElement>('[data-corner]'));
      const cropTopInput = panel.querySelector<HTMLInputElement>('[data-op5-tweak-croptop]');
      const cropTopOut = panel.querySelector<HTMLOutputElement>('[data-op5-tweak-croptop-out]');
      const cropRightInput = panel.querySelector<HTMLInputElement>('[data-op5-tweak-cropright]');
      const cropRightOut = panel.querySelector<HTMLOutputElement>('[data-op5-tweak-cropright-out]');
      const cornerTopInput = panel.querySelector<HTMLInputElement>('[data-op5-tweak-cornertop]');
      const cornerTopOut = panel.querySelector<HTMLOutputElement>('[data-op5-tweak-cornertop-out]');
      const gridGapInput = panel.querySelector<HTMLInputElement>('[data-op5-tweak-gridgap]');
      const gridGapOut = panel.querySelector<HTMLOutputElement>('[data-op5-tweak-gridgap-out]');
      const toggleBtn = panel.querySelector<HTMLButtonElement>('[data-op5-tweak-toggle]');
      const resetBtn = panel.querySelector<HTMLButtonElement>('[data-op5-tweak-reset]');
      const copyBtn = panel.querySelector<HTMLButtonElement>('[data-op5-tweak-copy]');
      const grippersCheck = panel.querySelector<HTMLInputElement>('[data-op5-tweak-grippers]');
      const grippers = grippersHost ? Array.from(grippersHost.querySelectorAll<HTMLButtonElement>('[data-grip]')) : [];

      function syncControls(): void {
        modeButtons.forEach((b) => {
          b.classList.toggle('is-active', b.dataset.mode === settings.mode);
        });
        cornerInputs.forEach((inp) => {
          if (document.activeElement === inp) return;
          const c = inp.dataset.corner as CornerKey;
          const a = inp.dataset.axis as Axis;
          inp.value = String(settings.quad[c][a]);
        });
        if (cropTopInput && document.activeElement !== cropTopInput) cropTopInput.value = String(settings.cropTop);
        if (cropTopOut) cropTopOut.value = String(settings.cropTop);
        if (cropRightInput && document.activeElement !== cropRightInput) cropRightInput.value = String(settings.cropRight);
        if (cropRightOut) cropRightOut.value = String(settings.cropRight);
        if (cornerTopInput && document.activeElement !== cornerTopInput) cornerTopInput.value = String(settings.cornerTop);
        if (cornerTopOut) cornerTopOut.value = String(settings.cornerTop);
        if (gridGapInput && document.activeElement !== gridGapInput) gridGapInput.value = String(settings.gridGap);
        if (gridGapOut) gridGapOut.value = String(settings.gridGap);
      }
      function applyCropTop(): void {
        page.style.setProperty('--op5-led-crop-top', settings.cropTop + '%');
        saveSettings();
        syncControls();
      }
      function applyCropRight(): void {
        page.style.setProperty('--op5-led-crop-right', settings.cropRight + '%');
        saveSettings();
        syncControls();
      }
      function applyCornerTop(): void {
        page.style.setProperty('--op5-led-corner-top', settings.cornerTop + 'px');
        saveSettings();
        syncControls();
      }
      function applyGridGap(): void {
        page.style.setProperty('--op5-led-grid-gap', settings.gridGap + 'px');
        saveSettings();
        syncControls();
      }
      function applyMode(m: RenderMode): void {
        settings.mode = m;
        saveSettings();
        applyGridModeClass();
        markDirty();
        syncControls();
      }
      function applyQuad(): void {
        (['tl', 'tr', 'br', 'bl'] as const).forEach((k) => {
          LED_QUAD[k].x = settings.quad[k].x;
          LED_QUAD[k].y = settings.quad[k].y;
        });
        saveSettings();
        positionLed();
        syncControls();
      }

      modeButtons.forEach((b) => {
        b.addEventListener('click', () => applyMode(b.dataset.mode as RenderMode));
      });
      // Apply mode class on initial mount.
      applyGridModeClass();
      cornerInputs.forEach((inp) => {
        inp.addEventListener('input', () => {
          const c = inp.dataset.corner as CornerKey;
          const a = inp.dataset.axis as Axis;
          const v = Number(inp.value);
          if (Number.isFinite(v)) {
            settings.quad[c][a] = v;
            applyQuad();
          }
        });
      });
      cropTopInput?.addEventListener('input', () => {
        const v = Number(cropTopInput.value);
        if (Number.isFinite(v)) {
          settings.cropTop = Math.max(0, Math.min(5, v));
          applyCropTop();
        }
      });
      cropRightInput?.addEventListener('input', () => {
        const v = Number(cropRightInput.value);
        if (Number.isFinite(v)) {
          settings.cropRight = Math.max(0, Math.min(5, v));
          applyCropRight();
        }
      });
      cornerTopInput?.addEventListener('input', () => {
        const v = Number(cornerTopInput.value);
        if (Number.isFinite(v)) {
          settings.cornerTop = Math.max(0, Math.min(50, v));
          applyCornerTop();
        }
      });
      gridGapInput?.addEventListener('input', () => {
        const v = Number(gridGapInput.value);
        if (Number.isFinite(v)) {
          settings.gridGap = Math.max(0, Math.min(10, v));
          applyGridGap();
        }
      });
      resetBtn?.addEventListener('click', () => {
        settings.mode = DEFAULT_SETTINGS.mode;
        settings.quad = cloneQuad(DEFAULT_SETTINGS.quad);
        settings.cropTop = DEFAULT_SETTINGS.cropTop;
        settings.cropRight = DEFAULT_SETTINGS.cropRight;
        settings.cornerTop = DEFAULT_SETTINGS.cornerTop;
        settings.gridGap = DEFAULT_SETTINGS.gridGap;
        applyQuad();
        applyCropTop();
        applyCropRight();
        applyCornerTop();
        applyGridGap();
        applyMode(settings.mode);
      });
      copyBtn?.addEventListener('click', () => {
        // Whole settings object (mode, quad, cropTop, cropRight,
        // cornerTop). Paste-friendly for dropping straight back into
        // DEFAULT_SETTINGS or for sharing tunings.
        navigator.clipboard?.writeText(JSON.stringify(settings, null, 2));
      });
      toggleBtn?.addEventListener('click', () => {
        panel.classList.toggle('is-collapsed');
        toggleBtn.textContent = panel.classList.contains('is-collapsed') ? '+' : '–';
      });

      function applyGrippersVisible(): void {
        if (!grippersHost) return;
        grippersHost.hidden = !grippersCheck?.checked;
      }
      grippersCheck?.addEventListener('change', applyGrippersVisible);

      // 50px diagonal-outward offset from each corner. The direction is
      // OUT from the quad centroid so the gripper sits clear of the
      // canvas corner regardless of how slanted the quad becomes.
      const GRIP_OFFSET = 50;
      function positionGrippers(): void {
        if (!grippersHost) return;
        const cx = (viewQuad.tl.x + viewQuad.tr.x + viewQuad.br.x + viewQuad.bl.x) / 4;
        const cy = (viewQuad.tl.y + viewQuad.tr.y + viewQuad.br.y + viewQuad.bl.y) / 4;
        for (const g of grippers) {
          const which = g.dataset.grip as CornerKey;
          const p = viewQuad[which];
          const dx = p.x - cx, dy = p.y - cy;
          const len = Math.hypot(dx, dy) || 1;
          g.style.left = (p.x + (dx / len) * GRIP_OFFSET) + 'px';
          g.style.top  = (p.y + (dy / len) * GRIP_OFFSET) + 'px';
        }
      }
      onLedRectChanged = positionGrippers;
      positionGrippers();
      applyGrippersVisible();

      // Drag: each gripper moves ONLY its own corner. Image-space delta
      // = viewport-space delta / cover-scale (captured at drag start).
      for (const g of grippers) {
        g.addEventListener('pointerdown', (ev) => {
          ev.preventDefault();
          const which = g.dataset.grip as CornerKey;
          const scale = currentLedScale || 1;
          const origX = settings.quad[which].x;
          const origY = settings.quad[which].y;
          const sX = ev.clientX, sY = ev.clientY;
          g.setPointerCapture(ev.pointerId);
          const drag = (e: PointerEvent) => {
            settings.quad[which].x = Math.round(origX + (e.clientX - sX) / scale);
            settings.quad[which].y = Math.round(origY + (e.clientY - sY) / scale);
            applyQuad();
          };
          const up = (e: PointerEvent) => {
            g.releasePointerCapture(e.pointerId);
            g.removeEventListener('pointermove', drag);
            g.removeEventListener('pointerup', up);
          };
          g.addEventListener('pointermove', drag);
          g.addEventListener('pointerup', up);
        });
      }

      syncControls();
      setInterval(() => {
        if (fpsOut) fpsOut.value = fpsDisplay > 0 ? String(fpsDisplay) : '—';
      }, 500);
    }

    // ── Act badge ──────────────────────────────────────────────────────
    const badgeNum = page.querySelector<HTMLElement>('[data-op5-badge-num]');
    const badgeName = page.querySelector<HTMLElement>('[data-op5-badge-name]');
    if (badgeNum && badgeName) {
      // Thresholds in "viewport heights of scroll", matched to the 700vh
      // spacer geometry (max progress ≈ 7).
      const acts: Array<[number, string, string]> = [
        [0.75, '1', 'Hero out'],
        [1.75, '2', 'Chapter 1'],
        [2.75, '3', 'Chapter 2'],
        [3.75, '4', 'Chapter 3'],
        [4.75, '5', 'Chapter 4'],
        [6,    '6', 'Variants slide'],
        [7,    '7', 'Unpin'],
      ];
      let last = -1;
      let raf = 0;
      const update = () => {
        raf = 0;
        const rect = target.getBoundingClientRect();
        const progress = -rect.top / window.innerHeight;
        let idx = acts.length;
        for (let i = 0; i < acts.length; i++) {
          if (progress < acts[i][0]) { idx = i; break; }
        }
        if (idx !== last) {
          last = idx;
          if (idx === acts.length) {
            badgeNum.textContent = '–';
            badgeName.textContent = 'Post';
          } else {
            badgeNum.textContent = acts[idx][1];
            badgeName.textContent = acts[idx][2];
          }
        }
      };
      const onScroll = () => { if (!raf) raf = requestAnimationFrame(update); };
      window.addEventListener('scroll', onScroll, { passive: true });
      update();
    }
  }
</script>

<style>
  .op5-page {
    background: #0a0a0a;
    color: #fff;
    font-family: 'Inter Tight', -apple-system, system-ui, Helvetica, Arial, sans-serif;

    /* Tunable: how far from the left edge the chapter eyebrow/title/body
       starts. Hero title sits at `padding-left: var(--pad-x)` (= 160px),
       so the chapter sits slightly to the RIGHT of it. Adjust the
       additive offset to move chapters left/right. */
    --op5-chapter-left: calc(var(--pad-x) + 80px);
  }

  /* Dev act indicator: pinned to top-right, always above everything. */
  .op5-act-badge {
    position: fixed;
    top: 14px;
    right: 14px;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #fff;
    font: 500 13px/1 ui-monospace, 'SF Mono', Menlo, monospace;
    letter-spacing: 0.02em;
    pointer-events: none;
    user-select: none;
  }
  .op5-act-badge [data-op5-badge-num] {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 6px;
    background: #fff;
    color: #000;
    font-weight: 700;
    font-size: 11px;
  }
  .op5-act-badge [data-op5-badge-name] {
    opacity: 0.85;
  }

  /* === Dev tweak panel ====================================================
     Pinned top-left so it doesn't fight the act badge top-right. Wider so
     the corner-bbox inputs fit two-up without squeezing. */
  .op5-tweak {
    position: fixed;
    top: 14px;
    left: 14px;
    z-index: 9998;
    width: 320px;
    background: rgba(10, 12, 18, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    color: #fff;
    font: 12px/1.4 ui-monospace, 'SF Mono', Menlo, monospace;
  }
  .op5-tweak.is-collapsed .op5-tweak__body { display: none; }
  .op5-tweak__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .op5-tweak__head strong { font-size: 12px; letter-spacing: 0.04em; }
  .op5-tweak__head button {
    width: 22px; height: 22px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 5px;
    color: #fff;
    font: 600 14px/1 ui-monospace, monospace;
    cursor: pointer;
  }
  .op5-tweak__body { padding: 10px; display: flex; flex-direction: column; gap: 10px; }
  .op5-tweak__row { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .op5-tweak__row--slider { gap: 6px; }
  .op5-tweak__row--slider input[type="range"] { flex: 1; min-width: 0; }
