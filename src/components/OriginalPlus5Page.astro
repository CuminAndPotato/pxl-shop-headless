---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';
import type { Product } from '../lib/shop';
import type { PageVariant } from '../lib/page-variants';
import { url } from '../lib/url';
import Variants from './Variants.astro';

interface Props {
  locale: Locale;
  variant: PageVariant;
  product: Product | null;
}

const { locale } = Astro.props;
const s = t(locale);

// All five scroll-story arcs live here. The user picks one via the
// Story panel (top-center floating UI); selection is persisted to
// localStorage and re-read on page load. Every story's chapters are
// rendered into the DOM and tagged with `data-story`; CSS hides
// chapters whose `data-story` doesn't match the active one, and the JS
// builds chapterMeta only from the visible set.
//
// Editing notes
//   • Each chapter is rendered as: eyebrow · glyph · title · body
//   • Bodies are 3–5 sentences. Concrete nouns; no jargon.
//   • Every story ends in a CTA chapter — Mk1, €299 (RONALD = €274),
//     pxlclock.com, Discord, GitHub. Product knowledge → action.
//   • Glyphs are decorative emoji; CSS adds a subtle float animation.
interface Chapter {
  slug: string;
  file: string;
  fps: number;
  eyebrow: string;
  title: string;
  body: string;
  glyph?: string;
}
interface Story {
  id: string;
  label: string;
  blurb: string;
  chapters: Chapter[];
}
