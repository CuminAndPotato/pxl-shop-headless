---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';
import type { Product } from '../lib/shop';
import type { PageVariant } from '../lib/page-variants';
import { url } from '../lib/url';
import Variants from './Variants.astro';

interface Props {
  locale: Locale;
  variant: PageVariant;
  product: Product | null;
}

const { locale } = Astro.props;
const s = t(locale);

// Chapters that scroll through Acts 2–5. Each chapter pairs a pixogram
// (rendered on the LED canvas overlaid on the hero photo) with text on
// the left side. Reuses Plus⁴'s curated set so we can iterate the
// scroll choreography without re-doing the copy.
interface Chapter {
  slug: string;
  file: string;
  fps: number;
  eyebrow: string;
  title: string;
  body: string;
}
const chapters: Chapter[] = locale === 'de'
  ? [
      { slug: 'ourtinysailboat',    file: 'ourtinysailboat.pxl',    fps: 5, eyebrow: 'Pixogramm 01', title: 'Our Tiny Sailboat',    body: 'Eine kleine Szene, die einfach passiert: ein Segelboot, eine Welle, ein Horizont. Pixogramme müssen nicht "smart" sein — manchmal reicht ein Bild, das atmet.' },
      { slug: 'colourwheeldynamic', file: 'colourwheeldynamic.pxl', fps: 5, eyebrow: 'Pixogramm 02', title: 'Colour Wheel Dynamic', body: 'Reine Farbe, kein Inhalt. Ein HSV-Rad, das sich permanent neu sortiert — die Uhr wird zur Farbpalette an der Wand und zeigt nebenbei die Sekunde.' },
      { slug: 'mythen',             file: 'mythen.pxl',             fps: 5, eyebrow: 'Pixogramm 03', title: 'Mythen',               body: 'Die Silhouette der Schweizer Mythen über einem zerfließenden Sonnenuntergang. Ein Pixogramm ist 24 × 24 — und kann trotzdem eine Landschaft sein.' },
      { slug: 'gameoflife',         file: 'gameoflife.pxl',         fps: 5, eyebrow: 'Pixogramm 04', title: 'Game of Life',         body: 'Conways Game of Life, live auf 576 Zellen. Jede Generation rechnet die Uhr selbst — kein Loop, kein Cheat. Ein Bildschirm darf auch einfach denken.' },
    ]
  : [
      { slug: 'ourtinysailboat',    file: 'ourtinysailboat.pxl',    fps: 5, eyebrow: 'Pixogram 01', title: 'Our Tiny Sailboat',    body: 'A small scene that simply happens — a boat, a wave, a horizon. Pixograms do not have to be "smart". Sometimes a quiet picture that breathes is enough.' },
      { slug: 'colourwheeldynamic', file: 'colourwheeldynamic.pxl', fps: 5, eyebrow: 'Pixogram 02', title: 'Colour Wheel Dynamic', body: 'Pure colour, no subject. An HSV wheel that keeps reshuffling itself — the clock turns into a colour palette on the wall and still tells you the second.' },
      { slug: 'mythen',             file: 'mythen.pxl',             fps: 5, eyebrow: 'Pixogram 03', title: 'Mythen',               body: 'The silhouette of the Swiss Mythen mountains over a slow sunset gradient. 24 × 24 pixels are still enough room for a landscape.' },
      { slug: 'gameoflife',         file: 'gameoflife.pxl',         fps: 5, eyebrow: 'Pixogram 04', title: 'Game of Life',         body: 'Conway\'s Game of Life, running live across 576 cells. Every generation is computed on the device — no loop, no cheat. A screen is allowed to just think.' },
    ];
---

{/* Plus⁵ — Hero-only sandbox for Motion (motion.dev).
    Markup + styling of the hero itself mirror Hero.astro 1:1 so the initial
    on-load view is visually identical to Plus⁴. The added wrapping (200vh
    scroll spacer with the hero `position: sticky` inside) is invisible at
    rest — it only becomes meaningful once the user starts scrolling, at
    which point Motion's scroll() scrubs two animations:
      1. .hero__title translates up and fades out
      2. .hero__pic dims its filter:brightness from 1 to 0.2
    After the scroll spacer is consumed, the Variants section follows. */}
<div class="op5-page" data-op5>
  {/* Dev/debug-only act indicator. Pinned to viewport, shows which Act of
      the choreography is currently active based on scroll position. */}
  <div class="op5-act-badge" data-op5-badge aria-hidden="true">
    <span data-op5-badge-num>1</span>
    <span data-op5-badge-name>Hero out</span>
  </div>
  <div class="op5-hero-scroll" data-op5-scroll>
    <div class="op5-hero-sticky">
    <section class="hero">
      <picture class="hero__pic" data-op5-bg>
        <img
          src={url('/img/sections/hero-lifestyle.avif')}
          alt=""
          width="2400"
          height="1600"
        />
      </picture>
      <div class="hero__overlay" aria-hidden="true"></div>
      {/* Clock-only overlay: same image cropped to the PXL Clock with the
          rest transparent. Sits ON TOP of the dim gradient at the same
          positioning as hero__pic so they line up pixel-perfectly. The
          dimming filter only targets hero__pic, so the clock stays at
          full brightness while the background fades. */}
      <picture class="hero__clock" data-op5-clock aria-hidden="true">
        <img
          src={url('/img/sections/hero-lifestyle-clock.webp')}
          alt=""
          width="2400"
          height="1600"
        />
      </picture>
      {/* LED canvas — positioned by JS to align with the LED quadrilateral
          inside the hero photo. The JS uses `object-fit: cover` math
          against the photo's natural aspect ratio so the canvas tracks
          the LED panel across any viewport size. The pixograms render on
          this canvas via renderRgbPhotoreal (same renderer Plus⁴ uses). */}
      <canvas class="hero__led" data-op5-led width="540" height="540" aria-hidden="true"></canvas>
      {/* Chapter panel on the left. One container per chapter, all
          absolute-stacked at the same position; opacity is scrubbed by
          scroll position so they cross-fade through. */}
      <div class="hero__chapters" data-op5-chapters>
        {chapters.map((c, i) => (
          <div
            class="hero__chapter"
            data-op5-chapter
            data-chapter-index={i}
            data-chapter-slug={c.slug}
            data-chapter-file={c.file}
            data-chapter-fps={c.fps}
          >
            <p class="hero__chapter-eyebrow">{c.eyebrow}</p>
            <h2 class="hero__chapter-title">{c.title}</h2>
            <p class="hero__chapter-body">{c.body}</p>
          </div>
        ))}
      </div>
      <div class="hero__inner">
        <h1 class="h-display hero__title" data-op5-title>
          {s.hero.title.map((line) => <span>{line}</span>)}
        </h1>
      </div>
    </section>
    </div>
  </div>

  <Variants locale={locale} />
</div>

<script>
  import { scroll, animate } from 'motion';
  import { parsePxl, type Pixogram } from '../lib/pxl-format';
  import { renderRgbPhotoreal } from '../lib/pixel-canvas';
  import { url } from '../lib/url';

  const page = document.querySelector<HTMLElement>('[data-op5]');
  if (page) {
    const target = page.querySelector<HTMLElement>('[data-op5-scroll]')!;
    const hero = target.querySelector<HTMLElement>('.hero')!;
    const title = page.querySelector<HTMLElement>('[data-op5-title]');
    const bg = page.querySelector<HTMLElement>('[data-op5-bg]');
    const bgImg = bg?.querySelector('img') ?? null;
    const clock = page.querySelector<HTMLElement>('[data-op5-clock]');
    const led = page.querySelector<HTMLCanvasElement>('[data-op5-led]');
    const chapterEls = Array.from(
      page.querySelectorAll<HTMLElement>('[data-op5-chapter]'),
    );

    // Spacer is 700vh; Act 1 still spans 0–75vh of scroll = 10.71% offset
    // (75 / 700). Title translates by exactly the scrolled distance so it
    // leaves at normal page-scroll speed; bg dims to 0.3; clock fades in.
    if (title) {
      scroll(
        animate(title, { y: [0, '-75vh'], opacity: [1, 0] }, { ease: 'linear' }),
        { target, offset: ['start start', '10.71% start'] },
      );
    }
    if (bg) {
      scroll(
        animate(bg, { filter: ['brightness(1)', 'brightness(0.3)'] }, { ease: 'linear' }),
        { target, offset: ['start start', '10.71% start'] },
      );
    }
    if (clock) {
      scroll(
        animate(clock, { opacity: [0, 1] }, { ease: 'linear' }),
        { target, offset: ['start start', '10.71% start'] },
      );
    }

    // ── LED projection ─────────────────────────────────────────────────
    // The LED panel of the PXL Clock in hero-lifestyle.avif sits at a
    // fixed axis-aligned quad in IMAGE coordinates (measured once on the
    // 1989×1119 source). To keep the canvas glued to the LEDs across any
    // viewport size we replay the CSS `object-fit: cover; object-position:
    // center 30%` math in JS: find where the image is actually rendered
    // inside the hero (the cropped/centred region), then map the LED quad
    // from image-space into that rendered area.
    const LED_NATURAL = { w: 1989, h: 1119 };
    const LED_BBOX = { x: 1195, y: 410, w: 480, h: 465 };
    const OBJECT_POS_X = 0.5;
    const OBJECT_POS_Y = 0.3;
    let currentLedHeight = 0; // captured so the chapter loop can scale its translateY range
    function positionLed(): void {
      if (!led || !bg || !hero) return;
      const r = bg.getBoundingClientRect();
      if (r.width === 0 || r.height === 0) return;
      const imgAR = LED_NATURAL.w / LED_NATURAL.h;
      const elAR = r.width / r.height;
      let dispW: number, dispH: number;
      if (imgAR > elAR) {
        // image wider than element → element height fills, width overflows
        dispH = r.height;
        dispW = dispH * imgAR;
      } else {
        dispW = r.width;
        dispH = dispW / imgAR;
      }
      const offX = (r.width - dispW) * OBJECT_POS_X;
      const offY = (r.height - dispH) * OBJECT_POS_Y;
      const scale = dispW / LED_NATURAL.w;
      const ledX = offX + LED_BBOX.x * scale;
      const ledY = offY + LED_BBOX.y * scale;
      const ledW = LED_BBOX.w * scale;
      const ledH = LED_BBOX.h * scale;
      const heroRect = hero.getBoundingClientRect();
      const localLeft = r.left + ledX - heroRect.left;
      const localTop = r.top + ledY - heroRect.top;
      led.style.left = localLeft + 'px';
      led.style.top = localTop + 'px';
      led.style.width = ledW + 'px';
      led.style.height = ledH + 'px';
      // Publish geometry to CSS so the chapter panel can vertically align
      // with the clock without re-doing the cover math in CSS.
      hero.style.setProperty('--op5-led-top', localTop + 'px');
      hero.style.setProperty('--op5-led-height', ledH + 'px');
      currentLedHeight = ledH;
    }
    if (led) {
      positionLed();
      window.addEventListener('resize', positionLed);
      // Re-run after the image loads in case the hero hadn't laid out yet.
      if (bgImg && !bgImg.complete) bgImg.addEventListener('load', positionLed, { once: true });
    }

    // ── Pixogram playback ──────────────────────────────────────────────
    // Single canvas, single rAF loop. The "active" pixogram is whichever
    // chapter has the highest current opacity (computed from scroll). The
    // canvas's own opacity follows the SUM of all chapter opacities (clamped
    // to 1) so it dims to 0 outside the chapter range and stays fully
    // visible during crossfades.
    const pixCache = new Map<string, Pixogram | null>();
    async function loadPx(file: string): Promise<Pixogram | null> {
      if (pixCache.has(file)) return pixCache.get(file) ?? null;
      try {
        const res = await fetch(url('/pixograms/' + file));
        if (!res.ok) throw new Error('http ' + res.status);
        const pix = parsePxl(await res.text());
        pixCache.set(file, pix);
        return pix;
      } catch (e) {
        pixCache.set(file, null);
        return null;
      }
    }
    // Kick off loading all chapter files up front.
    const chapterMeta = chapterEls.map((el) => ({
      el,
      idx: Number(el.dataset.chapterIndex),
      file: el.dataset.chapterFile || '',
      fps: Number(el.dataset.chapterFps) || 5,
    }));
    chapterMeta.forEach((c) => { void loadPx(c.file); });

    // ── Chapter timing ─────────────────────────────────────────────────
    // Per-chapter [fadeInStart, fadeInEnd, fadeOutStart, fadeOutEnd] in vh
    // of scroll. 25vh fade lengths with 100vh holds; ch(N+1)'s fade-in
    // aligns with ch(N)'s fade-out so they cross-fade.
    const FADES: Array<[number, number, number, number]> = [
      [ 75, 100, 150, 175], // ch1: peak 100–150
      [150, 175, 250, 275], // ch2: peak 175–250
      [250, 275, 350, 375], // ch3: peak 275–350
      [350, 375, 450, 475], // ch4: peak 375–450
    ];
    function chapterOpacityAt(progressVh: number, i: number): number {
      const [a, b, c, d] = FADES[i];
      if (progressVh <= a || progressVh >= d) return 0;
      if (progressVh >= b && progressVh <= c) return 1;
      if (progressVh < b) return (progressVh - a) / (b - a);
      return (d - progressVh) / (d - c);
    }
    // translateY for the chapter text. Linear interpolation across the
    // ENTIRE window — no hold in the middle. The text just scrolls up at
    // a constant rate while it's the active chapter, the way a normal
    // paragraph would behave on a non-pinned page. Total travel is
    // 2 × LED-height (from +H below the clock area to −H above it), which
    // keeps the motion confined to roughly the clock's vertical extent.
    const TRAVEL_FACTOR = 1.0; // multiplier on LED-height for each side
    function chapterTranslateAt(progressVh: number, i: number): number {
      const [a, _b, _c, d] = FADES[i];
      const h = currentLedHeight || 400;
      const t = Math.max(0, Math.min(1, (progressVh - a) / (d - a)));
      return (1 - 2 * t) * TRAVEL_FACTOR * h;
    }

    // Animation loop: at every frame, compute opacities, pick the active
    // chapter (highest opacity), paint its current pixogram frame onto
    // the canvas. Frame-stepping is fps-throttled per pixogram.
    const ctx = led?.getContext('2d') ?? null;
    let lastFrameTs = 0;
    let frameCounter = 0;
    let activeIdx = -1;
    function loop(now: number): void {
      // Compute current scroll progress (in vh).
      const rect = target.getBoundingClientRect();
      const progressVh = -rect.top / window.innerHeight * 100;

      // Per-chapter opacity + translateY, plus sum for canvas mask.
      let sum = 0;
      let bestOpacity = -1;
      let bestIdx = -1;
      for (let i = 0; i < chapterMeta.length; i++) {
        const o = chapterOpacityAt(progressVh, i);
        const ty = chapterTranslateAt(progressVh, i);
        chapterMeta[i].el.style.opacity = String(o);
        chapterMeta[i].el.style.transform = `translateY(${ty}px)`;
        sum += o;
        if (o > bestOpacity) { bestOpacity = o; bestIdx = i; }
      }
      if (led) led.style.opacity = String(Math.min(1, sum));

      // Switch the displayed pixogram if the active chapter changed.
      if (bestIdx !== activeIdx) {
        activeIdx = bestIdx;
        frameCounter = 0;
        lastFrameTs = now;
      }

      // Advance & paint at the active chapter's fps.
      if (activeIdx >= 0 && bestOpacity > 0.01 && led && ctx) {
        const meta = chapterMeta[activeIdx];
        const pix = pixCache.get(meta.file);
        if (pix) {
          const intervalMs = 1000 / meta.fps;
          if (now - lastFrameTs >= intervalMs) {
            frameCounter += 1;
            lastFrameTs = now - ((now - lastFrameTs) % intervalMs);
          }
          const frame = pix.frames[frameCounter % pix.frames.length];
          renderRgbPhotoreal(led, frame, pix.width, pix.height);
        }
      }

      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);

    // ── Act badge ──────────────────────────────────────────────────────
    const badgeNum = page.querySelector<HTMLElement>('[data-op5-badge-num]');
    const badgeName = page.querySelector<HTMLElement>('[data-op5-badge-name]');
    if (badgeNum && badgeName) {
      // Thresholds in "viewport heights of scroll", matched to the 700vh
      // spacer geometry (max progress ≈ 7).
      const acts: Array<[number, string, string]> = [
        [0.75, '1', 'Hero out'],
        [1.75, '2', 'Chapter 1'],
        [2.75, '3', 'Chapter 2'],
        [3.75, '4', 'Chapter 3'],
        [4.75, '5', 'Chapter 4'],
        [6,    '6', 'Variants slide'],
        [7,    '7', 'Unpin'],
      ];
      let last = -1;
      let raf = 0;
      const update = () => {
        raf = 0;
        const rect = target.getBoundingClientRect();
        const progress = -rect.top / window.innerHeight;
        let idx = acts.length;
        for (let i = 0; i < acts.length; i++) {
          if (progress < acts[i][0]) { idx = i; break; }
        }
        if (idx !== last) {
          last = idx;
          if (idx === acts.length) {
            badgeNum.textContent = '–';
            badgeName.textContent = 'Post';
          } else {
            badgeNum.textContent = acts[idx][1];
            badgeName.textContent = acts[idx][2];
          }
        }
      };
      const onScroll = () => { if (!raf) raf = requestAnimationFrame(update); };
      window.addEventListener('scroll', onScroll, { passive: true });
      update();
    }
  }
</script>

<style>
  .op5-page {
    background: #0a0a0a;
    color: #fff;
    font-family: 'Inter Tight', -apple-system, system-ui, Helvetica, Arial, sans-serif;

    /* Tunable: how far from the left edge the chapter eyebrow/title/body
       starts. Hero title sits at `padding-left: var(--pad-x)` (= 160px),
       so the chapter sits slightly to the RIGHT of it. Adjust the
       additive offset to move chapters left/right. */
    --op5-chapter-left: calc(var(--pad-x) + 80px);
  }

  /* Dev act indicator: pinned to top-right, always above everything. */
  .op5-act-badge {
    position: fixed;
    top: 14px;
    right: 14px;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #fff;
    font: 500 13px/1 ui-monospace, 'SF Mono', Menlo, monospace;
    letter-spacing: 0.02em;
    pointer-events: none;
    user-select: none;
  }
  .op5-act-badge [data-op5-badge-num] {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 6px;
    background: #fff;
    color: #000;
    font-weight: 700;
    font-size: 11px;
  }
  .op5-act-badge [data-op5-badge-name] {
    opacity: 0.85;
  }

  /* === Scroll spacer + sticky hero ========================================
     Spacer is 7× viewport. Act layout (all in vh of doc scroll):
       Act 1 (0–75):     title scrolls out, bg dims to 0.3, clock fades in
       Act 2 (75–175):   chapter 1 (Our Tiny Sailboat) on the LED canvas
       Act 3 (175–275):  chapter 2 (Colour Wheel Dynamic)
       Act 4 (275–375):  chapter 3 (Mythen)
       Act 5 (375–475):  chapter 4 (Game of Life)
       Act 6 (475–600):  short hold then Variants slides up over pinned hero
                         (Variants top is at doc-y 600 via -100vh margin)
       Act 7 (600–700):  hero un-pins (containerHeight − stickyHeight
                         = 700 − 100 = 600), both move together
     Adjacent chapter fades overlap by 25vh on each boundary, producing a
     smooth crossfade through the LED canvas + text panel. */
  .op5-hero-scroll {
    position: relative;
    height: 700vh;
    z-index: 1;
  }
  /* Sticky wrapper sits OUTSIDE the hero section. Keeping it separate
     avoids fighting the hero's inherited `position: relative` (which would
     otherwise win on specificity and break the pin). The wrapper takes
     exactly one viewport so the hero inside fills it cleanly. */
  .op5-hero-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
  }

  /* Hero styling lifted from Hero.astro so the initial layout matches Plus⁴
     pixel-for-pixel. The only additions are the will-change hints on the
     two animated elements so the compositor pre-promotes them to their own
     layers and doesn't repaint during the scrub. */
  :global(.op5-page .hero) {
    position: relative;
    height: 100vh;
    height: 100dvh;
    min-height: 640px;
    display: flex;
    align-items: center;
    padding-top: 4rem;
    color: #fff;
    overflow: hidden;
    isolation: isolate;
    background: #1a1a1a;
  }
  :global(.op5-page .hero__pic) {
    position: absolute;
    inset: 0;
    z-index: -2;
    will-change: filter;
  }
  :global(.op5-page .hero__pic img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  :global(.op5-page .hero__overlay) {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.62) 0%, rgba(255, 255, 255, 0) 60.982%);
    z-index: -1;
  }
  /* Clock-only overlay layer. Same `inset: 0 + object-fit: cover +
     object-position: center 30%` as .hero__pic so it overlays the
     background pixel-perfectly. Sits above the dim gradient (z-index 0
     beats overlay's -1) and below the inner (which is z-index 1 below).
     pointer-events: none so it never intercepts clicks. */
  :global(.op5-page .hero__clock) {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    will-change: opacity;
  }
  :global(.op5-page .hero__clock img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  :global(.op5-page .hero__inner) {
    position: relative;
    z-index: 3;
    width: 100%;
    padding-top: 120px;
    padding-bottom: 80px;
    padding-left: var(--pad-x);
    padding-right: var(--pad-x);
    box-sizing: border-box;
  }
  :global(.op5-page .hero__title) {
    max-width: none;
    will-change: transform, opacity;
  }
  :global(.op5-page .hero__title span) {
    display: block;
    color: #fff;
  }
  @media (max-width: 720px) {
    :global(.op5-page .hero__inner) { padding-top: 96px; padding-bottom: 48px; }
  }

  /* LED canvas — absolutely positioned, sized to the rendered LED quad of
     the hero photo (the JS sets left/top/width/height every resize). The
     canvas's intrinsic size stays 540×540 (renderRgbPhotoreal handles DPR
     internally) regardless of how the CSS box is sized. */
  :global(.op5-page .hero__led) {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    /* Initial CSS size; JS overrides on layout. Width/height of 0 keeps
       the canvas invisible until positionLed() has run. */
    width: 0;
    height: 0;
    opacity: 0;
    will-change: opacity;
  }

  /* Chapter panel — covers the whole hero; chapters inside are absolutely
     positioned to align with the LED area on the right and the
     --op5-chapter-left rail on the left. */
  :global(.op5-page .hero__chapters) {
    position: absolute;
    z-index: 2;
    inset: 0;
    pointer-events: none;
  }
  /* Each chapter is positioned at the same X (variable) and Y (top of the
     LED panel, published by positionLed). All four overlap; JS scrubs
     opacity and translateY from scroll. The hard-coded `top` fallback
     keeps the layout sensible BEFORE JS has run (and on browsers without
     JS). */
  :global(.op5-page .hero__chapter) {
    position: absolute;
    left: var(--op5-chapter-left);
    width: clamp(280px, 32vw, 440px);
    top: var(--op5-led-top, clamp(120px, 18vh, 220px));
    opacity: 0;
    will-change: opacity, transform;
  }
  :global(.op5-page .hero__chapter-eyebrow) {
    margin: 0 0 0.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }
  :global(.op5-page .hero__chapter-title) {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #fff;
  }
  :global(.op5-page .hero__chapter-body) {
    margin: 0;
    font-size: clamp(0.95rem, 1.05vw, 1.05rem);
