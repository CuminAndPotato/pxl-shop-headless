  }
  .op5-tweak__story-blurb:empty { display: none; }

  /* === Dev tweak panel ====================================================
     Pinned top-left so it doesn't fight the act badge top-right. Wider so
     the corner-bbox inputs fit two-up without squeezing. */
  .op5-tweak {
    position: fixed;
    top: 14px;
    left: 14px;
    z-index: 9998;
    width: 320px;
    background: rgba(10, 12, 18, 0.92);
