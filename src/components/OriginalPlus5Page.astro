  /* LED stage wrapper — carries the matrix3d transform AND the
     visibility opacity. The inner grid stays a regular 2D layer so
     opacity scrubs don't invalidate per-cell rasterisation.
     `clip-path: inset(N% 0 0 0)` clips the TOP of the wrapper in its
     LOCAL coordinate system (before matrix3d). After matrix3d the
     clipped strip lies along the visual top edge of the LED quad.
     `--op5-led-crop-top` is the JS-driven knob (0% = no crop). */
  :global(.op5-page .hero__led-wrap) {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 1;
    pointer-events: none;
    transform-origin: 0 0;
    opacity: 0;
    will-change: opacity, transform;
    clip-path: inset(
      var(--op5-led-crop-top, 0) var(--op5-led-crop-right, 0) 0 0
      round var(--op5-led-corner-top, 0) var(--op5-led-corner-top, 0) 0 0
    );
  }
  /* HTML LED grid — 24×24 cells. Photoreal mode applies the SVG bloom
     filter; Flat strips both the filter AND the per-cell highlight; Off
     paints every cell dark (the JS still updates lastRgb so a return to
     a paint mode triggers a clean diff). */
  :global(.op5-page .hero__led-grid) {
    display: grid;
    grid-template-columns: repeat(24, 1fr);
    grid-template-rows: repeat(24, 1fr);
    width: 100%;
    height: 100%;
    padding: 4px;
    gap: var(--op5-led-grid-gap, 2px);
    background: #050608;
    box-sizing: border-box;
    filter: url(#op5-led-bloom);
