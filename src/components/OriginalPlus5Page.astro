const stories: Story[] = locale === 'de' ? STORIES_DE : STORIES_EN;
const DEFAULT_STORY_ID = 'definition';
---

{/* Plus⁵ — Hero-only sandbox for Motion (motion.dev).
    Markup + styling of the hero itself mirror Hero.astro 1:1 so the initial
    on-load view is visually identical to Plus⁴. The added wrapping (200vh
    scroll spacer with the hero `position: sticky` inside) is invisible at
    rest — it only becomes meaningful once the user starts scrolling, at
    which point Motion's scroll() scrubs two animations:
      1. .hero__title translates up and fades out
      2. .hero__pic dims its filter:brightness from 1 to 0.2
    After the scroll spacer is consumed, the Variants section follows. */}
<div class="op5-page" data-op5>
  {/* Dev/debug-only act indicator. Pinned to viewport, shows which Act of
      the choreography is currently active based on scroll position. */}
  <div class="op5-act-badge" data-op5-badge aria-hidden="true">
    <span data-op5-badge-num>1</span>
    <span data-op5-badge-name>Hero out</span>
  </div>

  {/* Dev tweak panel — render-mode toggle, live FPS, LED bbox inputs.
      Pairs with the four corner grippers (rendered inside .hero) to fine
      tune the canvas projection without code edits. State persists to
      localStorage so adjustments survive reloads. */}
  <aside class="op5-tweak is-collapsed" data-op5-tweak>
    <header class="op5-tweak__head">
      <strong>Plus⁵ Tweak</strong>
      <button type="button" data-op5-tweak-toggle aria-label="Expand">+</button>
    </header>
    <div class="op5-tweak__body">
      <div class="op5-tweak__tabs" role="tablist">
        <button type="button" class="op5-tweak__tab is-active" data-op5-tab="render" role="tab" aria-selected="true">Render</button>
        <button type="button" class="op5-tweak__tab" data-op5-tab="pacing" role="tab" aria-selected="false">Pacing</button>
        <button type="button" class="op5-tweak__tab" data-op5-tab="story" role="tab" aria-selected="false">Story</button>
      </div>

      <div class="op5-tweak__panel" data-op5-tab-panel="render">
        <div class="op5-tweak__row">
          <span>FPS</span>
          <output data-op5-tweak-fps>—</output>
        </div>
        <div class="op5-tweak__row op5-tweak__row--column">
          <span>Render</span>
          <div class="op5-tweak__styles" data-op5-tweak-cellstyle role="radiogroup" aria-label="Render style">
            <button type="button" data-style="off" title="Off · panel paints a uniform off tint, no pixogram content">Off</button>
            <button type="button" data-style="0" title="Lift · vertical multiply, top brightened to ×1.30, bottom dimmed to ×0.80">Lift</button>
            <button type="button" data-style="1" title="Diag · diagonal multiply, top-left ×1.35, bottom-right ×0.72 (studio light)">Diag</button>
            <button type="button" data-style="2" title="Bowl · radial multiply, centre lifted ×1.32, edges sunk to ×0.72">Bowl</button>
            <button type="button" data-style="3" title="Tilt · Bowl with perspective shift — gradient origin walks across the panel">Tilt</button>
            <button type="button" data-style="13" title="Mid · halfway between Tilt and Smooth (×1.26 / ×0.77, radius 0.78)">Mid</button>
            <button type="button" data-style="10" title="Smooth · Tilt with lower contrast (×1.20 / ×0.82), wider falloff radius 0.90">Smooth</button>
            <button type="button" data-style="11" title="Deep · Tilt with higher contrast (×1.45 / ×0.62), tighter focus radius 0.55">Deep</button>
            <button type="button" data-style="12" title="Wide · Tilt with stronger perspective shift (0.30) — hotspot drift is very visible">Wide</button>
            <button type="button" data-style="4" title="Rim · bright cell border ×1.22, slightly dimmed body ×0.90 (rim light)">Rim</button>
            <button type="button" data-style="5" title="Halo · soft radial multiply + axial neighbour-colour bleed">Halo</button>
            <button type="button" data-style="6" title="Inset · full body, sharp dark band around the border (recessed LED feel)">Inset</button>
            <button type="button" data-style="7" title="Split · two-tone vertical, top half ×1.20, bottom half ×0.82, steep mid transition">Split</button>
            <button type="button" data-style="8" title="Soft · gentle radial with perspective, low contrast (×1.12 / ×0.88)">Soft</button>
            <button type="button" data-style="9" title="Glass · Bowl + diagonal additive sheen strip (the look you liked)">Glass</button>
          </div>
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span>Crop top</span>
          <input type="range" data-op5-tweak-croptop min="0" max="5" step="0.1">
          <output data-op5-tweak-croptop-out>0</output>%
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span>Crop right</span>
          <input type="range" data-op5-tweak-cropright min="0" max="5" step="0.1">
          <output data-op5-tweak-cropright-out>0</output>%
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span>Corner top</span>
          <input type="range" data-op5-tweak-cornertop min="0" max="50" step="1">
          <output data-op5-tweak-cornertop-out>0</output>px
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span>Grid gap</span>
          <input type="range" data-op5-tweak-gridgap min="0" max="10" step="0.1">
          <output data-op5-tweak-gridgap-out>2</output>px
        </div>
        <fieldset class="op5-tweak__fs">
          <legend>LED corners (image-px)</legend>
          <label>TL x <input type="number" data-corner="tl" data-axis="x" step="1"></label>
          <label>TL y <input type="number" data-corner="tl" data-axis="y" step="1"></label>
          <label>TR x <input type="number" data-corner="tr" data-axis="x" step="1"></label>
          <label>TR y <input type="number" data-corner="tr" data-axis="y" step="1"></label>
          <label>BR x <input type="number" data-corner="br" data-axis="x" step="1"></label>
          <label>BR y <input type="number" data-corner="br" data-axis="y" step="1"></label>
          <label>BL x <input type="number" data-corner="bl" data-axis="x" step="1"></label>
          <label>BL y <input type="number" data-corner="bl" data-axis="y" step="1"></label>
        </fieldset>
        <div class="op5-tweak__row">
          <label class="op5-tweak__check">
            <input type="checkbox" data-op5-tweak-grippers>
            Show corner grippers
          </label>
        </div>
        <div class="op5-tweak__actions">
          <button type="button" data-op5-tweak-reset>Reset</button>
          <button type="button" data-op5-tweak-copy>Copy</button>
        </div>
      </div>

      <div class="op5-tweak__panel is-hidden" data-op5-tab-panel="pacing">
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="vh, wo Hero KOMPLETT verschwunden ist (Title + Clock-Foto + Dim)">Hero end</span>
          <input type="range" data-op5-pacing="heroend" min="20" max="150" step="1">
          <output data-op5-pacing-out="heroend">50</output>vh
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="vh, wo Akt 1 zentral (REST) liegt — Spacer = Start − Hero end − Text fade">Start</span>
          <input type="range" data-op5-pacing="start" min="25" max="300" step="1">
          <output data-op5-pacing-out="start">120</output>vh
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="Abstand Akt-zu-Akt">Spacing</span>
          <input type="range" data-op5-pacing="spacing" min="30" max="300" step="1">
          <output data-op5-pacing-out="spacing">100</output>vh
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="Länge des Text-Crossfades vor Rest-Position">Text fade</span>
          <input type="range" data-op5-pacing="textfade" min="0" max="120" step="1">
          <output data-op5-pacing-out="textfade">30</output>vh
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="0 = Activation am Fade-In-Start, 0.5 = mid-fade (~50% Opazität), 1 = Activation = Rest (voll sichtbar)">Activation</span>
          <input type="range" data-op5-pacing="activation" min="0" max="1" step="0.05">
          <output data-op5-pacing-out="activation">0.5</output>
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="Dauer des Pixogramm-Crossfades">Pix transition</span>
          <input type="range" data-op5-pacing="pixtransition" min="1" max="80" step="1">
          <output data-op5-pacing-out="pixtransition">20</output>vh
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="Pixogramm-Transition ist X vh VOR der nächsten Activation fertig">Pix margin</span>
          <input type="range" data-op5-pacing="pixmargin" min="-40" max="80" step="1">
          <output data-op5-pacing-out="pixmargin">10</output>vh
        </div>
        <div class="op5-tweak__row op5-tweak__row--slider">
          <span title="Zusätzlicher vh-Abstand nach dem letzten Akt, bevor der nächste Abschnitt (Variants) reinscrollt">Tail hold</span>
          <input type="range" data-op5-pacing="tailhold" min="0" max="200" step="1">
          <output data-op5-pacing-out="tailhold">30</output>vh
        </div>
        <div class="op5-tweak__actions">
          <button type="button" data-op5-pacing-reset>Reset</button>
        </div>
      </div>

      <div class="op5-tweak__panel is-hidden" data-op5-tab-panel="story">
        <div class="op5-tweak__row">
          <span>Aktiv</span>
          <strong data-op5-story-current></strong>
        </div>
        <div class="op5-tweak__story-buttons">
          {stories.map((story) => (
            <button
              type="button"
              class="op5-tweak__story-btn"
              data-op5-story-btn
              data-story-id={story.id}
              title={story.blurb}
            >{story.label}</button>
          ))}
        </div>
        <p class="op5-tweak__story-blurb" data-op5-story-blurb></p>
      </div>
    </div>
  </aside>

  <div class="op5-hero-scroll" data-op5-scroll>
    <div class="op5-hero-sticky">
    <section class="hero">
      <picture class="hero__pic" data-op5-bg>
        <img
          src={url('/img/sections/hero-lifestyle.avif')}
          alt=""
          width="2400"
          height="1600"
        />
      </picture>
      <div class="hero__overlay" aria-hidden="true"></div>
      {/* Dim layer — black overlay whose opacity is scroll-scrubbed in
          Act 1. Replaces `filter: brightness()` on the bg <img> because
          opacity on a flat-colour layer is ~free on the GPU, while a
          filter shader has to run over the entire 2400×1600 bg texture
          each composite. */}
      <div class="hero__dim" data-op5-dim aria-hidden="true"></div>
      {/* Clock-only overlay: same image cropped to the PXL Clock with the
          rest transparent. Sits ON TOP of the dim gradient at the same
          positioning as hero__pic so they line up pixel-perfectly. The
          dimming filter only targets hero__pic, so the clock stays at
          full brightness while the background fades. */}
      <picture class="hero__clock" data-op5-clock aria-hidden="true">
        <img
          src={url('/img/sections/hero-lifestyle-clock.webp')}
          alt=""
          width="2400"
          height="1600"
        />
      </picture>
      {/* LED stage — a wrapper div carries the matrix3d transform; the
          actual LEDs are rendered by a single WebGL canvas. The fragment
          shader paints all 576 cells (per-cell hotspot, gap, rounded
          corners) and crossfades two slot textures, so the per-frame
          main-thread cost is one ~1.7 KB texSubImage2D upload + one
          drawArrays call instead of up to 1728 CSS setProperty calls. */}
      <div class="hero__led-wrap" data-op5-led-wrap aria-hidden="true">
        <canvas class="hero__led-canvas" data-op5-led-canvas></canvas>
      </div>
      {/* Corner grippers — visible only when the tweak panel's "Show
          corner grippers" is on. Each gripper is offset diagonally
          OUTWARD from its LED corner by 50px so the canvas corner stays
          visible inside the gripper bracket. Drag a gripper to adjust the
          LED bbox in image-space. */}
      <div class="hero__grippers" data-op5-grippers hidden>
        <button type="button" class="hero__grip" data-grip="tl" aria-label="Top-left corner"></button>
        <button type="button" class="hero__grip" data-grip="tr" aria-label="Top-right corner"></button>
        <button type="button" class="hero__grip" data-grip="br" aria-label="Bottom-right corner"></button>
        <button type="button" class="hero__grip" data-grip="bl" aria-label="Bottom-left corner"></button>
      </div>
      {/* Chapter panel on the left. One container per chapter, all
          absolute-stacked at the same position; opacity is scrubbed by
          scroll position so they cross-fade through. */}
      {/* Vertical chapter timeline. Seven dots in a column, sitting in
          the gap between the text panel (left) and the LED projection
          (right). Each dot = one chapter; the active one is brighter
          + larger and a thin "progress" line fills upward to the
          active dot's position. JS updates `is-active` per scroll. */}
      <div class="hero__timeline" data-op5-timeline aria-hidden="true">
        <div class="hero__timeline-line"></div>
        <div class="hero__timeline-line hero__timeline-line--fill" data-op5-timeline-fill></div>
        {Array.from({ length: 7 }).map((_, i) => (
          <div class="hero__timeline-dot" data-op5-timeline-dot data-idx={i}>
            <span class="hero__timeline-num">{i + 1}</span>
          </div>
        ))}
      </div>
      <div class="hero__chapters" data-op5-chapters data-active-story={DEFAULT_STORY_ID}>
        {stories.map((story) => story.chapters.map((c, i) => (
          <div
            class="hero__chapter"
            data-op5-chapter
            data-story={story.id}
            data-chapter-index={i}
            data-chapter-slug={c.slug}
            data-chapter-file={c.file}
            data-chapter-fps={c.fps}
          >
            <p class="hero__chapter-eyebrow">
              <span class="hero__chapter-eyebrow-text">{c.eyebrow}</span>
              {c.glyph && <span class="hero__chapter-glyph" aria-hidden="true">{c.glyph}</span>}
            </p>
            <h2 class="hero__chapter-title">{c.title}</h2>
            <p class="hero__chapter-body">{c.body}</p>
          </div>
        )))}
      </div>
      <div class="hero__inner">
        <h1 class="h-display hero__title" data-op5-title>
          {s.hero.title.map((line) => <span>{line}</span>)}
        </h1>
      </div>
    </section>
    </div>
  </div>

  <Variants locale={locale} />

  {/* Hidden SVG defs — additive bloom filter applied to the LED
      canvas's composite output. With one filter source rect (the canvas
      itself, already GPU-rasterised by WebGL) and no per-child paint
      invalidation, the filter cost is fixed per frame and stays on the
      compositor thread. feComposite arithmetic adds the blurred copy
      back on top of the source for a halo. */}
  <svg class="op5-defs" aria-hidden="true" focusable="false">
    <defs>
      <filter id="op5-led-bloom" x="-25%" y="-25%" width="150%" height="150%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="0.5" result="blur" />
        <feComposite in="blur" in2="SourceGraphic" operator="arithmetic" k1="0" k2="0.55" k3="1" k4="0" />
      </filter>
    </defs>
  </svg>
</div>

<script>
  import { parsePxl, type Pixogram } from '../lib/pxl-format';
  // The 24×24 LED panel is rendered by a single WebGL canvas — one draw
  // call per frame, two slot textures composited in the fragment shader.
  // See src/lib/pxl-webgl-renderer.ts for the implementation.
  import { PxlLedRenderer } from '../lib/pxl-webgl-renderer';
  import { cornersToMatrix3d } from '../lib/pxlib-perspective';
  import { url } from '../lib/url';
  import {
    computePacing,
    opacityAt,
    textTranslatePx,
    activeIdxAt,
    type Win,
  } from '../lib/op5-pacing';

  // ═══════════════════════════════════════════════════════════════════
  // ▼▼▼  PACING-KNOBS — Scroll-Choreographie für Plus⁵            ▼▼▼
  // ═══════════════════════════════════════════════════════════════════
  //
  // Modell:  Jeder Akt hat genau einen ACTIVATION-Punkt auf der Scroll-
  // Achse. Bei Akt N's Activation übernimmt der Akt offiziell — Timeline-
  // Dot springt auf N, Text-Opacity ist 1, Pixogramm zeigt Akt N.
  //
  //         Activation 0       Activation 1       Activation 2
  //              │                  │                  │
  //   ───────────●──────────────────●──────────────────●──────────  →
  //              │←──── SPACING ───→│←──── SPACING ───→│
  //              ↑
  //              START
  //
  // Pro Akt gibt es zwei Bezugspunkte auf der Scroll-Achse:
  //   REST[i]        = Text-FOKUS (Translation 0, Opazität 1, zentral).
  //   ACTIVATIONS[i] = wo der Akt offiziell als "aktiv" gilt (Timeline-
  //                    Dot wechselt, Pixogramm-Crossfade endet hier −
  //                    abzgl. MARGIN).
  //
  // START_VH — doc-scroll vh, wo der Fokus von Akt 1 liegt (= Text
  //   zentral, 100% sichtbar).
  //
  // SPACING_VH — Abstand zwischen aufeinanderfolgenden Fokus-Punkten.
  //   Groß = viel Scroll zwischen den Akten, klein = schnelle Folge.
  //
  // TEXT_FADE_VH — Länge des Text-Crossfades in vh. Der Text fadet die
  //   letzten TEXT_FADE vor seiner Rest-Position ein (0 → 1) und die
  //   ersten TEXT_FADE vor der nächsten Rest-Position wieder aus
  //   (synchron zum Fade-In des nächsten Akts = 1:1-Crossfade).
  //
  // ACTIVATION_FRAC — wo im Text-Fade-In die Activation-Linie sitzt:
  //   0.0 = Activation am Fade-In-Anfang (Text taucht auf, ~0%)
  //   0.5 = Activation in der Mitte (Text bei ~50% Opazität, im Anflug)
  //   1.0 = Activation = Rest-Position (Text voll sichtbar, zentral)
  //
  // PIXOGRAM_TRANSITION_VH — Dauer des Pixogramm-Crossfades in vh.
  //
  // PIXOGRAM_MARGIN_VH — wieviel vh die Pixogramm-Transition VOR der
  //   nächsten Activation FERTIG ist. 0 = endet exakt auf der Activation,
  //   positiv = Pixogramm steht schon, wenn der Akt offiziell übernimmt.
  // ═══════════════════════════════════════════════════════════════════
  // Defaults; the Tweak panel (Pacing tab) overrides at runtime and
  // persists via localStorage (settings.pacing.*).
  let HERO_END_VH = 49;
  let START_VH = 59;
  let SPACING_VH = 68;
  let TEXT_FADE_VH = 41;
  let ACTIVATION_FRAC = 1;
  let PIXOGRAM_TRANSITION_VH = 15;
  let PIXOGRAM_MARGIN_VH = 8;
  let TAIL_HOLD_VH = 30;
  // ═══════════════════════════════════════════════════════════════════

  const page = document.querySelector<HTMLElement>('[data-op5]');
  if (page) {
    const target = page.querySelector<HTMLElement>('[data-op5-scroll]')!;
    const hero = target.querySelector<HTMLElement>('.hero')!;
    const title = page.querySelector<HTMLElement>('[data-op5-title]');
    const bg = page.querySelector<HTMLElement>('[data-op5-bg]');
    const bgImg = bg?.querySelector('img') ?? null;
    const dim = page.querySelector<HTMLElement>('[data-op5-dim]');
    const clock = page.querySelector<HTMLElement>('[data-op5-clock]');
    const ledWrap = page.querySelector<HTMLElement>('[data-op5-led-wrap]');
    // The 24×24 LED panel is a single WebGL canvas driven by PxlLedRenderer.
    // It holds two slot textures internally; the shader composites them in
    // a single draw call per frame. See src/lib/pxl-webgl-renderer.ts.
    //
    // Construction is wrapped in try/catch so a shader compile/link error
    // or WebGL-unavailable environment doesn't take the rest of the scroll
    // experience down with it — title, text crossfades, timeline, dev panel
    // all keep working even if the LED canvas itself can't be initialised.
    const ledCanvas = page.querySelector<HTMLCanvasElement>('[data-op5-led-canvas]');
    let ledRenderer: PxlLedRenderer | null = null;
    if (ledCanvas) {
      try {
        ledRenderer = new PxlLedRenderer(ledCanvas);
      } catch (e) {
        console.error('PxlLedRenderer init failed:', e);
        ledCanvas.style.display = 'none';
      }
    }
    // Peek at localStorage for the active story BEFORE the full Settings
    // block runs (the loop + chapter queries below need to filter by
    // story-id, but Settings has TDZ rules and isn't declared yet).
    // CSS already handles the visibility hiding via data-active-story,
    // and the rAF loop will only walk chapters of the active story.
    const VALID_STORY_IDS = ['definition', 'daily', 'campfire', 'diva', 'maker'] as const;
    type StoryId = typeof VALID_STORY_IDS[number];
    let activeStoryId: StoryId = 'definition';
    try {
      const raw = localStorage.getItem('op5-settings-v5');
      if (raw) {
        const parsed = JSON.parse(raw);
        if (typeof parsed.activeStory === 'string' && (VALID_STORY_IDS as readonly string[]).includes(parsed.activeStory)) {
          activeStoryId = parsed.activeStory as StoryId;
        }
      }
    } catch {}
    const chaptersHost = page.querySelector<HTMLElement>('[data-op5-chapters]');
    if (chaptersHost) chaptersHost.dataset.activeStory = activeStoryId;
    const chapterEls = Array.from(
      page.querySelectorAll<HTMLElement>(`[data-op5-chapter][data-story="${activeStoryId}"]`),
    );

    // Act 1 animations (title out, dim in, clock fade in) were previously
    // driven by three separate motion.scroll() calls. Each installed its
    // own scroll listener + per-frame value-apply pipeline, so during
    // Act 1 the scroll thread had four animation handlers (3 motion + 1
    // rAF) all doing redundant work. Consolidated into the main rAF loop
    // below — one scroll handler, one writes-only-when-changed pass.

    // ── LED projection ─────────────────────────────────────────────────
    // The PXL Clock LED panel in hero-lifestyle.avif is a quadrilateral
    // (slight perspective tilt). We store FOUR independent corners in
    // IMAGE coordinates (1989×1119 source) and project them into the
    // hero's local space by replaying the CSS `object-fit: cover;
    // object-position: center 30%` math. The canvas itself sits at
    // hero (0,0) with a fixed base size; `matrix3d` warps it onto the
    // four corner points each layout pass.
    interface Pt { x: number; y: number }
    interface Quad { tl: Pt; tr: Pt; br: Pt; bl: Pt }
    const LED_NATURAL = { w: 1989, h: 1119 };
    // Calibrated against the hero-lifestyle.avif photo. Adjust here OR
    // via the dev tweak panel; the panel writes back to localStorage.
    const DEFAULT_QUAD: Quad = {
      tl: { x: 1208, y: 391 },
      tr: { x: 1672, y: 393 },
      br: { x: 1669, y: 869 },
      bl: { x: 1208, y: 839 },
    };
    // Live, mutable image-space corners. Tweak-panel inputs / gripper
    // drags edit this in place; positionLed reads from it.
    const LED_QUAD: Quad = {
      tl: { ...DEFAULT_QUAD.tl }, tr: { ...DEFAULT_QUAD.tr },
      br: { ...DEFAULT_QUAD.br }, bl: { ...DEFAULT_QUAD.bl },
    };
    const OBJECT_POS_X = 0.5;
    const OBJECT_POS_Y = 0.3; // fixed — matches CSS `object-position: center 30%`
    // Canvas base CSS size — matrix3d transforms this rectangle to the
    // four corners, so the value just needs to be big enough for crisp
    // backbuffer resolution (renderRgbPhotoreal then ups by DPR).
    const CANVAS_BASE = 600;

    // 4 viewport (hero-local) corners — populated by positionLed. Used by
    // the grippers and matrix3d transform.
    const viewQuad: Quad = {
      tl: { x: 0, y: 0 }, tr: { x: 0, y: 0 },
      br: { x: 0, y: 0 }, bl: { x: 0, y: 0 },
    };
    let currentLedScale = 1; // viewport-px per image-px (uniform under cover)
    let currentLedHeight = 0; // avg vertical span of the live quad, for chapter motion amplitude

    let onLedRectChanged: () => void = () => {};

    function positionLed(): void {
      if (!ledWrap || !bg || !hero) return;
      const r = bg.getBoundingClientRect();
      if (r.width === 0 || r.height === 0) return;
      // Cover math against the hero element box (bg <picture> has inset 0).
      const imgAR = LED_NATURAL.w / LED_NATURAL.h;
      const elAR = r.width / r.height;
      let dispW: number, dispH: number;
      if (imgAR > elAR) { dispH = r.height; dispW = dispH * imgAR; }
      else              { dispW = r.width;  dispH = dispW / imgAR; }
      const offX = (r.width - dispW) * OBJECT_POS_X;
      const offY = (r.height - dispH) * OBJECT_POS_Y;
      const scale = dispW / LED_NATURAL.w;
      currentLedScale = scale;
      // Project each image-space corner into hero-local viewport coords.
      const heroRect = hero.getBoundingClientRect();
      const dx = r.left - heroRect.left;
      const dy = r.top - heroRect.top;
      (['tl', 'tr', 'br', 'bl'] as const).forEach((k) => {
        viewQuad[k].x = dx + offX + LED_QUAD[k].x * scale;
        viewQuad[k].y = dy + offY + LED_QUAD[k].y * scale;
      });
      // matrix3d on the wrapper — the LED grid inside is a 2D layer.
      ledWrap.style.left = '0px';
      ledWrap.style.top = '0px';
      ledWrap.style.width = CANVAS_BASE + 'px';
      ledWrap.style.height = CANVAS_BASE + 'px';
      ledWrap.style.transformOrigin = '0 0';
      const toPct = (p: Pt) => ({ x: (p.x / CANVAS_BASE) * 100, y: (p.y / CANVAS_BASE) * 100 });
      ledWrap.style.transform = cornersToMatrix3d(
        { tl: toPct(viewQuad.tl), tr: toPct(viewQuad.tr), br: toPct(viewQuad.br), bl: toPct(viewQuad.bl) },
        CANVAS_BASE, CANVAS_BASE,
      );
      // Average left & right edge heights → used by the chapter animation
      // amplitude. Doesn't drive chapter REST position any more (those
      // values are CSS-fixed) — only how far text travels in its window.
      const leftH = viewQuad.bl.y - viewQuad.tl.y;
      const rightH = viewQuad.br.y - viewQuad.tr.y;
      currentLedHeight = (leftH + rightH) / 2;
      // Sync the GL backbuffer size to the canvas's CSS dimensions × DPR.
      // No-op when nothing changed; cheap enough to call every layout.
      ledRenderer?.resize();
      onLedRectChanged();
    }
    if (ledWrap) {
      positionLed();
      window.addEventListener('resize', positionLed);
      // ResizeObserver catches every size change of the bg element —
      // viewport resize, browser zoom, mobile URL-bar collapse, devtools
      // open/close — even when `resize` doesn't fire. visualViewport
      // covers pinch-zoom on touch devices.
      if (bg && 'ResizeObserver' in window) {
        const ro = new ResizeObserver(() => positionLed());
        ro.observe(bg);
      }
      if (typeof window.visualViewport !== 'undefined' && window.visualViewport) {
        window.visualViewport.addEventListener('resize', positionLed);
      }
      // Re-run after the image loads in case the hero hadn't laid out yet.
      if (bgImg && !bgImg.complete) bgImg.addEventListener('load', positionLed, { once: true });
    }

    // ── Pixogram playback ──────────────────────────────────────────────
    // Single canvas, single rAF loop. The "active" pixogram is whichever
    // chapter has the highest current opacity (computed from scroll). The
    // canvas's own opacity follows the SUM of all chapter opacities (clamped
    // to 1) so it dims to 0 outside the chapter range and stays fully
    // visible during crossfades.
    const pixCache = new Map<string, Pixogram | null>();
    async function loadPx(file: string): Promise<Pixogram | null> {
      if (pixCache.has(file)) return pixCache.get(file) ?? null;
      try {
        const res = await fetch(url('/pixograms/' + file));
        if (!res.ok) throw new Error('http ' + res.status);
        const pix = parsePxl(await res.text());
        pixCache.set(file, pix);
        return pix;
      } catch (e) {
        pixCache.set(file, null);
        return null;
      }
    }
    // Kick off loading all chapter files up front.
    const chapterMeta = chapterEls.map((el) => ({
      el,
      idx: Number(el.dataset.chapterIndex),
      file: el.dataset.chapterFile || '',
      fps: Number(el.dataset.chapterFps) || 5,
    }));
    chapterMeta.forEach((c) => { void loadPx(c.file); });

    // ── Chapter timing ─────────────────────────────────────────────────
    // ACTIVATIONS[i] = scroll-vh where act i is fully active (text at
    //                  rest position AND opacity 1).
    //
    // TEXT_FADES[i] = [a, b, c, d]:
    //   a = Activation_i - TEXT_FADE  (fade-in start, opacity 0)
    //   b = Activation_i              (fade-in end, opacity 1 — REST POS)
    //   c = Activation_{i+1} - TEXT_FADE  (fade-out start)
    //   d = Activation_{i+1}          (fade-out end, opacity 0)
    //
    // Adjacent acts crossfade 1:1 during the last TEXT_FADE before the
    // next activation: act N ramps 1 → 0 while act N+1 ramps 0 → 1, so
    // at Activation_{N+1} the new act is fully visible at its rest pos.
    //
    // PIX_FADES[i] = [a, b, c, d]: same shape but shifted so the
    //   pixogram crossfade ENDS at (Activation_i - MARGIN). With
    //   MARGIN > 0 the pixogram is already in place before the text
    //   officially activates.
    let REST_VHS: number[] = [];
    let ACTIVATIONS: number[] = [];
    let TEXT_FADES: Win[] = [];
    let PIX_FADES: Win[] = [];
    let HERO_END = 1;
    let TOTAL_VH = 700;
    function recomputeFades(): void {
      const p = computePacing(
        {
          heroEndVh: HERO_END_VH,
          startVh: START_VH,
          spacingVh: SPACING_VH,
          textFadeVh: TEXT_FADE_VH,
          activationFrac: ACTIVATION_FRAC,
          pixTransitionVh: PIXOGRAM_TRANSITION_VH,
          pixMarginVh: PIXOGRAM_MARGIN_VH,
          tailHoldVh: TAIL_HOLD_VH,
        },
        chapterMeta.length,
      );
      REST_VHS = p.REST_VHS;
      ACTIVATIONS = p.ACTIVATIONS;
      TEXT_FADES = p.TEXT_FADES;
      PIX_FADES = p.PIX_FADES;
      HERO_END = p.heroEnd;
      TOTAL_VH = p.totalVh;
    }
    recomputeFades();
    function chapterOpacityAt(progressVh: number, i: number): number {
      return opacityAt(progressVh, TEXT_FADES[i]);
    }
    function chapterPixogramOpacityAt(progressVh: number, i: number): number {
      return opacityAt(progressVh, PIX_FADES[i]);
    }
    // translateY for the chapter text. Linear interpolation across the
    // ENTIRE window, scaled to MATCH NORMAL PAGE SCROLL SPEED 1:1 — i.e.
    // when the user scrolls 1 CSS pixel, the text translates -1 CSS
    // pixel. The text feels like a regular paragraph drifting through
    // a sticky-pinned section, not a parallax effect.
    //
    // Math: over (d − a) vh of scroll, the user moves the page by
    // (d − a) × vh / 100 px. We translate the text by the same amount,
    // centred so its rest position is at the middle of the window.
    function chapterTranslateAt(progressVh: number, i: number): number {
      return textTranslatePx(progressVh, REST_VHS[i], vh);
    }

    // ── Settings (persisted) ───────────────────────────────────────────
    // Display switch + LED quad corners are user-tweakable via the dev
    // panel. State lives in `settings` and persists to localStorage.
    interface Settings {
      /** Master display switch. `false` = the panel renders a uniform
       *  off tint regardless of pixogram content / cell style.
       *  Replaced the old 3-way Photoreal/Flat/Off toggle — the cell
       *  style picker IS the look choice now, this is just on/off. */
      enabled: boolean;
      quad: Quad;
      /** 0–100. Percent of the LED wrap height that gets clipped off
       *  the top via `clip-path: inset(N% 0 0 0)`. Purely visual; does
       *  NOT shift the bg image or re-project the LED. */
      cropTop: number;
      /** 0–5. Same idea as cropTop, but clips the right edge. */
      cropRight: number;
      /** 0–50, in CSS px of the LED wrap's local coordinate system
       *  (CANVAS_BASE = 600). Radius applied to the TL + TR corners of
       *  the clip-path inset, softening the top edge. */
      cornerTop: number;
      /** Grid gap between LED cells, in CSS px of the wrap's local
       *  coordinate system (CANVAS_BASE = 600). Smaller = tighter
       *  pixels, more "panel-like"; larger = more visible trenches. */
      gridGap: number;
      /** Selected story arc id (must match one of the entries in the
       *  `stories` array in the frontmatter). The page's chapter set
       *  switches with this value — persisted so reloads keep the
       *  selection. */
      activeStory: string;
      /** LED cell rendering style — 0..9. Each value selects a different
       *  CSS gradient pattern for the cell hotspot (Soft Bulb, Pure Dot,
       *  Backlight, Crystal, Pillow, Hot Core, Frosted, CRT, Matte,
       *  Wide Glow). Applied via `data-cell-style` on both grid slots. */
      cellStyle: number;
      /** Scroll-pacing knobs. Override the defaults declared at the top
       *  of the script via the Tweak panel's Pacing tab. Stored as a
       *  nested object so missing fields fall back cleanly. */
      pacing: {
        heroEndVh: number;
        startVh: number;
        spacingVh: number;
        textFadeVh: number;
        activationFrac: number;
        pixTransitionVh: number;
        pixMarginVh: number;
        tailHoldVh: number;
      };
    }
    // v11: added tailHoldVh — extra scroll padding after the last act's
    // REST before the next section slides in.
    const SETTINGS_KEY = 'op5-settings-v11';
    const DEFAULT_SETTINGS: Settings = {
      enabled: true,
      quad: {
        tl: { ...DEFAULT_QUAD.tl }, tr: { ...DEFAULT_QUAD.tr },
        br: { ...DEFAULT_QUAD.br }, bl: { ...DEFAULT_QUAD.bl },
      },
      cropTop: 1,
      cropRight: 0.8,
      cornerTop: 4,
      gridGap: 1.7,
      activeStory: 'definition',
      cellStyle: 13,
      pacing: {
        heroEndVh: HERO_END_VH,
        startVh: START_VH,
        spacingVh: SPACING_VH,
        textFadeVh: TEXT_FADE_VH,
        activationFrac: ACTIVATION_FRAC,
        pixTransitionVh: PIXOGRAM_TRANSITION_VH,
        pixMarginVh: PIXOGRAM_MARGIN_VH,
        tailHoldVh: TAIL_HOLD_VH,
      },
    };
    function cloneQuad(q: Quad): Quad {
      return { tl: { ...q.tl }, tr: { ...q.tr }, br: { ...q.br }, bl: { ...q.bl } };
    }
    function freshSettings(): Settings {
      return {
        enabled: DEFAULT_SETTINGS.enabled,
        quad: cloneQuad(DEFAULT_SETTINGS.quad),
        cropTop: DEFAULT_SETTINGS.cropTop,
        cropRight: DEFAULT_SETTINGS.cropRight,
        cornerTop: DEFAULT_SETTINGS.cornerTop,
        gridGap: DEFAULT_SETTINGS.gridGap,
        activeStory: DEFAULT_SETTINGS.activeStory,
        cellStyle: DEFAULT_SETTINGS.cellStyle,
        pacing: { ...DEFAULT_SETTINGS.pacing },
      };
    }
    function loadSettings(): Settings {
      try {
        const raw = localStorage.getItem(SETTINGS_KEY);
        if (!raw) return freshSettings();
        const parsed = JSON.parse(raw);
        const q = parsed.quad ?? {};
        return {
          enabled: typeof parsed.enabled === 'boolean' ? parsed.enabled : DEFAULT_SETTINGS.enabled,
          quad: {
            tl: { ...DEFAULT_SETTINGS.quad.tl, ...(q.tl ?? {}) },
            tr: { ...DEFAULT_SETTINGS.quad.tr, ...(q.tr ?? {}) },
            br: { ...DEFAULT_SETTINGS.quad.br, ...(q.br ?? {}) },
            bl: { ...DEFAULT_SETTINGS.quad.bl, ...(q.bl ?? {}) },
          },
          cropTop: typeof parsed.cropTop === 'number' ? parsed.cropTop : DEFAULT_SETTINGS.cropTop,
          cropRight: typeof parsed.cropRight === 'number' ? parsed.cropRight : DEFAULT_SETTINGS.cropRight,
          cornerTop: typeof parsed.cornerTop === 'number' ? parsed.cornerTop : DEFAULT_SETTINGS.cornerTop,
          gridGap: typeof parsed.gridGap === 'number' ? parsed.gridGap : DEFAULT_SETTINGS.gridGap,
          activeStory: typeof parsed.activeStory === 'string' ? parsed.activeStory : DEFAULT_SETTINGS.activeStory,
          cellStyle: typeof parsed.cellStyle === 'number' ? parsed.cellStyle : DEFAULT_SETTINGS.cellStyle,
          pacing: {
            heroEndVh: typeof parsed.pacing?.heroEndVh === 'number' ? parsed.pacing.heroEndVh : DEFAULT_SETTINGS.pacing.heroEndVh,
            startVh: typeof parsed.pacing?.startVh === 'number' ? parsed.pacing.startVh : DEFAULT_SETTINGS.pacing.startVh,
            spacingVh: typeof parsed.pacing?.spacingVh === 'number' ? parsed.pacing.spacingVh : DEFAULT_SETTINGS.pacing.spacingVh,
            textFadeVh: typeof parsed.pacing?.textFadeVh === 'number' ? parsed.pacing.textFadeVh : DEFAULT_SETTINGS.pacing.textFadeVh,
            activationFrac: typeof parsed.pacing?.activationFrac === 'number' ? parsed.pacing.activationFrac : DEFAULT_SETTINGS.pacing.activationFrac,
