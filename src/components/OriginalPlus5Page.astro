  :global(.op5-page .hero__led-grid.is-flat) { filter: none; }
  :global(.op5-page .hero__led-grid.is-off)  { filter: none; }
  :global(.op5-page .hero__led-cell) {
    border-radius: 12%;
    /* Layered backgrounds: the radial-gradient overlay is a constant
       (browser caches the pattern), so changing only --r/--g/--b on the
       solid base lets the compositor re-rasterise just the flat fill. */
    background:
      radial-gradient(circle at 50% 50%,
        rgba(255, 255, 255, 0.18) 0%,
        rgba(255, 255, 255, 0.06) 45%,
        transparent 75%),
      rgb(var(--r, 12), var(--g, 13), var(--b, 16));
  }
  :global(.op5-page .hero__led-grid.is-flat .hero__led-cell) {
    background: rgb(var(--r, 12), var(--g, 13), var(--b, 16));
  }
  :global(.op5-page .hero__led-grid.is-off .hero__led-cell) {
    background: rgb(12, 13, 16);
  }

