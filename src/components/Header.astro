---
import type { Locale } from '../i18n/strings';
import { url } from '../lib/url';
import { t, homeHref } from '../i18n/strings';

interface Props {
  locale: Locale;
  /** "dark" = white text + inverted logo (over hero); "light" = black text on white pages */
  variant?: 'dark' | 'light';
  languageHrefs?: {
    de: string;
    en: string;
  };
}
const { locale, variant = 'dark', languageHrefs } = Astro.props;
const s = t(locale);

const cartHref = locale === 'de' ? url('/de/cart') : url('/cart');
const deHref = languageHrefs?.de ?? url('/de/');
const enHref = languageHrefs?.en ?? '/';
---

<header class={variant === 'light' ? 'site-header site-header--light' : 'site-header'}>
  <div class="header__inner">
    <nav class="header__nav" aria-label="Primary">
      <a href={homeHref(locale)}>{s.nav.product}</a>
      <a href="https://discord.gg/KDbVdKQh5j" target="_blank" rel="noopener">{s.nav.community}</a>
      <a href={homeHref(locale) + '#story'}>{s.nav.about}</a>
    </nav>
    <a class="header__logo" href={homeHref(locale)} aria-label="PXL Clock home">
      <img src={url("/logos/pxl.svg")} alt="PXL" width="120" height="42" />
    </a>
    <div class="header__right">
      <div class="lang" role="group" aria-label="Language">
        <a class={locale === 'de' ? 'lang__btn lang__btn--on' : 'lang__btn'} href={deHref}>DE</a>
        <a class={locale === 'en' ? 'lang__btn lang__btn--on' : 'lang__btn'} href={enHref}>EN</a>
      </div>
      <a class="cart" href={cartHref} aria-label={s.nav.cart} data-cart-link>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 7h12l-1.2 10.5a2 2 0 0 1-2 1.8H9.2a2 2 0 0 1-2-1.8L6 7Z" />
          <path d="M9 7a3 3 0 0 1 6 0" />
        </svg>
        <span class="cart__badge" data-cart-count hidden></span>
      </a>
    </div>
  </div>
</header>

<script>
  import { getCart, CART_CHANGED } from '../lib/shop-browser';
  import type { Cart } from '../lib/shop';

  const badge = document.querySelector<HTMLElement>('[data-cart-count]');
  const link = document.querySelector<HTMLElement>('[data-cart-link]');
  const baseLabel = link?.getAttribute('aria-label') ?? 'Cart';

  function applyCount(n: number) {
    if (!badge || !link) return;
    if (n > 0) {
      badge.textContent = String(n);
      badge.hidden = false;
      link.setAttribute('aria-label', `${baseLabel} (${n})`);
    } else {
      badge.textContent = '';
      badge.hidden = true;
      link.setAttribute('aria-label', baseLabel);
    }
  }

  document.addEventListener(CART_CHANGED, ((e: CustomEvent<Cart>) => {
    applyCount(e.detail.itemCount);
  }) as EventListener);

  getCart()
    .then((cart) => applyCount(cart.itemCount))
    .catch(() => { /* badge stays hidden */ });
</script>

<style>
  .site-header {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: transparent;
    color: #fff;
  }
  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    /* Taller bar + extra top padding so the whole row sits visibly lower from
       the viewport edge. */
    height: 132px;
    padding-top: 24px;
    /* Full-width — same horizontal padding as the hero, so on every viewport
       (including ultra-wide) the nav and the hero headline share the same
       left edge. Body sections still sit inside the centered .container. */
    padding-left: var(--pad-x);
    padding-right: var(--pad-x);
  }
  .header__nav {
    display: flex;
    gap: 2.5rem;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.18em;
  }
  .header__nav a:hover { opacity: 0.75; }
  .header__logo { display: inline-flex; align-items: center; }
  /* Logo is the BLACK pxl.svg; we invert it to white for the dark hero header.
     The gaps between pixels are transparent → header bg shows through as gridlines. */
  .header__logo img {
    height: 56px; width: auto;
    filter: brightness(0) invert(1) drop-shadow(0 1px 10px rgba(0,0,0,0.35));
  }
  .header__right {
    display: flex;
    justify-content: flex-end;
    gap: 1.5rem;
    align-items: center;
  }
  .lang {
    display: inline-flex;
    border: 1px solid rgba(255,255,255,0.55);
    border-radius: 6px;
    overflow: hidden;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .lang__btn {
    padding: 0.55rem 1.1rem;
    color: #fff;
    background: transparent;
  }
  .lang__btn--on { background: #fff; color: #0a0a0a; }
  .cart {
    position: relative;
    color: #fff;
    display: inline-flex;
    align-items: center;
  }
  .cart svg { width: 28px; height: 28px; }
  .cart__badge {
    position: absolute;
    top: -8px; right: -10px;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: 11px;
    background: #fff;
    color: #0a0a0a;
    font-weight: 700;
    font-size: 13px;
    line-height: 22px;
    text-align: center;
    box-shadow: 0 1px 6px rgba(0,0,0,0.25);
  }
  /* Variant when header sits over light section (used post-scroll if needed) */
  .site-header--light { color: var(--fg); }
  .site-header--light .header__logo img { filter: none; } /* keep black */
  .site-header--light .lang { border-color: var(--hairline); }
  .site-header--light .lang__btn { color: var(--fg); }
  .site-header--light .lang__btn--on { background: var(--fg); color: #fff; }
  .site-header--light .cart { color: var(--fg); }
  .site-header--light .cart__badge { background: var(--fg); color: #fff; }

  @media (max-width: 720px) {
    .header__nav { display: none; }
    .header__inner { grid-template-columns: auto 1fr auto; }
    .header__logo { justify-self: start; }
  }
</style>
