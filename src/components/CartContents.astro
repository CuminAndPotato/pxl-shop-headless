---
import type { Cart } from '../lib/shop';
import type { Locale } from '../i18n/strings';
import { t, homeHref } from '../i18n/strings';

interface Props { locale: Locale; cart: Cart }
const { locale, cart } = Astro.props;
const s = t(locale);
const back = locale === 'de' ? '/de/cart' : '/cart';
---

<section class="section cart">
  <div class="container cart__inner">
    <h1 class="h-section cart__title">{s.cart.title}</h1>

    {cart.lineItems.length === 0 ? (
      <div class="cart__empty">
        <p class="lead">{s.cart.empty}</p>
        <a class="btn" href={homeHref(locale)}>{s.cart.backToShop}</a>
      </div>
    ) : (
      <div class="cart__grid">
        <ul class="cart__items">
          {cart.lineItems.map((it) => (
            <li class="cart-item">
              {it.image && <img class="cart-item__img" src={it.image} alt="" loading="lazy" />}
              <div class="cart-item__main">
                <div class="cart-item__name">{it.productName}</div>
                {it.variantLabel && <div class="cart-item__variant">{it.variantLabel}</div>}
                <form method="POST" action="/api/cart/update" class="cart-item__qty-form">
                  <input type="hidden" name="lineItemId" value={it.id} />
                  <input type="hidden" name="back" value={back} />
                  <label class="cart-item__qty">
                    <span class="visually-hidden">{s.cart.qty}</span>
                    <input type="number" name="quantity" value={it.quantity} min="1" max="10" />
                  </label>
                  <button type="submit" class="cart-item__update">↻</button>
                </form>
              </div>
              <div class="cart-item__right">
                <div class="cart-item__price">{it.lineTotal.formatted}</div>
                <form method="POST" action="/api/cart/remove">
                  <input type="hidden" name="lineItemId" value={it.id} />
                  <input type="hidden" name="back" value={back} />
                  <button type="submit" class="cart-item__remove">{s.cart.remove}</button>
                </form>
              </div>
            </li>
          ))}
        </ul>

        <aside class="cart__summary">
          <form method="POST" action="/api/cart/coupon" class="cart__coupon">
            <input type="hidden" name="back" value={back} />
            {cart.appliedDiscount ? (
              <div class="cart__coupon-applied">
                <span>{cart.appliedDiscount.code}</span>
                <button type="submit" name="action" value="remove" class="cart__coupon-remove">{s.cart.couponRemove}</button>
              </div>
            ) : (
              <div class="cart__coupon-input">
                <input type="text" name="code" placeholder={s.cart.couponPlaceholder} autocomplete="off" />
                <button type="submit">{s.cart.couponApply}</button>
              </div>
            )}
          </form>

          <dl class="cart__totals">
            <div>
              <dt>{s.cart.subtotal}</dt>
              <dd>{cart.subtotal.formatted}</dd>
            </div>
            {cart.appliedDiscount && (
              <div class="cart__totals-discount">
                <dt>{s.cart.discount}</dt>
                <dd>−{cart.appliedDiscount.amount.formatted}</dd>
              </div>
            )}
            <div class="cart__totals-grand">
              <dt>{s.cart.total}</dt>
              <dd>{cart.total.formatted}</dd>
            </div>
          </dl>

          <form method="POST" action="/api/cart/checkout">
            <input type="hidden" name="locale" value={locale} />
            <button type="submit" class="btn cart__checkout">{s.cart.checkout}</button>
          </form>
        </aside>
      </div>
    )}
  </div>
</section>

<style>
  .cart { padding-top: 7rem; }
  .cart__inner { max-width: 1100px; margin: 0 auto; }
  .cart__title { font-weight: 700; margin-bottom: 2rem; }

  .cart__empty { text-align: center; padding: 3rem 0; }
  .cart__empty .btn { margin-top: 1rem; }

  .cart__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .cart__items { list-style: none; padding: 0; margin: 0; }
  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--hairline);
  }
  .cart-item__img {
    width: 100px; height: 100px; object-fit: cover; border-radius: 4px;
  }
  .cart-item__name { font-weight: 700; font-size: 1.05rem; }
  .cart-item__variant { color: var(--muted); font-size: 0.9rem; margin-top: 0.25rem; }
  .cart-item__qty-form {
    display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 0.6rem;
  }
  .cart-item__qty input {
    width: 64px; padding: 0.4rem 0.5rem;
    border: 1px solid var(--hairline); border-radius: 4px;
    font-size: 0.95rem;
  }
  .cart-item__update {
    border: 1px solid var(--hairline); background: #fff;
    width: 32px; height: 32px; border-radius: 4px; cursor: pointer; font-size: 1.1rem;
  }
  .cart-item__update:hover { background: #f5f5f5; }
  .cart-item__right { text-align: right; }
  .cart-item__price { font-weight: 700; font-size: 1.05rem; }
  .cart-item__remove {
    background: none; border: 0; padding: 0; margin-top: 0.5rem;
    color: var(--muted); font-size: 0.85rem; cursor: pointer; text-decoration: underline;
  }
  .cart-item__remove:hover { color: var(--fg); }

  .cart__summary {
    position: sticky; top: 100px;
    background: var(--bg-soft);
    padding: 1.5rem;
    border-radius: 8px;
  }
  .cart__coupon { margin-bottom: 1.5rem; }
  .cart__coupon-input { display: flex; gap: 0.5rem; align-items: stretch; }
  .cart__coupon-input input {
    flex: 1;
    height: 44px;
    padding: 0 0.9rem;
    border: 1px solid var(--hairline); border-radius: 4px;
    font-size: 0.95rem; font-family: inherit;
  }
  .cart__coupon-input button {
    height: 44px;
    padding: 0 1.25rem;
    background: #fff; border: 1px solid var(--fg); border-radius: 4px;
    color: var(--fg);
    font-family: inherit;
    font-weight: 700; font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
    /* Override the global .btn min-height/min-width that some browsers apply */
    min-width: 0;
  }
  .cart__coupon-input button:hover { background: #f5f5f5; }
  .cart__coupon-applied {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.7rem 0.9rem;
    background: #fff;
    border: 1px solid #1a7f37; border-radius: 4px;
    color: #1a7f37; font-weight: 700;
  }
  .cart__coupon-remove {
    background: none; border: 0; color: var(--muted);
    font-size: 0.8rem; cursor: pointer; text-decoration: underline;
  }

  .cart__totals { margin: 0 0 1.5rem; padding: 0; }
  .cart__totals > div {
    display: flex; justify-content: space-between;
    padding: 0.5rem 0;
  }
  .cart__totals dt, .cart__totals dd { margin: 0; }
  .cart__totals-discount { color: #1a7f37; }
  .cart__totals-grand {
    border-top: 1px solid var(--hairline);
    margin-top: 0.5rem; padding-top: 1rem !important;
    font-weight: 700; font-size: 1.15rem;
  }
  .cart__checkout { width: 100%; }

  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  @media (max-width: 720px) {
    .cart__grid { grid-template-columns: 1fr; }
    .cart-item { grid-template-columns: 80px 1fr auto; }
    .cart-item__img { width: 80px; height: 80px; }
  }
</style>
