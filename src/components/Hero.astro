---
import type { Locale } from '../i18n/strings';
import { url } from '../lib/url';
import { t } from '../i18n/strings';
import { url } from '../lib/url';

interface Props { locale: Locale }
const { locale } = Astro.props;
const s = t(locale);
---

<section class="hero">
  <picture class="hero__pic">
    <img
      src={url("/img/sections/hero-lifestyle.avif")}
      alt=""
      width="2400"
      height="1600"
    />
  </picture>
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__inner">
    <h1 class="h-display hero__title">
      {s.hero.title.map((line) => <span>{line}</span>)}
    </h1>
  </div>
</section>

<style>
  .hero {
    position: relative;
    /* Always fill the full viewport so the section below never peeks. dvh
       handles mobile-browser URL-bar collapse; vh is the desktop fallback. */
    height: 100vh;
    height: 100dvh;
    min-height: 640px;
    display: flex;
    /* Title sits a touch below center — visually one line lower. */
    align-items: center;
    padding-top: 4rem;
    color: #fff;
    overflow: hidden;
    isolation: isolate;
    background: #1a1a1a;
  }
  .hero__pic {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero__pic img {
    width: 100%;
    height: 100%;
    /* `cover` would zoom in tightly; `contain` shows the whole photo with the
       hero background color filling any unused area on the sides — less crop,
       which is what the live site does. */
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.62) 0%, rgba(255, 255, 255, 0) 60.982%);
    z-index: -1;
  }
  .hero__inner {
    position: relative;
    width: 100%;
    /* Full-width — same horizontal padding as the header, so the headline
       sits at the same x as the nav above. NO .container/max-width, so on
       ultra-wide monitors the headline doesn't get pulled to the centre. */
    padding-top: 120px;
    padding-bottom: 80px;
    padding-left: var(--pad-x);
    padding-right: var(--pad-x);
    box-sizing: border-box;
  }
  .hero__title {
    /* Headline can wrap naturally; no fixed max-width pulling it rightward. */
    max-width: none;
  }
  .hero__title span {
    display: block;
    color: #fff;
  }
  @media (max-width: 720px) {
    .hero__inner { padding-top: 96px; padding-bottom: 48px; }
  }
</style>
