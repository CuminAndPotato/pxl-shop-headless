---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';
import type { Product } from '../lib/shop';
import type { PageVariant } from '../lib/page-variants';
import { lifestyleGallery, workshopGallery } from '../lib/assets';
import { url } from '../lib/url';
import Hero from './Hero.astro';
import ProductPanel from './ProductPanel.astro';
import Gallery from './Gallery.astro';
import Handmade from './Handmade.astro';
import Setup from './Setup.astro';
import OurStory from './OurStory.astro';
import LivePixogramPicker from './LivePixogramPicker.astro';
import AISandbox from './AISandbox.astro';
import StickyPixelStory from './StickyPixelStory.astro';
import SectionDivider from './SectionDivider.astro';
import PixogramLibrary from './PixogramLibrary.astro';
import type { StickyChapter } from './StickyPixelStory.astro';
import {
  stickyChapters as buildStickyChapters,
  makerSteps as buildMakerSteps,
  vscodeCopy as buildVscodeCopy,
  jamCopy as buildJamCopy,
} from '../lib/pxl-page-content';
import BuyButton from './BuyButton.astro';

interface Props {
  locale: Locale;
  variant: PageVariant;
  product: Product | null;
}

const { locale, product } = Astro.props;
const s = t(locale);

// Sticky chapters, maker steps, VS Code copy, JAM copy all live in
// src/lib/pxl-page-content.ts so they're shared with Plus³ (any future Plus
// sibling) and edits stay in one place.
const stickyChapters: StickyChapter[] = buildStickyChapters(locale);
const makerSteps = buildMakerSteps(locale);
const vscodeCopy = buildVscodeCopy(locale);
const jamCopy = buildJamCopy(locale);

// === AI Pipeline / Pixogram Gallery =======================================
const pipelineCopy = locale === 'de'
  ? {
      kicker: 'AI-Pipeline',
      title: 'Jede Idee aus einem GitHub-Issue wird zu einem Pixogramm.',
      lede: 'Auf schlenkr.github.io/pxl-clock läuft eine Live-Model-Shootout: dieselbe Idee — beschrieben in einem GitHub-Issue — wird parallel von mehreren KI-Modellen interpretiert. Mehrere Spalten, mehrere Iterationen, mehrere Stile.',
      models: ['Claude Opus 4.7', 'Sonnet 4.6', 'Gemini', 'GPT-OSS', 'Qwen', 'Nemotron'],
      roles: 'Visionary → Craftsman → Implementor → Maverick',
      footer: 'Multi-Agent-Orchestrierung, Prompt-Caching, byte-stable Prefixes, Konversations-Kompaktierung, Trust-Filter gegen Prompt-Injection. Selbst Open Source: pixogram-maker im PXL-Clock-Repo.',
      cta: 'Gallery ansehen',
    }
  : {
      kicker: 'AI pipeline',
      title: 'Every visual idea from a GitHub issue becomes a pixogram.',
      lede: 'schlenkr.github.io/pxl-clock runs a live model shoot-out: the same idea — described in a GitHub issue — interpreted in parallel by several AI models. Multiple columns, multiple iterations, multiple styles.',
      models: ['Claude Opus 4.7', 'Sonnet 4.6', 'Gemini', 'GPT-OSS', 'Qwen', 'Nemotron'],
      roles: 'Visionary → Craftsman → Implementor → Maverick',
      footer: 'Multi-agent orchestration, prompt caching, byte-stable prefixes, conversation compaction, trust filtering against prompt injection. Itself open source: pixogram-maker inside the PXL Clock repo.',
      cta: 'See the gallery',
    };

const closing = locale === 'de'
  ? { headline: 'Eine Beta-Serie. Eine ehrliche Entscheidung.', body: 'Versand in zwei bis vier Werktagen mit DHL. Mit Promo-Code RONALD sparst du 25 €.', cta: 'Jetzt bestellen' }
  : { headline: 'A beta run. An honest decision.',                body: 'Ships in two to four business days with DHL. Promo code RONALD takes 25 € off.',                       cta: 'Order now' };

const price = product?.discountedPrice?.formatted ?? product?.price?.formatted ?? '229,00€';
const cartHref = locale === 'de' ? url('/de/cart') : url('/cart');
const defaultVariantId = product?.variants[0]?.id ?? '';
---

<div class="op2-page brand-gradient">

<Hero locale={locale} />

<!-- Sticky pixel story — right after the hero, the show-and-tell moment -->
<section class="op2-sticky">
  <StickyPixelStory locale={locale} chapters={stickyChapters} />
</section>

<!-- Compact specs ribbon — inline running specs, no pill chips -->
<section class="op2-ribbon">
  <p>
    {locale === 'de'
      ? '24 × 24 RGB-LEDs · 576 Pixel · echtes Glas · handgefertigter Rahmen · 27 × 27 × 6 cm · 2 kg · WLAN · OTA · Mobile App · C# / .NET · 229 € · Versand aus Deutschland in zwei bis vier Werktagen'
      : '24 × 24 RGB LEDs · 576 pixels · real glass · handmade frame · 27 × 27 × 6 cm · 2 kg · WiFi · OTA · mobile app · C# / .NET · 229 € · ships from Germany in two to four business days'}
  </p>
</section>

<!-- Original product panel — the buy moment -->
<ProductPanel locale={locale} product={product} />

<!-- Lifestyle gallery -->
<Gallery images={lifestyleGallery} ariaLabel={locale === 'de' ? 'Lifestyle-Galerie' : 'Lifestyle gallery'} />

<!-- Maker triptych — from idea to clock in three steps -->
<section class="op2-maker">
  <header class="op2-maker__head">
    <p class="op2-kicker">{locale === 'de' ? 'Werkstatt' : 'Workshop'}</p>
    <h2 class="op2-h">{locale === 'de' ? 'Von der Idee zum Pixogramm — drei Schritte.' : 'From idea to pixogram — three steps.'}</h2>
  </header>
  <ol class="op2-maker__steps">
    {makerSteps.map((step) => (
      <li>
        <p class="op2-maker__tag">{step.tag}</p>
        <h3 class="op2-maker__title">{step.title}</h3>
        <p class="op2-maker__body">{step.body}</p>
      </li>
    ))}
  </ol>
</section>

<!-- VS Code Extension block — dark surface for code-tool context -->
<section class="op2-vscode">
  <SectionDivider side="top" pattern="scallop" fill="#0d1014" height="110px" />
  <div class="op2-vscode__inner">
    <p class="op2-kicker op2-kicker--inv">{vscodeCopy.kicker}</p>
    <h2 class="op2-h op2-h--inv">{vscodeCopy.title}</h2>
    <p class="op2-vscode__lede">{vscodeCopy.lede}</p>
    <ul class="op2-vscode__list">
      {vscodeCopy.bullets.map((b) => <li>{b}</li>)}
    </ul>
    <p class="op2-vscode__meta">
      <a href="https://marketplace.visualstudio.com/items?itemName=pxlclock.pxl-clock" target="_blank" rel="noopener">{vscodeCopy.cta}</a>
      <span>·</span>
      <span class="op2-vscode__metainfo">{vscodeCopy.meta}</span>
    </p>
  </div>
  <SectionDivider side="bottom" pattern="wave-asym" fill="#ffffff" height="120px" />
</section>

<!-- PXL JAM section — community story -->
<section class="op2-jam">
  <div class="op2-jam__inner">
    <div class="op2-jam__copy">
      <p class="op2-kicker">{jamCopy.kicker}</p>
      <h2 class="op2-h">{jamCopy.title}</h2>
      {jamCopy.paragraphs.map((p) => <p class="op2-jam__body">{p}</p>)}
      <p class="op2-jam__links">
        {jamCopy.links.map((l, i) => (
          <>
            {i > 0 && <span class="op2-jam__sep">·</span>}
            <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
          </>
        ))}
      </p>
    </div>
    <figure class="op2-jam__figure">
      <img src={workshopGallery[5]} alt="" loading="lazy" />
      <figcaption>{locale === 'de' ? 'PXL JAM 2024 — Hackathon-Edition, drei Gewinner-Pixogramme aus der Community.' : 'PXL JAM 2024 — hackathon edition, three winning pixograms from the community.'}</figcaption>
    </figure>
  </div>
</section>

<!-- AI Pipeline section — quietly nerdy, fits the dev audience -->
<section class="op2-pipeline">
  <SectionDivider side="top" pattern="arc" fill="rgba(255,255,255,0.4)" height="120px" />
  <div class="op2-pipeline__inner">
    <header class="op2-pipeline__head">
      <p class="op2-kicker">{pipelineCopy.kicker}</p>
      <h2 class="op2-h">{pipelineCopy.title}</h2>
      <p class="op2-pipeline__lede">{pipelineCopy.lede}</p>
    </header>
    <div class="op2-pipeline__grid">
      <div class="op2-pipeline__models">
        <p class="op2-pipeline__sublabel">{locale === 'de' ? 'Modelle, parallel' : 'Models, in parallel'}</p>
        <ul>
          {pipelineCopy.models.map((m) => <li>{m}</li>)}
        </ul>
      </div>
      <div class="op2-pipeline__roles">
        <p class="op2-pipeline__sublabel">{locale === 'de' ? 'Rollen pro Iteration' : 'Roles per iteration'}</p>
        <p class="op2-pipeline__route">{pipelineCopy.roles}</p>
        <p class="op2-pipeline__footer">{pipelineCopy.footer}</p>
        <a class="op2-pipeline__cta" href="https://schlenkr.github.io/pxl-clock/" target="_blank" rel="noopener">
          {pipelineCopy.cta} →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Handmade story -->
<Handmade locale={locale} productId={product?.id} />

<!-- Workshop gallery -->
<Gallery images={workshopGallery} ariaLabel={locale === 'de' ? 'Werkstatt-Galerie' : 'Workshop gallery'} />

<!-- Pixogram library — real clockFaces and scenes rendered as .pxl files,
     replayed in canvas with the photoreal mode. Loaded lazily per card. -->
<section class="op2-library">
  <PixogramLibrary locale={locale} />
</section>

<!-- AI sandbox -->
<section class="op2-sandbox">
  <AISandbox locale={locale} variant="card" tone="light" />
</section>

<!-- Our story — Sefa & Ronald -->
<OurStory locale={locale} />

<!-- Setup -->
<Setup locale={locale} />

<!-- Final CTA -->
<section class="op2-final">
  <div class="op2-final__inner">
    <h2 class="op2-h">{closing.headline}</h2>
    <p>{closing.body}</p>
    <BuyButton
      productId={product?.id}
      variantId={defaultVariantId}
      cartHref={cartHref}
      label={`${closing.cta} · ${price}`}
      class="op2-btn"
    />
  </div>
</section>

</div>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=Mona+Sans:wght@500;600;700&display=swap');
</style>

<style>
  @import '../styles/brand-gradient.css';
  /* Page wrapper — brand gradient is supplied by the imported stylesheet via
     the `.brand-gradient` class added to the wrapper element. */
  .op2-page {
    color: #0a0a0a;
    font-family: 'Inter Tight', -apple-system, system-ui, Helvetica, Arial, sans-serif;
    font-feature-settings: 'tnum' 1;
  }

  /* ===== Page palette + type system ===== */
  /* Body / headings use Inter Tight + Mona Sans (consistent with the other
     fresh pages); code blocks use JetBrains Mono inherited from globals. */
  .op2-kicker {
    margin: 0 0 0.85rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(10, 10, 10, 0.55);
    font-family: 'Inter Tight', -apple-system, system-ui, Helvetica, Arial, sans-serif;
  }
  .op2-kicker--inv { color: rgba(236, 230, 218, 0.7); }
  .op2-h {
    margin: 0 0 1rem;
    font-family: 'Mona Sans', 'Inter Tight', sans-serif;
    font-size: clamp(1.9rem, 3.6vw, 2.9rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #0a0a0a;
  }
  .op2-h--inv { color: #ece6da; }

  /* Sticky story already styles itself; just give it air. */
  .op2-sticky { background: transparent; }

  /* Specs ribbon — single running line, replaces three-card TL;DR */
  .op2-ribbon {
    padding: clamp(2rem, 4vw, 3rem) clamp(1rem, 4vw, 3rem);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(6px);
    border-top: 1px solid rgba(10, 10, 10, 0.08);
    border-bottom: 1px solid rgba(10, 10, 10, 0.08);
  }
  .op2-ribbon p {
    margin: 0 auto;
    max-width: 1080px;
    font-family: 'Inter Tight', sans-serif;
    font-size: clamp(0.92rem, 1.2vw, 1.02rem);
    color: rgba(10, 10, 10, 0.78);
    text-align: center;
    line-height: 1.6;
    letter-spacing: 0.01em;
  }

  /* Maker triptych — three numbered cards */
  .op2-maker {
    padding: clamp(5rem, 10vw, 8rem) clamp(1rem, 4vw, 3rem);
    max-width: 1280px;
    margin: 0 auto;
    font-family: 'Inter Tight', sans-serif;
  }
  .op2-maker__head { max-width: 56ch; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .op2-maker__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .op2-maker__steps li {
    padding: clamp(1.5rem, 3vw, 2.2rem);
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(10, 10, 10, 0.10);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }
  .op2-maker__tag {
    margin: 0 0 1rem;
    font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    color: #485dbd;
    letter-spacing: 0.04em;
  }
  .op2-maker__title {
    margin: 0 0 0.6rem;
    font-family: 'Mona Sans', 'Inter Tight', sans-serif;
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #0a0a0a;
  }
  .op2-maker__body {
    margin: 0;
    color: rgba(10, 10, 10, 0.65);
    line-height: 1.6;
    font-size: 0.96rem;
  }
  @media (max-width: 860px) {
    .op2-maker__steps { grid-template-columns: 1fr; }
  }

  /* VS Code Extension — dark contrast block */
  .op2-vscode {
    position: relative;
    background: #0d1014;
    color: #ece6da;
    padding: clamp(5rem, 10vw, 8rem) 0;
    font-family: 'Inter Tight', sans-serif;
  }
  .op2-vscode__inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    position: relative;
    z-index: 2;
  }
  .op2-vscode__lede {
    margin: 0 0 1.8rem;
    color: rgba(236, 230, 218, 0.78);
    line-height: 1.6;
    font-size: clamp(1rem, 1.3vw, 1.1rem);
  }
  .op2-vscode__list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: grid;
    gap: 0.85rem;
  }
  .op2-vscode__list li {
    padding-left: 1.4rem;
    position: relative;
    color: rgba(236, 230, 218, 0.85);
    line-height: 1.55;
    font-size: 0.98rem;
  }
  .op2-vscode__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 7px;
    height: 7px;
    border-radius: 1px;
    background: #fbb238;
  }
  .op2-vscode__meta {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin: 0;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(236, 230, 218, 0.15);
    font-size: 0.9rem;
  }
  .op2-vscode__meta a {
    color: #fbb238;
    font-weight: 700;
    text-decoration: none;
  }
  .op2-vscode__meta a:hover { text-decoration: underline; }
  .op2-vscode__metainfo {
    font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
    font-size: 0.82rem;
    color: rgba(236, 230, 218, 0.55);
  }

  /* PXL JAM — community block on the gradient */
  .op2-jam {
    padding: clamp(5rem, 10vw, 8rem) clamp(1rem, 4vw, 3rem);
    font-family: 'Inter Tight', sans-serif;
  }
  .op2-jam__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .op2-jam__copy { max-width: 56ch; }
  .op2-jam__body {
    margin: 0 0 1rem;
    color: rgba(10, 10, 10, 0.7);
    line-height: 1.65;
    font-size: clamp(1rem, 1.3vw, 1.08rem);
  }
  .op2-jam__links {
    margin: 1.4rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }
  .op2-jam__links a {
    color: #485dbd;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .op2-jam__sep { color: rgba(10, 10, 10, 0.3); }
  .op2-jam__figure {
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 8px;
  }
  .op2-jam__figure img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .op2-jam__figure figcaption {
    margin-top: 0.9rem;
    color: rgba(10, 10, 10, 0.55);
    font-size: 0.86rem;
    line-height: 1.55;
  }
  @media (max-width: 860px) {
    .op2-jam__inner { grid-template-columns: 1fr; }
  }

  /* AI Pipeline section */
  .op2-pipeline {
    position: relative;
    padding: clamp(5rem, 10vw, 8rem) clamp(1rem, 4vw, 3rem);
    font-family: 'Inter Tight', sans-serif;
  }
  .op2-pipeline__inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .op2-pipeline__head { max-width: 60ch; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .op2-pipeline__lede {
    margin: 0;
    color: rgba(10, 10, 10, 0.7);
    line-height: 1.6;
    font-size: clamp(1rem, 1.3vw, 1.1rem);
  }
  .op2-pipeline__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    padding: clamp(2rem, 4vw, 3rem);
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(10, 10, 10, 0.10);
    border-radius: 12px;
  }
  .op2-pipeline__sublabel {
    margin: 0 0 1rem;
    font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(10, 10, 10, 0.5);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .op2-pipeline__models ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
    border-top: 1px solid rgba(10, 10, 10, 0.10);
  }
  .op2-pipeline__models li {
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(10, 10, 10, 0.10);
    font-size: 0.96rem;
    color: #0a0a0a;
    font-feature-settings: 'tnum' 1;
  }
  .op2-pipeline__route {
    margin: 0 0 1.5rem;
    padding: 1rem 1.2rem;
    background: rgba(72, 93, 189, 0.08);
    border-left: 3px solid #485dbd;
    border-radius: 0 4px 4px 0;
    font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
    font-size: 0.92rem;
    color: #0a0a0a;
    line-height: 1.5;
  }
  .op2-pipeline__footer {
    margin: 0 0 1.5rem;
    color: rgba(10, 10, 10, 0.65);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .op2-pipeline__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #485dbd;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  @media (max-width: 860px) {
    .op2-pipeline__grid { grid-template-columns: 1fr; }
  }

  /* Pixogram library section */
  .op2-library {
    padding: clamp(5rem, 10vw, 8rem) clamp(1rem, 4vw, 3rem);
    background: transparent;
  }
  .op2-library > :global(.pxlib) { max-width: 1280px; margin: 0 auto; }

  /* Sandbox section */
  .op2-sandbox {
    padding: clamp(5rem, 10vw, 8rem) clamp(1rem, 4vw, 3rem);
    background: transparent;
  }
  .op2-sandbox > :global(.ais) { max-width: 1180px; margin: 0 auto; }

  /* Final CTA */
  .op2-final {
    padding: clamp(6rem, 12vw, 10rem) clamp(1rem, 4vw, 3rem);
    text-align: center;
    font-family: 'Inter Tight', sans-serif;
  }
  .op2-final__inner { max-width: 760px; margin: 0 auto; }
  .op2-final p {
    margin: 0 auto 1.6rem;
    color: rgba(10, 10, 10, 0.7);
    line-height: 1.6;
    max-width: 50ch;
  }
  .op2-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.1rem 1.8rem;
    border: 0;
    border-radius: 999px;
    background: #0a0a0a;
    color: #ffffff;
    font-family: inherit;
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    transition: background 160ms ease, transform 160ms ease;
  }
  .op2-btn:hover { background: #000; transform: translateY(-1px); }
</style>

<!-- Page-wide gradient on the wrapper supplied by Plus2's variant container -->
<style>
  /* The fresh-layout wrapper applies the gradient via VariantPage. Plus2
     wants the same brand-world gradient as the other fresh variants, so we
     declare it on a body-level class injected by the layout. */
</style>
