---
import Base from '../layouts/Base.astro';
const locale = 'en';
---

<Base locale={locale} headerVariant="light" title="Thanks for your order · PXL Clock">
  <section class="section thanks">
    <div class="container thanks__inner">
      <p class="eyebrow">Order placed</p>
      <h1 class="h-section">Thanks for your order!</h1>
      <p class="lead">
        We'll send you an email with order confirmation and shipping details. Your PXL Clock is being prepared in Germany.
      </p>
      <p>
        <a href="/" class="btn btn--ghost">Back to shop</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .thanks__inner { max-width: 60ch; text-align: center; margin: 0 auto; }
  .thanks .eyebrow { color: var(--accent); }
  .thanks p { margin-left: auto; margin-right: auto; }
  .thanks .btn { margin-top: 2rem; }
</style>
