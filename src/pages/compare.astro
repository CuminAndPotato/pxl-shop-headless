---
import { url } from '../lib/url';
import Base from '../layouts/Base.astro';
import VariantCompare from '../components/VariantCompare.astro';

const locale = 'en';
---

<Base
  locale={locale}
  title="PXL Clock · Compare variants"
  description="Side-by-side comparison for landing-page variants."
  headerVariant="light"
  languageHrefs={{ de: url('/de/compare'), en: url('/compare') }}
>
  <VariantCompare locale={locale} />
</Base>