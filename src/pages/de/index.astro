---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import ProductPanel from '../../components/ProductPanel.astro';
import Gallery from '../../components/Gallery.astro';
import Variants from '../../components/Variants.astro';
import Statement from '../../components/Statement.astro';
import Handmade from '../../components/Handmade.astro';
import CreateItYourself from '../../components/CreateItYourself.astro';
import Setup from '../../components/Setup.astro';
import OurStory from '../../components/OurStory.astro';
import { t } from '../../i18n/strings';
import { lifestyleGallery, workshopGallery, shapeSpacesBg, startedBg } from '../../lib/assets';
import { getBuildTimeProduct } from '../../lib/build-shop';

const locale = 'de';
const s = t(locale);
const product = await getBuildTimeProduct();
---

<Base
  locale={locale}
  title={`${product?.name ?? 'PXL Clock'} · programmierbare Pixeluhr`}
  description="Programmierbare 24x24 RGB-LED Pixeluhr. C# / .NET. Echtes Glas, handgefertigt in Deutschland."
>
  <Hero locale={locale} />
  <ProductPanel locale={locale} product={product} />
  <Gallery images={lifestyleGallery} ariaLabel="Lifestyle-Galerie" />
  <Variants locale={locale} />
  <Statement line1={s.shapeSpaces.line1} line2={s.shapeSpaces.line2} bgImage={shapeSpacesBg} />
  <Handmade locale={locale} productId={product?.id} />
  <Gallery images={workshopGallery} ariaLabel="Werkstatt-Galerie" />
  <Statement line1={s.started.line1} line2={s.started.line2} bgImage={startedBg} />
  <CreateItYourself locale={locale} />
  <Setup locale={locale} />
  <OurStory locale={locale} />
</Base>
