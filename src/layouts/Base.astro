---
import type { Locale } from '../i18n/strings';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
}
const { locale, title, description } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" hreflang="en" href={Astro.site ? new URL('/', Astro.site).toString() : '/'} />
    <link rel="alternate" hreflang="de" href={Astro.site ? new URL('/de/', Astro.site).toString() : '/de/'} />
  </head>
  <body>
    <Header locale={locale} variant={headerVariant} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
